@page "/Account/Manage/PersonalData"

@using Microsoft.AspNetCore.Identity
@using DinoBlazorApp_v2.Data

@inject UserManager<ApplicationUser> UserManager
@inject IdentityRedirectManager RedirectManager

<PageTitle>@T["Personal Data"]</PageTitle>

<StatusMessage />
<h3>@T["Personal Data"]</h3>

<div class="row">
    <div class="col-md-6">
        <p>@T["Your account contains personal data that you have given us. This page allows you to download or delete that data."]</p>
        <p>
            <strong>@T["Deleting this data will permanently remove your account, and this cannot be recovered."]</strong>
        </p>
        <form action="Account/Manage/DownloadPersonalData" method="post">
            <AntiforgeryToken />
            <button class="btn btn-primary" type="submit">@T["Download"]</button>
        </form>
        <p>
            <a href="Account/Manage/DeletePersonalData" class="btn btn-danger">@T["Delete"]</a>
        </p>
    </div>
</div>

@code {
    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        var user  = await UserManager.GetUserAsync(HttpContext.User);
        if (user is null)
        {
            RedirectManager.RedirectToInvalidUser(UserManager, HttpContext);
        }
    }
}

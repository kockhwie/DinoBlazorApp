@* MOBILE DRAWER *@
@if (IsMobileDrawerOpen)
{
    <div class="nav-bg on" @onclick="CloseDrawer"></div>
}
<div class="nav-drawer @(IsMobileDrawerOpen ? "on" : "")">
    <div class="nav-head">
        <div class="nav-head-b">
            <span class="logo-anim" style="width: 32px; height: 32px;"></span>
            <span class="nd-lbl">Menu</span>
        </div>
        <button class="nav-close" @onclick="CloseDrawer"><i class="ti ti-x"></i></button>
    </div>

    <div class="nav-sec"></div>
    <a href="/" class="nav-lnk @(CurrentPath == "" ? "on" : "")"><span class="ni"><i class="ti ti-home"></i></span><span class="nl">Home</span></a>
    <button class="nav-lnk"><span class="ni"><i class="ti ti-library"></i></span><span class="nl">Prompt Library</span><span class="nav-soon">Soon</span></button>
    <button class="nav-lnk"><span class="ni"><i class="ti ti-bulb"></i></span><span class="nl">Learning Snippets</span><span class="nav-soon">Soon</span></button>
    <button class="nav-lnk"><span class="ni"><i class="ti ti-history"></i></span><span class="nl">My History</span><span class="nav-soon">Soon</span></button>

    <div class="nav-div"></div>
    <div class="nav-sec">Account</div>
    <button class="nav-lnk"><span class="ni"><i class="ti ti-user-circle"></i></span><span class="nl">Profile</span><span class="nav-soon">Soon</span></button>
    <button class="nav-lnk"><span class="ni"><i class="ti ti-settings"></i></span><span class="nl">Settings</span><span class="nav-soon">Soon</span></button>
    <button class="nav-lnk">
        <span class="ni">
            <dotlottie-player src="/assets/icons/animate-antenna.json" 
                             background="transparent" 
                             speed="1" 
                             style="width: 20px; height: 20px;" 
                             loop 
                             autoplay>
            </dotlottie-player>
        </span>
        <span class="nl">System Status</span>
    </button>

    <div class="nav-div"></div>
    <div class="nav-sec">Community</div>
    <a href="/feedback" class="nav-lnk @(CurrentPath == "feedback" ? "on" : "")"><span class="ni"><i class="ti ti-message-circle"></i></span><span class="nl">Feedback &amp; Wishlist</span><span class="nav-new">New</span></a>
    <a href="/release-notes" class="nav-lnk @(CurrentPath == "release-notes" ? "on" : "")"><span class="ni"><i class="ti ti-file-description"></i></span><span class="nl">Release Notes</span></a>

    <div class="nav-div"></div>
    <button class="nav-lnk" style="color:var(--amber)">
        <span class="ni"><i class="ti ti-key"></i></span><span class="nl">Sign In / Register</span><span class="nav-soon">Soon</span>
    </button>

    <div class="nav-foot">v1.3.3 · Dino Prompt Academy</div>
</div>

@implements IDisposable

@code {
    [Parameter] public bool IsMobileDrawerOpen { get; set; }
    [Parameter] public EventCallback<bool> IsMobileDrawerOpenChanged { get; set; }

    [Inject] private NavigationManager NavManager { get; set; } = default!;

    public string CurrentPath => NavManager.ToBaseRelativePath(NavManager.Uri);

    protected override void OnInitialized()
    {
        NavManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        NavManager.LocationChanged -= OnLocationChanged;
    }

    private async Task CloseDrawer()
    {
        IsMobileDrawerOpen = false;
        await IsMobileDrawerOpenChanged.InvokeAsync(false);
    }
}

        <span class="gn-dino">🦕</span>
    </div>
    
    <div class="gn-links">
        <a href="/" class="gn-link @(CurrentPath == "" ? "on" : "")" title="Academy Home">
            <span class="ni">🏠</span>
            <span class="gn-lbl">Home</span>
        </a>
        <a href="/release-notes" class="gn-link @(CurrentPath == "release-notes" ? "on" : "")" title="Release Notes">
            <span class="ni">📋</span>
            <span class="gn-lbl">Release Notes</span>
        </a>
        <a href="/feedback" class="gn-link @(CurrentPath == "feedback" ? "on" : "")" title="Feedback & Wishlist">
            <span class="ni" style="position:relative;">💬</span>
            <span class="gn-lbl">Feedback & Wishlist</span>
        </a>
    </div>

    <div class="gn-bottom">
        <button class="gn-link soon" title="Profile (Soon)">
            <span class="ni">👤</span>
        </button>
        <button class="gn-link soon" title="Settings (Soon)">
            <span class="ni">⚙️</span>
        </button>

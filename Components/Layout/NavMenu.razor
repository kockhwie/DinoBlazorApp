<!-- DESKTOP NAV RAIL -->
<div class="hidden md:flex flex-col w-[68px] bg-[#080a0f] border-r border-dino-bdr items-center py-5 gap-0 shrink-0 z-[100]">

    <!-- Brand Icon -->
    <div class="mb-7">
        <iconify-icon icon="game-icons:dinosaur-bones" width="40" height="40" class="text-dino-amber animate-dino-float"></iconify-icon>
    </div>

    <!-- Nav Links -->
    <div class="flex flex-col gap-4 flex-1 w-full items-center">
        <a href="/" class="group relative flex items-center justify-center w-11 h-11 rounded-xl border transition-all duration-200
                           @(CurrentPath == "" ? "bg-dino-amber/10 border-dino-ambers text-dino-amber" : "bg-transparent border-transparent text-dino-muted hover:bg-dino-surf2 hover:border-dino-bdr hover:text-dino-cream")"
           title="Academy Home">
            <iconify-icon icon="glyphs-poly:house" width="28" height="28"></iconify-icon>
            <span class="absolute left-14 bg-dino-surf3 text-dino-cream px-3 py-1.5 rounded-md text-xs font-semibold
                         opacity-0 pointer-events-none -translate-x-2 transition-all duration-200 whitespace-nowrap z-50 shadow-xl
                         group-hover:opacity-100 group-hover:translate-x-0">Home</span>
        </a>
        <a href="/release-notes" class="group relative flex items-center justify-center w-11 h-11 rounded-xl border transition-all duration-200
                                        @(CurrentPath == "release-notes" ? "bg-dino-amber/10 border-dino-ambers text-dino-amber" : "bg-transparent border-transparent text-dino-muted hover:bg-dino-surf2 hover:border-dino-bdr hover:text-dino-cream")"
           title="Release Notes">
            <iconify-icon icon="glyphs-poly:note-pad" width="28" height="28"></iconify-icon>
            <span class="absolute left-14 bg-dino-surf3 text-dino-cream px-3 py-1.5 rounded-md text-xs font-semibold
                         opacity-0 pointer-events-none -translate-x-2 transition-all duration-200 whitespace-nowrap z-50 shadow-xl
                         group-hover:opacity-100 group-hover:translate-x-0">Release Notes</span>
        </a>
        <a href="/feedback" class="group relative flex items-center justify-center w-11 h-11 rounded-xl border transition-all duration-200
                                   @(CurrentPath == "feedback" ? "bg-dino-amber/10 border-dino-ambers text-dino-amber" : "bg-transparent border-transparent text-dino-muted hover:bg-dino-surf2 hover:border-dino-bdr hover:text-dino-cream")"
           title="Feedback & Wishlist">
            <iconify-icon icon="glyphs-poly:comment-2" width="28" height="28"></iconify-icon>
            <span class="absolute left-14 bg-dino-surf3 text-dino-cream px-3 py-1.5 rounded-md text-xs font-semibold
                         opacity-0 pointer-events-none -translate-x-2 transition-all duration-200 whitespace-nowrap z-50 shadow-xl
                         group-hover:opacity-100 group-hover:translate-x-0">Feedback &amp; Wishlist</span>
        </a>
    </div>

    <!-- Bottom: Profile / Settings (coming soon) -->
    <div class="flex flex-col gap-4 w-full items-center">
        <button class="group relative flex items-center justify-center w-11 h-11 rounded-xl border border-transparent
                       text-dino-muted opacity-40 cursor-not-allowed" title="Profile (Soon)">
            <iconify-icon icon="line-md:account" width="24" height="24"></iconify-icon>
            <span class="absolute left-14 bg-dino-surf3 text-dino-cream px-3 py-1.5 rounded-md text-xs font-semibold
                         opacity-0 pointer-events-none -translate-x-2 transition-all duration-200 whitespace-nowrap z-50 shadow-xl
                         group-hover:opacity-100 group-hover:translate-x-0">Profile</span>
        </button>
        <button class="group relative flex items-center justify-center w-11 h-11 rounded-xl border border-transparent
                       text-dino-muted opacity-40 cursor-not-allowed" title="Settings (Soon)">
            <iconify-icon icon="glyphs-poly:cog" width="28" height="28"></iconify-icon>
            <span class="absolute left-14 bg-dino-surf3 text-dino-cream px-3 py-1.5 rounded-md text-xs font-semibold
                         opacity-0 pointer-events-none -translate-x-2 transition-all duration-200 whitespace-nowrap z-50 shadow-xl
                         group-hover:opacity-100 group-hover:translate-x-0">Settings</span>
        </button>
    </div>
</div>

<!-- MOBILE DRAWER BACKDROP -->
@if (IsMobileDrawerOpen)
{
    <div class="fixed inset-0 bg-black/60 z-[200] md:hidden" @onclick="CloseDrawer"></div>
}

<!-- MOBILE DRAWER PANEL -->
<div class="fixed top-0 right-0 bottom-0 w-[74vw] max-w-[290px] bg-dino-surf border-l border-dino-bdr z-[201]
            flex flex-col overflow-y-auto transition-transform duration-[350ms] ease-[cubic-bezier(.34,1.56,.64,1)] md:hidden
            @(IsMobileDrawerOpen ? "translate-x-0" : "translate-x-full")">

    <!-- Drawer Header -->
    <div class="flex items-center justify-between px-4 py-4 border-b border-dino-bdr shrink-0">
        <div class="flex items-center gap-2">
            <span class="logo-anim" style="width: 32px; height: 32px;"></span>
            <span class="font-display font-bold text-sm text-dino-cream">Menu</span>
        </div>
        <button class="text-dino-muted hover:text-dino-cream transition-colors text-lg" @onclick="CloseDrawer">
            <i class="ti ti-x"></i>
        </button>
    </div>

    <!-- Nav Links -->
    <div class="text-[10px] font-bold text-dino-muted2 uppercase tracking-widest px-4 pt-3 pb-1">Learn</div>
    <a href="/" class="flex items-center gap-3 px-4 py-3 text-dino-creamd text-sm hover:bg-dino-surf2 transition-colors @(CurrentPath == "" ? "text-dino-amber" : "")">
        <i class="ti ti-home w-5 text-center text-base shrink-0"></i><span class="flex-1">Home</span>
    </a>
    <button class="flex items-center gap-3 px-4 py-3 text-dino-creamd text-sm hover:bg-dino-surf2 transition-colors w-full text-left">
        <i class="ti ti-library w-5 text-center text-base shrink-0"></i><span class="flex-1">Prompt Library</span>
        <span class="text-[10px] bg-dino-surf3 text-dino-muted border border-dino-bdr px-1.5 py-0.5 rounded-full">Soon</span>
    </button>
    <button class="flex items-center gap-3 px-4 py-3 text-dino-creamd text-sm hover:bg-dino-surf2 transition-colors w-full text-left">
        <i class="ti ti-bulb w-5 text-center text-base shrink-0"></i><span class="flex-1">Learning Snippets</span>
        <span class="text-[10px] bg-dino-surf3 text-dino-muted border border-dino-bdr px-1.5 py-0.5 rounded-full">Soon</span>
    </button>
    <button class="flex items-center gap-3 px-4 py-3 text-dino-creamd text-sm hover:bg-dino-surf2 transition-colors w-full text-left">
        <i class="ti ti-history w-5 text-center text-base shrink-0"></i><span class="flex-1">My History</span>
        <span class="text-[10px] bg-dino-surf3 text-dino-muted border border-dino-bdr px-1.5 py-0.5 rounded-full">Soon</span>
    </button>

    <div class="h-px bg-dino-bdr mx-4 my-1.5"></div>
    <div class="text-[10px] font-bold text-dino-muted2 uppercase tracking-widest px-4 pt-2 pb-1">Account</div>
    <button class="flex items-center gap-3 px-4 py-3 text-dino-creamd text-sm hover:bg-dino-surf2 transition-colors w-full text-left">
        <i class="ti ti-user-circle w-5 text-center text-base shrink-0"></i><span class="flex-1">Profile</span>
        <span class="text-[10px] bg-dino-surf3 text-dino-muted border border-dino-bdr px-1.5 py-0.5 rounded-full">Soon</span>
    </button>
    <button class="flex items-center gap-3 px-4 py-3 text-dino-creamd text-sm hover:bg-dino-surf2 transition-colors w-full text-left">
        <i class="ti ti-settings w-5 text-center text-base shrink-0"></i><span class="flex-1">Settings</span>
        <span class="text-[10px] bg-dino-surf3 text-dino-muted border border-dino-bdr px-1.5 py-0.5 rounded-full">Soon</span>
    </button>

    <div class="h-px bg-dino-bdr mx-4 my-1.5"></div>
    <div class="text-[10px] font-bold text-dino-muted2 uppercase tracking-widest px-4 pt-2 pb-1">Community</div>
    <a href="/feedback" class="flex items-center gap-3 px-4 py-3 text-dino-creamd text-sm hover:bg-dino-surf2 transition-colors @(CurrentPath == "feedback" ? "text-dino-amber" : "")">
        <i class="ti ti-message-circle w-5 text-center text-base shrink-0"></i>
        <span class="flex-1">Feedback &amp; Wishlist</span>
        <span class="text-[10px] bg-dino-amber/15 text-dino-amber border border-dino-ambers px-1.5 py-0.5 rounded-full">New</span>
    </a>
    <a href="/release-notes" class="flex items-center gap-3 px-4 py-3 text-dino-creamd text-sm hover:bg-dino-surf2 transition-colors @(CurrentPath == "release-notes" ? "text-dino-amber" : "")">
        <i class="ti ti-file-description w-5 text-center text-base shrink-0"></i><span class="flex-1">Release Notes</span>
    </a>

    <div class="h-px bg-dino-bdr mx-4 my-1.5"></div>
    <button class="flex items-center gap-3 px-4 py-3 text-dino-amber text-sm hover:bg-dino-surf2 transition-colors w-full text-left">
        <i class="ti ti-key w-5 text-center text-base shrink-0"></i>
        <span class="flex-1">Sign In / Register</span>
        <span class="text-[10px] bg-dino-surf3 text-dino-muted border border-dino-bdr px-1.5 py-0.5 rounded-full">Soon</span>
    </button>

    <!-- Drawer Footer -->
    <div class="mt-auto px-4 py-4 border-t border-dino-bdr text-[10px] text-dino-muted2">
        v1.3.3 · Dino Prompt Academy
    </div>
</div>

@implements IDisposable

@code {
    [Parameter] public bool IsMobileDrawerOpen { get; set; }
    [Parameter] public EventCallback<bool> IsMobileDrawerOpenChanged { get; set; }

    [Inject] private NavigationManager NavManager { get; set; } = default!;

    public string CurrentPath => NavManager.ToBaseRelativePath(NavManager.Uri);

    protected override void OnInitialized()
    {
        NavManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        NavManager.LocationChanged -= OnLocationChanged;
    }

    private async Task CloseDrawer()
    {
        IsMobileDrawerOpen = false;
        await IsMobileDrawerOpenChanged.InvokeAsync(false);
    }
}

@inject NavigationManager NavigationManager

<nav class="navbar site-nav">
    <div class="navbar-start gap-2">
        <div class="dropdown lg:hidden">
            <div tabindex="0" role="button" class="btn btn-square btn-sm nav-menu-toggle" aria-label="@T["Open navigation menu"]">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                </svg>
            </div>
            <ul tabindex="0" class="menu menu-sm dropdown-content z-50 mt-4 w-56 rounded-box nav-menu p-2 shadow-2xl">
                <li>
                    <details name="mobile-nav">
                        <summary>@T["Courses"]</summary>
                        <ul class="p-1">
                            <li><a href="#">@T["Starter Path"]</a></li>
                            <li><a href="#">@T["Advanced Path"]</a></li>
                            <li><a href="#">@T["Projects"]</a></li>
                        </ul>
                    </details>
                </li>
                <li><a href="#">@T["AI Tools"]</a></li>
                <li>
                    <details name="mobile-nav">
                        <summary>@T["Resources"]</summary>
                        <ul class="p-1">
                            <li><a href="#">@T["Guides"]</a></li>
                            <li><a href="#">@T["Templates"]</a></li>
                            <li><a href="#">@T["Videos"]</a></li>
                        </ul>
                    </details>
                </li>
                <li><a href="#">@T["Community"]</a></li>
            </ul>
        </div>

        <a href="/" class="brand-link" aria-label="@T["Dino AI Academy home"]">
            <img alt="@T["Dino mascot"]" class="brand-mark" src="@Assets["assets/company_logo.png"]" />
            <img alt="@T["Dino AI Academy"]" class="brand-wordmark" src="@Assets["assets/company_name.png"]" />
        </a>
    </div>

    <div class="navbar-center hidden lg:flex">
        <ul class="menu menu-horizontal menu-sm items-center gap-1 px-1 nav-links">
            <li>
                <details class="nav-dropdown" name="primary-nav">
                    <summary>@T["Courses"]</summary>
                    <ul class="rounded-box nav-menu p-2 shadow-2xl">
                        <li><a href="#">@T["Starter Path"]</a></li>
                        <li><a href="#">@T["Advanced Path"]</a></li>
                        <li><a href="#">@T["Projects"]</a></li>
                    </ul>
                </details>
            </li>
            <li><a href="#">@T["AI Tools"]</a></li>
            <li>
                <details class="nav-dropdown" name="primary-nav">
                    <summary>@T["Resources"]</summary>
                    <ul class="rounded-box nav-menu p-2 shadow-2xl">
                        <li><a href="#">@T["Guides"]</a></li>
                        <li><a href="#">@T["Templates"]</a></li>
                        <li><a href="#">@T["Videos"]</a></li>
                    </ul>
                </details>
            </li>
            <li><a href="#">@T["Community"]</a></li>
        </ul>
    </div>

    <div class="navbar-end gap-3">
        <div class="join join-horizontal border border-base-300/70 rounded-btn overflow-hidden">
            <a class="@GetLanguageButtonClass("en-US")" href="@GetCultureUrl("en-US")" aria-pressed="@IsCurrentCulture("en-US")">EN</a>
            <a class="@GetLanguageButtonClass("zh-Hant")" href="@GetCultureUrl("zh-Hant")" aria-pressed="@IsCurrentCulture("zh-Hant")">繁中</a>
        </div>
        <a href="/membership" class="btn btn-sm sm:btn-md shadow-none nav-login">@T["Log in"]</a>
        <a href="/membership" class="btn btn-sm sm:btn-md nav-join">@T["Join Academy"]</a>
    </div>
</nav>

@code {
    private string GetCurrentReturnUrl()
    {
        var uri = new Uri(NavigationManager.Uri);
        var path = uri.AbsolutePath;
        return string.IsNullOrWhiteSpace(path) || path == "/" ? "/" : "/" + path.TrimStart('/');
    }

    private string GetCultureUrl(string culture) =>
        $"/culture/set?culture={Uri.EscapeDataString(culture)}&returnUrl={Uri.EscapeDataString(GetCurrentReturnUrl())}";

    private bool IsCurrentCulture(string culture) =>
        string.Equals(CultureInfo.CurrentUICulture.Name, culture, StringComparison.OrdinalIgnoreCase);

    private string GetLanguageButtonClass(string culture)
    {
        var active = IsCurrentCulture(culture);
        return active
            ? "btn btn-xs sm:btn-sm btn-primary rounded-none border-0"
            : "btn btn-xs sm:btn-sm btn-ghost rounded-none border-0";
    }

    private Task ChangeToEn()
    {
        NavigationManager.NavigateTo(GetCultureUrl("en-US"), forceLoad: true);
        return Task.CompletedTask;
    }

    private Task ChangeToZh()
    {
        NavigationManager.NavigateTo(GetCultureUrl("zh-Hant"), forceLoad: true);
        return Task.CompletedTask;
    }
}

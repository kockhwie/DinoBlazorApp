@inherits LayoutComponentBase

<div class="flex h-screen overflow-hidden bg-dino-bg">
    <NavMenu @bind-IsMobileDrawerOpen="navOpen" />

    <main class="flex-1 overflow-y-auto flex flex-col relative">
        @* MOBILE TOP NAV *@
        <nav class="flex md:hidden items-center justify-between bg-dino-surf border-b border-dino-bdr px-4 h-[52px] shrink-0 z-50 relative">
            <div class="flex items-center gap-2.5">
                <span class="logo-anim" style="width: 32px; height: 32px;"></span>
                <div class="font-display font-bold text-sm text-dino-cream leading-tight">Dino Prompt Academy</div>
            </div>
            <button class="flex items-center justify-center w-9 h-9 rounded-lg border border-dino-bdr text-dino-muted hover:border-dino-bdr2 hover:text-dino-cream transition-all"
                    @onclick="OpenNav" aria-label="Open menu">
                <i class="ti ti-menu-2 text-lg"></i>
            </button>
        </nav>

        <div class="flex-1 flex flex-col min-h-0">
            @Body
        </div>
    </main>
</div>

@code {
    private bool navOpen = false;
    private void OpenNav() => navOpen = true;
}

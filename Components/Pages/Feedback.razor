@page "/feedback"
@layout SubPageLayout
@using DinoBlazorApp.Models
@inject DinoBlazorApp.Services.IFeedbackService FeedbackService
@inject IJSRuntime JS

<div class="flex flex-col h-full bg-dino-bg text-dino-cream font-body overflow-hidden">

    <!-- PAGE HEADER -->
    <header class="bg-dino-surf border-b border-dino-bdr px-6 md:px-12 pt-7 shrink-0">
        <div class="flex items-center gap-5 pb-5">
            <div class="text-4xl shrink-0 animate-dino-float">
                <iconify-icon icon="glyphs-poly:comment-2" width="44" height="44" class="text-dino-amber"></iconify-icon>
            </div>
            <div>
                <h1 class="font-display text-2xl md:text-[2.2rem] font-extrabold text-dino-cream leading-tight">Feedback &amp; Wishlist</h1>
                <p class="text-sm text-dino-muted mt-1">Help us evolve. Every roar counts.</p>
            </div>
        </div>

        @* Tab strip *@
        <div class="flex gap-2 bg-dino-surf2 p-1.5 rounded-2xl border border-dino-bdr max-w-lg mx-auto mb-7">
            <button class="flex-1 flex items-center justify-center gap-2 py-3 px-4 rounded-xl text-sm font-semibold cursor-pointer transition-all duration-200
                           @(activeTab == "feedback" ? "text-dino-amber bg-dino-surf border border-dino-bdr shadow-lg" : "text-dino-muted hover:text-dino-creamd bg-transparent border-none")"
                    @onclick='() => activeTab = "feedback"'>
                <i class="ti ti-edit"></i>
                <span>Leave Feedback</span>
            </button>
            <button class="flex-1 flex items-center justify-center gap-2 py-3 px-4 rounded-xl text-sm font-semibold cursor-pointer transition-all duration-200
                           @(activeTab == "wishlist" ? "text-dino-amber bg-dino-surf border border-dino-bdr shadow-lg" : "text-dino-muted hover:text-dino-creamd bg-transparent border-none")"
                    @onclick='() => activeTab = "wishlist"'>
                <i class="ti ti-sparkles"></i>
                <span>Feature Wishlist</span>
                <span class="bg-red-500 text-white rounded-full px-2 py-0.5 text-[10px] font-extrabold">@wishlistItems.Count</span>
            </button>
        </div>
    </header>

    @* ── FEEDBACK TAB ── *@
    @if (activeTab == "feedback")
    {
        <div class="flex-1 overflow-y-auto px-6 md:px-12 py-8">

            @* Submitted state *@
            @if (feedbackSubmitted)
            {
                <div class="max-w-md mx-auto mt-14 text-center animate-slide-up">
                    <div class="h-24 flex items-center justify-center mb-4">
                        <span class="logo-anim" style="width: 80px; height: 80px;"></span>
                    </div>
                    <h2 class="font-display text-2xl font-bold text-dino-cream mb-2">Thank you, @(string.IsNullOrWhiteSpace(form.Nickname) ? "friend" : form.Nickname)!</h2>
                    <p class="text-dino-muted text-sm mb-7">Your feedback has been received. We read every single one.</p>
                    <button class="border border-dino-bdr2 text-dino-amber rounded-lg px-5 py-2 text-sm font-semibold
                                   hover:bg-dino-amber/10 transition-colors cursor-pointer" @onclick="ResetForm">
                        Submit another <i class="ti ti-arrow-right"></i>
                    </button>
                </div>
            }
            else
            {
                <div class="grid grid-cols-1 md:grid-cols-[520px_1fr] gap-10 max-w-[1400px] mx-auto">

                    @* ── FORM ── *@
                    <div class="bg-dino-surf border border-dino-bdr rounded-[18px] p-6 flex flex-col gap-5 h-fit">
                        <div class="font-display font-bold text-dino-cream">Tell us what you think</div>

                        @* Type selector *@
                        <div class="flex flex-col gap-2">
                            <label class="text-[11px] font-semibold text-dino-muted uppercase tracking-[.8px]">What kind of feedback is this?</label>
                            <div class="flex flex-wrap gap-2">
                                @foreach (var t in FeedbackTypes)
                                {
                                    <button class="px-3.5 py-1.5 rounded-full text-xs font-semibold border cursor-pointer transition-all whitespace-nowrap
                                                   @(form.Type == t.Key ? "bg-dino-amber/10 border-dino-ambers text-dino-amber" : "bg-dino-surf2 border-dino-bdr text-dino-muted hover:border-dino-bdr2 hover:text-dino-creamd")"
                                            @onclick="() => form.Type = t.Key">
                                        @((MarkupString)t.Value)
                                    </button>
                                }
                            </div>
                        </div>

                        @* Dino rating *@
                        <div class="flex flex-col gap-2">
                            <label class="text-[11px] font-semibold text-dino-muted uppercase tracking-[.8px]">How do you feel about the app?</label>
                            <div class="flex items-center gap-1.5">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    var score = i;
                                    <button class="bg-transparent border-none p-0 cursor-pointer transition-all @(form.Rating >= score ? "opacity-100 scale-110" : "opacity-30 hover:opacity-75")"
                                            @onclick="() => form.Rating = score" title="@RatingLabel(score)">
                                        <span class="logo-anim" style="width: 20px; height: 20px;"></span>
                                    </button>
                                }
                                @if (form.Rating > 0)
                                {
                                    <span class="text-xs text-dino-amber font-semibold ml-1">@RatingLabel(form.Rating)</span>
                                }
                            </div>
                        </div>

                        @* Nickname *@
                        <div class="flex flex-col gap-2">
                            <label class="text-[11px] font-semibold text-dino-muted uppercase tracking-[.8px]">
                                Your name <span class="font-normal normal-case text-dino-muted2 tracking-normal">(optional)</span>
                            </label>
                            <input class="bg-dino-surf2 border border-dino-bdr rounded-lg px-3.5 py-2.5 text-dino-cream text-sm
                                          outline-none w-full transition-all focus:border-dino-bdr2 focus:ring-1 focus:ring-dino-amber/20
                                          placeholder:text-dino-muted2"
                                   type="text" placeholder="e.g. Dino Tamer" @bind="form.Nickname" maxlength="40" />
                        </div>

                        @* Message *@
                        <div class="flex flex-col gap-2">
                            <label class="text-[11px] font-semibold text-dino-muted uppercase tracking-[.8px]">
                                Your message <span class="text-dino-amber">*</span>
                            </label>
                            <textarea class="bg-dino-surf2 border border-dino-bdr rounded-lg px-3.5 py-2.5 text-dino-cream text-sm
                                             outline-none w-full resize-none leading-relaxed transition-all
                                             focus:border-dino-bdr2 focus:ring-1 focus:ring-dino-amber/20 placeholder:text-dino-muted2"
                                      placeholder="@GetPlaceholder()" @bind="form.Message" maxlength="1000" rows="5"></textarea>
                            <div class="text-[11px] text-dino-muted2 text-right -mt-1">@form.Message.Length / 1000</div>
                        </div>

                        @* Validation *@
                        @if (showValidation && string.IsNullOrWhiteSpace(form.Message))
                        {
                            <div class="bg-dino-rose/10 border border-dino-rose/30 rounded-lg px-3.5 py-2.5 text-xs text-dino-rose">
                                <i class="ti ti-alert-triangle"></i> Please write a message before submitting.
                            </div>
                        }

                        <button class="w-full bg-dino-amber text-[#180f00] font-bold text-sm rounded-lg py-3 flex items-center justify-center gap-2
                                       transition-all hover:-translate-y-0.5 hover:bg-amber-400 hover:shadow-lg disabled:opacity-40 disabled:cursor-not-allowed disabled:transform-none cursor-pointer"
                                @onclick="SubmitFeedback" disabled="@isSubmitting">
                            @if (isSubmitting)
                            { <i class="ti ti-loader-2 animate-spin"></i> <span>Sending...</span> }
                            else
                            { <i class="ti ti-rocket"></i> <span>Send Feedback</span> }
                        </button>
                    </div>

                    @* ── RECENT FEEDBACK WALL ── *@
                    <div class="flex flex-col gap-3">
                        <div class="font-display font-bold text-dino-cream">Recent feedback</div>
                        @if (!recentFeedback.Any())
                        {
                            <div class="bg-dino-surf border border-dino-bdr border-dashed rounded-2xl py-10 px-5 text-center text-dino-muted">
                                <div class="text-3xl mb-2.5"><i class="ti ti-mood-empty"></i></div>
                                <p class="text-sm">Be the first to leave feedback!</p>
                            </div>
                        }
                        else
                        {
                            @foreach (var fb in recentFeedback.OrderByDescending(f => f.At).Take(8))
                            {
                                <div class="bg-dino-surf border border-dino-bdr rounded-xl p-4 animate-slide-up">
                                    <div class="flex items-center gap-2 mb-1.5">
                                        <span class="text-xs">@((MarkupString)FeedbackTypes.GetValueOrDefault(fb.Type, "<i class='ti ti-message'></i>"))</span>
                                        <span class="text-xs font-semibold text-dino-creamd flex-1">@(string.IsNullOrEmpty(fb.Nickname) ? "Anonymous Dino" : fb.Nickname)</span>
                                        <span class="text-[11px] text-dino-muted2">@TimeAgo(fb.At)</span>
                                    </div>
                                    @if (fb.Rating > 0)
                                    {
                                        <div class="mb-1.5 flex gap-0.5">
                                            @for (int i = 0; i < fb.Rating; i++) { <span class="logo-anim" style="width: 14px; height: 14px; margin-right: 2px;"></span> }
                                        </div>
                                    }
                                    <div class="text-xs text-dino-creamd leading-relaxed">@fb.Message</div>
                                </div>
                            }
                        }
                    </div>

                </div>
            }
        </div>
    }

    @* ── WISHLIST TAB ── *@
    @if (activeTab == "wishlist")
    {
        <div class="flex-1 overflow-y-auto px-6 md:px-12 py-8">
            <div class="grid grid-cols-1 md:grid-cols-[520px_1fr] gap-10 max-w-[1400px] mx-auto">

                @* ── ADD IDEA FORM ── *@
                <div class="bg-dino-surf border border-dino-bdr rounded-[18px] p-6 flex flex-col gap-5 h-fit">
                    <div class="font-display font-bold text-dino-cream">Suggest a feature</div>

                    <div class="flex flex-col gap-2">
                        <label class="text-[11px] font-semibold text-dino-muted uppercase tracking-[.8px]">Feature title <span class="text-dino-amber">*</span></label>
                        <input class="bg-dino-surf2 border border-dino-bdr rounded-lg px-3.5 py-2.5 text-dino-cream text-sm
                                      outline-none w-full transition-all focus:border-dino-bdr2 placeholder:text-dino-muted2"
                               type="text" placeholder="e.g. Save favourite prompts" @bind="newIdea.Title" maxlength="80" />
                    </div>

                    <div class="flex flex-col gap-2">
                        <label class="text-[11px] font-semibold text-dino-muted uppercase tracking-[.8px]">Category</label>
                        <div class="flex flex-wrap gap-2">
                            @foreach (var c in IdeaCategories)
                            {
                                <button class="px-3.5 py-1.5 rounded-full text-xs font-semibold border cursor-pointer transition-all whitespace-nowrap
                                               @(newIdea.Category == c.Key ? "bg-dino-amber/10 border-dino-ambers text-dino-amber" : "bg-dino-surf2 border-dino-bdr text-dino-muted hover:border-dino-bdr2 hover:text-dino-creamd")"
                                        @onclick="() => newIdea.Category = c.Key">
                                    @((MarkupString)c.Value)
                                </button>
                            }
                        </div>
                    </div>

                    <div class="flex flex-col gap-2">
                        <label class="text-[11px] font-semibold text-dino-muted uppercase tracking-[.8px]">
                            Why would this help you? <span class="font-normal normal-case text-dino-muted2 tracking-normal">(optional)</span>
                        </label>
                        <textarea class="bg-dino-surf2 border border-dino-bdr rounded-lg px-3.5 py-2.5 text-dino-cream text-sm
                                         outline-none w-full resize-none leading-relaxed transition-all
                                         focus:border-dino-bdr2 placeholder:text-dino-muted2"
                                  placeholder="Describe the problem it solves or the value it adds..."
                                  @bind="newIdea.Desc" maxlength="500" rows="4"></textarea>
                    </div>

                    @if (showIdeaValidation && string.IsNullOrWhiteSpace(newIdea.Title))
                    {
                        <div class="bg-dino-rose/10 border border-dino-rose/30 rounded-lg px-3.5 py-2.5 text-xs text-dino-rose">
                            <i class="ti ti-alert-triangle"></i> Please give your idea a title.
                        </div>
                    }

                    <button class="w-full bg-dino-amber text-[#180f00] font-bold text-sm rounded-lg py-3 flex items-center justify-center gap-2
                                   transition-all hover:-translate-y-0.5 hover:bg-amber-400 hover:shadow-lg cursor-pointer"
                            @onclick="SubmitIdea">
                        <i class="ti ti-sparkles"></i> Add to Wishlist
                    </button>

                    <p class="text-[11px] text-dino-muted2 bg-dino-surf2 border border-dino-bdr rounded-lg px-3.5 py-2.5 leading-relaxed">
                        💾 Submissions are stored in-memory for this session. Persistent voting &amp; history coming in a future release.
                    </p>
                </div>

                @* ── WISHLIST WALL ── *@
                <div class="flex flex-col gap-3">
                    <div class="flex items-center justify-between mb-1">
                        <span class="font-display font-bold text-dino-cream">Community wishlist</span>
                        <div class="flex gap-1.5">
                            <button class="text-[11px] border rounded-full px-3 py-1 font-semibold cursor-pointer transition-all
                                           @(sortBy == "votes" ? "bg-dino-surf3 text-dino-cream border-dino-bdr2" : "bg-transparent text-dino-muted border-dino-bdr hover:text-dino-creamd hover:border-dino-bdr2")"
                                    @onclick='() => sortBy = "votes"'><i class="ti ti-flame"></i> Top</button>
                            <button class="text-[11px] border rounded-full px-3 py-1 font-semibold cursor-pointer transition-all
                                           @(sortBy == "new" ? "bg-dino-surf3 text-dino-cream border-dino-bdr2" : "bg-transparent text-dino-muted border-dino-bdr hover:text-dino-creamd hover:border-dino-bdr2")"
                                    @onclick='() => sortBy = "new"'><i class="ti ti-sparkles"></i> New</button>
                        </div>
                    </div>

                    @foreach (var idea in SortedIdeas())
                    {
                        <div class="bg-dino-surf border rounded-xl p-4 flex gap-3.5 items-start transition-colors animate-slide-up
                                    @(idea.Voted ? "border-dino-ambers" : "border-dino-bdr")">
                            <button class="shrink-0 flex flex-col items-center gap-1 rounded-lg px-2.5 py-2 border min-w-[48px]
                                           cursor-pointer transition-all @(idea.Voted ? "bg-dino-amber/10 border-dino-ambers" : "bg-dino-surf2 border-dino-bdr hover:border-dino-ambers hover:bg-dino-amber/10")"
                                    @onclick="() => ToggleVote(idea)"
                                    title="@(idea.Voted ? "Remove vote" : "Upvote this idea")">
                                <span class="text-lg leading-none">
                                    @(idea.Voted
                                        ? (MarkupString)"<span class='logo-anim' style='width:16px; height:16px'></span>"
                                        : (MarkupString)"<iconify-icon icon='emojione:meat-on-bone' width='20' height='20'></iconify-icon>")
                                </span>
                                <span class="text-[11px] font-bold @(idea.Voted ? "text-dino-amber" : "text-dino-muted")">@idea.Votes</span>
                            </button>
                            <div class="flex-1 flex flex-col gap-1.5">
                                <div class="flex items-center gap-2">
                                    <span class="text-xs">@((MarkupString)IdeaCategories.GetValueOrDefault(idea.Category, "<i class='ti ti-bulb'></i>"))</span>
                                    @if (idea.IsNew)
                                    {
                                        <span class="text-[10px] font-bold bg-dino-amber/15 text-dino-amber border border-dino-ambers rounded-full px-2 py-0.5">New</span>
                                    }
                                </div>
                                <div class="font-display text-sm font-bold text-dino-cream leading-snug">@idea.Title</div>
                                @if (!string.IsNullOrEmpty(idea.Desc))
                                {
                                    <div class="text-xs text-dino-muted leading-relaxed">@idea.Desc</div>
                                }
                            </div>
                        </div>
                    }
                </div>

            </div>
        </div>
    }

</div>

@code {
    // ── TABS ──
    private string activeTab  = "feedback";
    private string sortBy     = "votes";

    // ── FEEDBACK FORM STATE ──
    private FeedbackForm form = new();
    private bool feedbackSubmitted = false;
    private bool isSubmitting      = false;
    private bool showValidation    = false;

    // ── WISHLIST FORM STATE ──
    private IdeaForm newIdea         = new();
    private bool showIdeaValidation  = false;

    // ── DATA ──
    private IReadOnlyList<FeedbackEntry> recentFeedback => FeedbackService.GetFeedback();
    private IReadOnlyList<WishlistItem> wishlistItems => FeedbackService.GetWishlist();

    // ── LOOKUP TABLES ──
    private static readonly Dictionary<string, string> FeedbackTypes = new()
    {
        { "general",  "<i class='ti ti-message'></i> General"      },
        { "bug",      "<i class='ti ti-bug'></i> Bug Report"   },
        { "idea",     "<i class='ti ti-bulb'></i> Idea"         },
        { "praise",   "<i class='ti ti-star'></i> Compliment"   }
    };

    private static readonly Dictionary<string, string> IdeaCategories = new()
    {
        { "feature", "<i class='ti ti-bolt'></i> Feature"  },
        { "ux",      "<i class='ti ti-palette'></i> Design"   },
        { "learn",   "<i class='ti ti-library'></i> Learning" },
        { "mobile",  "<i class='ti ti-device-mobile'></i> Mobile"   },
        { "perf",    "<i class='ti ti-rocket'></i> Speed"    }
    };

    // ── RATING LABELS ──
    private static string RatingLabel(int r) => r switch
    {
        1 => "Needs a lot of work",
        2 => "Could be better",
        3 => "It's decent",
        4 => "Really good!",
        5 => "Absolutely love it",
        _ => ""
    };

    // ── PLACEHOLDER BY TYPE ──
    private string GetPlaceholder() => form.Type switch
    {
        "bug"    => "Describe what happened, what you expected, and how to reproduce it...",
        "idea"   => "What would you like to see? How would it help you?",
        "praise" => "We'd love to hear what you enjoy about the app",
        _        => "Share your thoughts — every roar counts..."
    };

    // ── SUBMIT FEEDBACK ──
    private async Task SubmitFeedback()
    {
        showValidation = true;
        if (string.IsNullOrWhiteSpace(form.Message)) return;

        isSubmitting = true;
        StateHasChanged();
        await Task.Delay(900); // simulate brief send

        FeedbackService.AddFeedback(new FeedbackEntry
        {
            Nickname = form.Nickname,
            Type     = form.Type,
            Rating   = form.Rating,
            Message  = form.Message,
            At       = DateTime.Now
        });

        isSubmitting      = false;
        feedbackSubmitted = true;
        showValidation    = false;
    }

    private void ResetForm()
    {
        form              = new FeedbackForm();
        feedbackSubmitted = false;
        showValidation    = false;
    }

    // ── SUBMIT IDEA ──
    private void SubmitIdea()
    {
        showIdeaValidation = true;
        if (string.IsNullOrWhiteSpace(newIdea.Title)) return;

        FeedbackService.AddWishlistItem(new WishlistItem
        {
            Title    = newIdea.Title,
            Category = string.IsNullOrEmpty(newIdea.Category) ? "feature" : newIdea.Category,
            Desc     = newIdea.Desc,
            Votes    = 1,
            Voted    = true,
            IsNew    = true
        });

        newIdea            = new IdeaForm();
        showIdeaValidation = false;
    }

    // ── VOTE ──
    private void ToggleVote(WishlistItem item)
    {
        FeedbackService.ToggleVote(item.Id);
    }

    // ── SORT ──
    private IEnumerable<WishlistItem> SortedIdeas() => sortBy == "votes"
        ? wishlistItems.OrderByDescending(i => i.Votes)
        : wishlistItems.OrderByDescending(i => i.IsNew).ThenByDescending(i => i.Id);

    // ── TIME AGO ──
    private static string TimeAgo(DateTime dt)
    {
        var diff = DateTime.Now - dt;
        if (diff.TotalSeconds < 60)  return "just now";
        if (diff.TotalMinutes < 60)  return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours   < 24)  return $"{(int)diff.TotalHours}h ago";
        return $"{(int)diff.TotalDays}d ago";
    }


}


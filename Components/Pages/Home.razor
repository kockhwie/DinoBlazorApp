@page "/"

<PageTitle>Dino AI Academy</PageTitle>

<main class="home-page">
    <section class="hero-shell">
        <SiteNav />

        <div class="hero-grid">
            <div class="hero-copy">

                <h1>Don't just use AI.<br />Evolve with it.</h1>
                <p class="lead">
                    Master AI through hands-on learning, real-world projects, and a thriving community of innovators.
                </p>

                <div class="benefits">
                    @foreach (var item in BenefitItems)
                    {
                        <div class="benefit">
                            <span class="benefit-icon">@((MarkupString)item.Icon)</span>
                            <span>@item.Label</span>
                        </div>
                    }
                </div>

                <div class="hero-actions">
                    <a href="/membership" class="btn btn-cta">Start Your Evolution <i class="ti ti-chevron-right"></i></a>
                </div>
            </div>

            <div class="hero-visual" aria-hidden="true">
                <img alt="" class="hero-mascot" src="@Assets["assets/dino_mascot.png"]" />
            </div>
        </div>
    </section>

    <section class="showcase-shell">
        <div class="showcase-panel workbench">
            <div class="panel-title">
                <i class="ti ti-device-laptop"></i>
                <span>AI Workbench</span>
            </div>

            <EditForm Model="@EmailDraft" class="composer-card">
                <div class="composer-form">
                    <div class="email-fields">
                        <label class="email-field">
                            <span class="email-label">To</span>
                            <input @bind="EmailDraft.To" class="email-input" />
                        </label>
                        <label class="email-field">
                            <span class="email-label">Subject</span>
                            <input @bind="EmailDraft.Subject" class="email-input" />
                        </label>
                        <label class="email-field email-field-message">
                            <span class="email-label">Message</span>
                            <textarea @bind="EmailDraft.Message" rows="10" class="email-textarea" placeholder="Write or paste your email content here..."></textarea>
                        </label>
                    </div>
                </div>

 
                <div class="composer-actions">
                    <button type="button" class="mini-btn ghost" @onclick="ClearDraft">Clear</button>
                    <button type="button" class="mini-btn ghost" @onclick="LoadImprovedDraft">Improve</button>
                    <button type="button" class="mini-btn solid" @onclick="HandleSendEmail">Send Email</button>
                </div>
                @if (!string.IsNullOrWhiteSpace(EmailDraft.StatusMessage))
                {
                    <div class="text-xs text-emerald-400 mt-2 px-1 text-right">
                        @EmailDraft.StatusMessage
                    </div>
                }
            </EditForm>
        </div>

        <div class="showcase-panel assistant flex flex-col h-full">
            <div class="flex items-center justify-between mb-2">
                <div class="panel-title flex items-center gap-2 m-0" style="margin-bottom: 0;">
                    <i class="ti ti-sparkle-highlight text-[#33d7a6] text-lg"></i>
                    <span class="text-xs font-semibold uppercase tracking-wider text-[#33d7a6]">AI Assistant</span>
                </div>
                @if (currentView != "options")
                {
                    <button type="button" @onclick="GoBackToOptions" class="px-2.5 py-1 rounded-lg text-slate-400 hover:text-[#33d7a6] hover:bg-[#33d7a6]/10 gap-1 flex items-center transition-all duration-300 text-xs cursor-pointer">
                        <i class="ti ti-chevron-left"></i> Back
                    </button>
                }
            </div>

            @if (currentView == "options")
            {
                <p class="text-xs text-slate-400 mb-4">Enhance your content with the power of AI.</p>
                <div class="assistant-options">
                    <!-- Option 1: Refine My Draft -->
                    <button type="button" @onclick='() => SelectOption("refine")' class="assistant-option assistant-option-refine">
                        <div class="assistant-option-icon">
                            <span>✏️</span>
                        </div>
                        <div class="assistant-option-copy">
                            <h3>Refine My Draft</h3>
                            <p>Improve clarity, tone, grammar, and structure while keeping your original message.</p>
                        </div>
                        <span class="assistant-option-arrow">→</span>
                    </button>

                    <!-- Option 2: Generate from Prompt -->
                    <button type="button" @onclick='() => SelectOption("generate")' class="assistant-option assistant-option-generate">
                        <div class="assistant-option-icon">
                            <span>💡</span>
                        </div>
                        <div class="assistant-option-copy">
                            <h3>Generate from Prompt</h3>
                            <p>Create a professional email from just a few words or instructions.</p>
                        </div>
                        <span class="assistant-option-arrow">→</span>
                    </button>

                    <!-- Option 3: Professional Upgrade -->
                    <button type="button" @onclick='() => SelectOption("professional")' class="assistant-option assistant-option-professional">
                        <div class="assistant-option-icon">
                            <span>👑</span>
                        </div>
                        <div class="assistant-option-copy">
                            <h3>Professional Upgrade</h3>
                            <p>Elevate your email to a more polished, executive-level tone.</p>
                        </div>
                        <span class="assistant-option-arrow">→</span>
                    </button>
                </div>
            }
            else
            {
                <div class="flex-1 flex flex-col">
                    @if (isLoading)
                    {
                        <div class="flex flex-col gap-4 w-full py-4 flex-1 justify-center animate-pulse">
                            <div class="skeleton h-8 w-1/3 bg-[#031810]"></div>
                            <div class="skeleton h-36 w-full bg-[#031810]"></div>
                            <div class="skeleton h-10 w-full bg-[#031810]"></div>
                        </div>
                    }
                    else if (currentView == "refine")
                    {
                        <div class="space-y-4 flex-1 flex flex-col">
                            <div class="flex items-center gap-2">
                                <span class="text-[#9be326] text-sm">✏️</span>
                                <h3 class="font-semibold text-slate-200 text-sm">Refine My Draft</h3>
                            </div>

                            @if (string.IsNullOrWhiteSpace(EmailDraft.Message))
                            {
                                <div class="p-4 rounded-xl bg-amber-500/5 border border-amber-500/20 text-amber-200 text-xs space-y-2">
                                    <p class="font-semibold">Your draft is empty!</p>
                                    <p>Please compose or paste your email in the AI Workbench on the left, or use our pre-filled sample draft to see refinement in action.</p>
                                    <button type="button" @onclick="LoadSampleDraft" class="w-full py-2 bg-gradient-to-r from-[#f5b722] to-[#f5bb2c] text-[#08110f] font-bold rounded-lg text-xs mt-2 hover:brightness-110 transition-all duration-300 cursor-pointer">
                                        Use Sample Draft
                                    </button>
                                </div>
                            }
                            else
                            {
                                <div class="flex flex-col flex-1 gap-3">
                                    <p class="text-xs text-slate-400">✓ Refined version of your email:</p>
                                    <textarea @bind="refinedText" class="w-full p-3 bg-[#031810] border border-[rgba(86, 230, 145, 0.22)] rounded-xl text-xs text-slate-100 placeholder-slate-500 focus:outline-none focus:border-[#9be326] focus:ring-1 focus:ring-[#9be326] transition-all duration-300 flex-1 min-h-[180px] resize-none" rows="8"></textarea>
                                    <button type="button" @onclick="TriggerPromptGeneration" class="w-full py-2 rounded-lg bg-gradient-to-r from-[#2dc98e] to-[#80e36b] text-[#08110f] font-bold hover:brightness-110 transition-all duration-300 text-xs flex items-center justify-center gap-1.5 cursor-pointer">
                                        🚀 Generate Email
                                    </button>
                                    <label id="new-email-message1" class="block text-xs font-medium text-slate-300 mb-1.5">New Email Message:</label>
                                    <textarea @bind="refinedEmail" class="w-full p-3 bg-[#031810] border border-[rgba(86, 230, 145, 0.22)] rounded-xl text-xs text-slate-100 focus:outline-none focus:border-[#25d0be] focus:ring-1 focus:ring-[#25d0be] transition-all duration-300 flex-1 min-h-[150px] resize-none" rows="6"></textarea>

                                    <div class="p-3 bg-green-500/5 border border-green-500/20 rounded-xl mt-auto">
                                        <p class="text-xs font-semibold text-green-400 flex items-center gap-1">⏱️ Time Saved: 8.5 minutes</p>
                                        <p class="text-[10px] text-slate-400 mt-0.5">That's 7.1 hours per year!</p>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else if (currentView == "generate")
                    {
                        <div class="space-y-4 flex-1 flex flex-col">
                            <div class="flex items-center gap-2">
                                <span class="text-[#25d0be] text-sm">💡</span>
                                <h3 class="font-semibold text-slate-200 text-sm">Generate from Prompt</h3>
                            </div>

                            <div class="space-y-3 flex-1 flex flex-col">
                                <div>
                                    <label class="block text-xs font-medium text-slate-300 mb-1.5">Your Prompt:</label>
                                    <textarea @bind="promptInput" class="w-full p-3 bg-[#031810] border border-[rgba(86, 230, 145, 0.22)] rounded-xl text-xs text-slate-100 placeholder-slate-500 focus:outline-none focus:border-[#25d0be] focus:ring-1 focus:ring-[#25d0be] transition-all duration-300 resize-none" rows="3" placeholder="Describe what email you want to generate..."></textarea>
                                </div>

                                <div class="flex flex-wrap gap-1.5">
                                    <button type="button" @onclick='() => SetPrompt("Write a professional email requesting a project deadline extension. Keep it concise and polite.")' class="px-2.5 py-1 rounded-full border border-slate-700 text-slate-400 hover:text-[#25d0be] hover:border-[#25d0be]/50 bg-[#02100c] text-[10px] transition-all duration-300 cursor-pointer">
                                        📅 Extension
                                    </button>
                                    <button type="button" @onclick='() => SetPrompt("Write a warm follow-up email after a project kick-off meeting. Summarize key action items.")' class="px-2.5 py-1 rounded-full border border-slate-700 text-slate-400 hover:text-[#25d0be] hover:border-[#25d0be]/50 bg-[#02100c] text-[10px] transition-all duration-300 cursor-pointer">
                                        🤝 Follow-up
                                    </button>
                                    <button type="button" @onclick='() => SetPrompt("Write a brief out-of-office auto-reply. I am on vacation until next Monday.")' class="px-2.5 py-1 rounded-full border border-slate-700 text-slate-400 hover:text-[#25d0be] hover:border-[#25d0be]/50 bg-[#02100c] text-[10px] transition-all duration-300 cursor-pointer">
                                        🏝️ Vacation
                                    </button>
                                </div>

                                <button type="button" @onclick="TriggerPromptGeneration" class="w-full py-2 rounded-lg bg-gradient-to-r from-[#2dc98e] to-[#80e36b] text-[#08110f] font-bold hover:brightness-110 transition-all duration-300 text-xs flex items-center justify-center gap-1.5 cursor-pointer">
                                    🚀 Generate Email
                                </button>
                                <label id="new-email-message2" class="block text-xs font-medium text-slate-300 mb-1.5">New Email Message:</label>

                                    <div class="space-y-3 flex-1 flex flex-col">
                                        <textarea @bind="generatedEmail" class="w-full p-3 bg-[#031810] border border-[rgba(86, 230, 145, 0.22)] rounded-xl text-xs text-slate-100 focus:outline-none focus:border-[#25d0be] focus:ring-1 focus:ring-[#25d0be] transition-all duration-300 flex-1 min-h-[150px] resize-none" rows="6"></textarea>
                                        <div class="p-3 bg-green-500/5 border border-green-500/20 rounded-xl mt-auto">
                                            <p class="text-xs font-semibold text-green-400 flex items-center gap-1">⏱️ Time Saved: 12 minutes</p>
                                            <p class="text-[10px] text-slate-400 mt-0.5">That's 10 hours per year!</p>
                                        </div>
                                    </div>
 
                            </div>
                        </div>
                    }
                    else if (currentView == "professional")
                    {
                        <div class="space-y-4 flex-1 flex flex-col">
                            <div class="flex items-center gap-2">
                                <span class="text-[#f5b722] text-sm">👑</span>
                                <h3 class="font-semibold text-slate-200 text-sm">Professional Upgrade</h3>
                            </div>

                            <div class="space-y-3 flex-1 flex flex-col">
                                <div>
                                    <label class="block text-xs font-medium text-slate-300 mb-1.5">Your Prompt:</label>
                                    <textarea @bind="professionalFramework" class="w-full p-3 bg-[#031810] border border-[rgba(86, 230, 145, 0.22)] rounded-xl text-[11px] text-slate-100 placeholder-slate-500 focus:outline-none focus:border-[#f5b722] focus:ring-1 focus:ring-[#f5b722] transition-all duration-300 resize-none font-mono" rows="6"></textarea>
                                </div>

                                <div class="space-y-1.5">
                                    <span class="block text-[11px] font-medium text-slate-400">Select Tone:</span>
                                    <div class="flex gap-2">
                                        <button type="button" @onclick='() => SetTone("Executive")' class="px-2.5 py-1 rounded-lg text-xs font-semibold transition-all duration-300 flex-1 cursor-pointer @(selectedTone == "Executive" ? "bg-[#f5b722] text-[#08110f]" : "border border-slate-700 text-slate-400 hover:text-[#f5b722] hover:border-[#f5b722]/50 bg-[#02100c]")">
                                            💼 Executive
                                        </button>
                                        <button type="button" @onclick='() => SetTone("Diplomatic")' class="px-2.5 py-1 rounded-lg text-xs font-semibold transition-all duration-300 flex-1 cursor-pointer @(selectedTone == "Diplomatic" ? "bg-[#f5b722] text-[#08110f]" : "border border-slate-700 text-slate-400 hover:text-[#f5b722] hover:border-[#f5b722]/50 bg-[#02100c]")">
                                            🤝 Diplomatic
                                        </button>
                                        <button type="button" @onclick='() => SetTone("Persuasive")' class="px-2.5 py-1 rounded-lg text-xs font-semibold transition-all duration-300 flex-1 cursor-pointer @(selectedTone == "Persuasive" ? "bg-[#f5b722] text-[#08110f]" : "border border-slate-700 text-slate-400 hover:text-[#f5b722] hover:border-[#f5b722]/50 bg-[#02100c]")">
                                            📣 Persuasive
                                        </button>
                                    </div>
                                </div>

                                <button type="button" @onclick="TriggerProfessionalUpgrade" class="w-full py-2 rounded-lg bg-gradient-to-r from-[#2dc98e] to-[#80e36b] text-[#08110f] font-bold hover:brightness-110 transition-all duration-300 text-xs flex items-center justify-center gap-1.5 cursor-pointer">
                                    👑 Generate Email
                                </button>
                                <label class="block text-xs font-medium text-slate-300 mb-1.5">New Email Message:</label>

                                    <div class="space-y-3 flex-1 flex flex-col">
                                        <textarea @bind="professionalOutputText" class="w-full p-3 bg-[#031810] border border-[rgba(86, 230, 145, 0.22)] rounded-xl text-xs text-slate-100 focus:outline-none focus:border-[#f5b722] focus:ring-1 focus:ring-[#f5b722] transition-all duration-300 flex-1 min-h-[150px] resize-none" rows="6"></textarea>
                                        <div id="new-email-message3" class="p-3 bg-green-500/5 border border-green-500/20 rounded-xl mt-auto">
                                            <p class="text-xs font-semibold text-green-400 flex items-center gap-1">⏱️ Time Saved: 15 minutes</p>
                                            <p class="text-[10px] text-slate-400 mt-0.5">That's 12.5 hours per year!</p>
                                        </div>
                                    </div>
                                
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </section>

    <footer class="footer-shell">
        <div class="footer-grid">
<div class="footer-card" id="release-notes">
    <p class="footer-card-title">Release Notes</p>
    <ul class="footer-list">
        <li><strong>v2.0.0</strong> - Public website release, invitation-only membership flow, and AI Workbench polish.</li>
        <li><a href="/release-notes">Read the full release notes</a></li>
    </ul>
</div>
            <div class="footer-card" id="feedback">
                <p class="footer-card-title">Feedback / Wishlist</p>
                <ul class="footer-links">
                    <li><a href="mailto:admin@codingdinos.asia?subject=Dino%20AI%20Academy%20Feedback">Send feedback</a></li>
                    <li><a href="mailto:admin@codingdinos.asia?subject=Dino%20AI%20Academy%20Wishlist">Add to wishlist</a></li>
                    <li><a href="#">View roadmap</a></li>
                </ul>
            </div>
        </div>

        <div class="footer-bottom">
            <span>© @DateTime.Now.Year Dino AI Academy</span>
            <span>Built with Blazor and DaisyUI</span>
        </div>
    </footer>
</main>

@code {
    // State variables for interactive AI Assistant
    private string currentView = "options";
    private bool isLoading = false;
    private string refinedText = "";
    private string refinedEmail = "";
    private string promptInput = "Write a professional email requesting a project deadline extension. Keep it concise and polite.";
    private string generatedEmail = "";
 
    private string professionalFramework = "Subject: [Clear, specific subject line]\n\nDear [Recipient Name],\n\n[Opening: State your purpose clearly and professionally]\n\n[Body: Provide context and key details in 2-3 sentences]\n\n[Call to Action: Specify what you need or expect]\n\nBest regards,\n[Your Name]";
    private string professionalOutputText = "";
 
    private string selectedTone = "Executive";

    private static readonly IReadOnlyList<BenefitItem> BenefitItems =
    [
        new BenefitItem(LeafIcon, "Learn AI the right way"),
        new BenefitItem(MountainIcon, "Build real projects"),
        new BenefitItem(CommunityIcon, "Join a global community"),
        new BenefitItem(ShieldIcon, "Advance your career"),
    ];

    private static readonly IReadOnlyList<AssistantCard> AssistantCards =
    [
        new AssistantCard(
            "content",
            "Refine My Draft",
            "Create engaging content in seconds.",
            ["Blog posts", "Course outlines", "Social media", "Marketing copy"],
            "Generate Content",
            "green",
            LeafRingIcon,
            new EmailPreview(
                "team@dinoacademy.com",
                "Project Update & Next Steps",
                ["Hi Team,", "I wanted to share a quick update on the progress of our AI Academy project."],
                ["Content outline for the next module", "Landing page copy draft", "Social post ideas"],
                "Looking forward to your feedback!",
                "Best,\nAlex")),
        new AssistantCard(
            "code",
            "Generate from Prompt",
            "Write better code, faster.",
            ["Debug and fix", "Explain code", "Generate snippets", "Best practices"],
            "Write Code",
            "teal",
            CodeIcon,
            new EmailPreview(
                "engineering@dinoacademy.com",
                "Code Review Follow-Up",
                ["Hi team,", "Here’s a quick summary of the issues we should address before the next release."],
                ["Refactor duplicated UI logic", "Add responsive breakpoints", "Review accessibility states"],
                "Let’s sync on the fixes this afternoon.",
                "Thanks,\nAlex")),
        new AssistantCard(
            "idea",
            "Professional Upgrade",
            "Spark new ideas and solve problems.",
            ["Creative ideas", "Problem solving", "Project concepts", "Strategy planning"],
            "Brainstorm Ideas",
            "gold",
            IdeaIcon,
            new EmailPreview(
                "product@dinoacademy.com",
                "Wishlist & Roadmap Notes",
                ["Hi team,", "I collected a few ideas that could improve the next release and keep momentum going."],
                ["Release notes page", "Feedback form", "Feature wishlist"],
                "Happy to refine these further.",
                "Cheers,\nAlex")),
    ];

    private static readonly string DefaultAssistantKey = AssistantCards[0].Key;

    private string SelectedAssistantKey { get; set; } = DefaultAssistantKey;
    private EmailDraftModel EmailDraft { get; set; } = CreateDraft(AssistantCards[0].Email);

    private AssistantCard SelectedAssistant =>
        AssistantCards.FirstOrDefault(card => card.Key == SelectedAssistantKey) ?? AssistantCards[0];

    private void SelectAssistant(string assistantKey)
    {
        SelectedAssistantKey = assistantKey;
        var assistant = SelectedAssistant;
        EmailDraft = CreateDraft(assistant.Email);
    }

    private void ClearDraft()
    {
        EmailDraft = new EmailDraftModel();
    }

    private async Task LoadImprovedDraft()
    {
        await SelectOption("refine");
    }

    private void HandleSendEmail()
    {
        EmailDraft = EmailDraft with { StatusMessage = "Send preview only — no email was submitted." };
    }

    private static EmailDraftModel CreateDraft(EmailPreview preview) =>
        new()
        {
            To = preview.To,
            Subject = preview.Subject,
            Message = BuildMessage(preview)
        };

    // New Interactive Logic Methods
    private async Task SelectOption(string view)
    {
        currentView = view;
        if (view == "refine")
        {
            await TriggerDraftRefinement();
        }
    }

    private void GoBackToOptions()
    {
        currentView = "options";
    }

    private void SetPrompt(string prompt)
    {
        promptInput = prompt;
    }

    private void SetTone(string tone)
    {
        selectedTone = tone;
    }

    private void LoadSampleDraft()
    {
        EmailDraft.Message = "Hi, I was thinking about the deadline of the project, I need more time because I have some other stuff going on. Can we push it by a week? Let me know.";
        _ = TriggerDraftRefinement();
    }

    private async Task TriggerDraftRefinement()
    {
        if (string.IsNullOrWhiteSpace(EmailDraft.Message)) return;

        isLoading = true;
        StateHasChanged();
        await Task.Delay(1000); // Simulate refinement latency

        refinedText = PerformRefinementText(EmailDraft.Message);
        isLoading = false;
    }

    private string PerformRefinementText(string original)
    {
        if (original.Contains("deadline") && original.Contains("week"))
        {
            return "Subject: Request for Project Deadline Extension\n\nDear Team,\n\nI hope this email finds you well.\n\nI am writing to request a brief one-week extension on the current project deadline. Due to unexpected complexities in the development phase and competing project priorities, this extra time will ensure we deliver a polished, high-quality result.\n\nThank you for your understanding. Please let me know if this adjustment is acceptable.\n\nBest regards,\n[Your Name]";
        }

        // General smart polish
        var subject = string.IsNullOrWhiteSpace(EmailDraft.Subject) ? "Project Update" : EmailDraft.Subject;
        return $"Subject: Refined: {subject}\n\nDear [Recipient],\n\nI hope this message finds you well. I wanted to follow up and share the details regarding our discussion:\n\n{original}\n\nI would appreciate your thoughts on this at your earliest convenience.\n\nBest regards,\n[Your Name]";
    }

    private async Task TriggerPromptGeneration()
    {
        if (string.IsNullOrWhiteSpace(promptInput)) return;

        isLoading = true;
        StateHasChanged();
        await Task.Delay(1200); // Simulate generation latency

        generatedEmail = GenerateEmailFromPrompt(promptInput);
        isLoading = false;
    }

    private string GenerateEmailFromPrompt(string prompt)
    {
        var lowerPrompt = prompt.ToLowerInvariant();
        if (lowerPrompt.Contains("extension") || lowerPrompt.Contains("deadline"))
        {
            return "Subject: Request for Project Deadline Extension\n\nDear [Manager Name],\n\nI hope this email finds you well. I am writing to request a brief extension on the current project deadline.\n\nDue to unforeseen circumstances and additional requirements that emerged during the development phase, I believe an extension of [X days] would allow me to deliver a higher quality result.\n\nI am committed to keeping you updated on progress and ensuring minimal impact on the overall timeline.\n\nThank you for considering this request. I look forward to your response.\n\nBest regards,\n[Your Name]";
        }
        else if (lowerPrompt.Contains("follow up") || lowerPrompt.Contains("meeting"))
        {
            return "Subject: Follow-up & Action Items: Project Kick-off\n\nDear [Client Name],\n\nThank you for taking the time to meet with us today. It was great discussing the roadmap for the Dino AI Academy project.\n\nAs discussed, here are our next steps:\n- Finalize the layout prototype\n- Complete copy refinement for the AI Assistant panel\n- Schedule our weekly sync for next Thursday\n\nI will keep you updated as we make progress. Please let me know if there's anything else you'd like to add.\n\nBest regards,\n[Your Name]";
        }
        else if (lowerPrompt.Contains("out of office") || lowerPrompt.Contains("vacation") || lowerPrompt.Contains("holiday"))
        {
            return "Subject: Out of Office: [Your Name]\n\nHello,\n\nThank you for your email. I am currently out of the office on vacation, returning on Monday, June 8th.\n\nI will have limited access to my email during this time. For urgent matters, please contact our team at info@dinoacademy.com.\n\nBest regards,\n[Your Name]";
        }

        return $"Subject: Dino AI Assistant Draft\n\nDear [Recipient Name],\n\nFollowing up on our query regarding: \"{promptInput}\".\n\nI wanted to reach out and provide an update. We are currently processing the details and expect to have a full response for you shortly.\n\nPlease let me know if you have any questions in the meantime.\n\nBest regards,\n[Your Name]";
    }

    private async Task TriggerProfessionalUpgrade()
    {
        isLoading = true;
        StateHasChanged();
        await Task.Delay(1200); // Simulate upgrade latency

        professionalOutputText = UpgradeToProfessional(selectedTone);
        isLoading = false;
    }

    private string UpgradeToProfessional(string tone)
    {
        if (tone == "Executive")
        {
            return "Subject: Strategic Proposal: Q3 Operational Initiatives\n\nDear [Executive Name],\n\nI am writing to present a strategic opportunity that aligns with our organizational objectives and mid-term growth strategies.\n\nOur analysis indicates a significant potential for optimization. By implementing the proposed framework, we can enhance operational efficiency by an estimated 30% while reducing overhead costs. This initiative requires a modest upfront investment but promises substantial returns within the first fiscal year.\n\nI would welcome the opportunity to discuss this proposal in detail and explore how we might collaborate to drive this initiative forward. I am available for a meeting at your earliest convenience.\n\nRespectfully,\n[Your Name]";
        }
        else if (tone == "Diplomatic")
        {
            return "Subject: Collaborative Review of Project Milestones & Timeline\n\nDear [Team Lead Name],\n\nI hope this email finds you well. I am writing to discuss our upcoming project milestones and ensure we are aligned on resource allocation.\n\nTo ensure we maintain our high standards of quality, I would appreciate your insights on the timeline adjustments we discussed. Balancing our team's capacity with the client's expectations will be key to our collective success. I want to make sure everyone feels supported as we move forward.\n\nCould we schedule a brief sync tomorrow to review the schedule together and find a mutually beneficial path?\n\nWarm regards,\n[Your Name]";
        }
        else // Persuasive
        {
            return "Subject: Unlock Your Team's Productivity with Dino AI Academy\n\nDear [Decision Maker Name],\n\nAre you ready to elevate your team's productivity and master the future of work?\n\nI am writing to invite you to partner with Dino AI Academy. Our hands-on learning platform has helped thousands of professionals automate repetitive tasks, saving an average of 12.5 hours per week. By integrating our course modules, your team will gain practical skills that drive direct bottom-line results.\n\nLet's schedule a 15-minute demo this week to explore how we can tailor our programs to your goals. You can book a slot directly using the link below.\n\nBest regards,\n[Your Name]";
        }
    }

    private static string BuildMessage(EmailPreview preview) =>
        string.Join("\n\n", preview.Paragraphs)
        + "\n\n"
        + string.Join("\n", preview.Bullets.Select(item => $"- {item}"))
        + "\n\n"
        + preview.Closing
        + "\n"
        + preview.Signature.Replace("\n", Environment.NewLine);


    private static readonly string DefaultAssistantKey = AssistantCards[0].Key;

    private string SelectedAssistantKey { get; set; } = DefaultAssistantKey;
    private EmailDraftModel EmailDraft { get; set; } = CreateDraft(AssistantCards[0].Email);

    private AssistantCard SelectedAssistant =>
        AssistantCards.FirstOrDefault(card => card.Key == SelectedAssistantKey) ?? AssistantCards[0];

    private AssistantViewSpec CurrentAssistantView =>
        AssistantViews.TryGetValue(currentView, out var view) ? view : AssistantViews["refine"];

    private void SelectAssistant(string assistantKey)
    {
        SelectedAssistantKey = assistantKey;
        var assistant = SelectedAssistant;
        EmailDraft = CreateDraft(assistant.Email);
    }

    private void ClearDraft()
    {
        EmailDraft = new EmailDraftModel();
    }

    private async Task LoadImprovedDraft()
    {
        await SelectOption("refine");
    }

    private void HandleSendEmail()
    {
        EmailDraft = EmailDraft with { StatusMessage = "Send preview only — no email was submitted." };
    }

    private static EmailDraftModel CreateDraft(EmailPreview preview) =>
        new()
        {
            To = preview.To,
            Subject = preview.Subject,
            Message = BuildMessage(preview)
        };

    // New Interactive Logic Methods
    private async Task SelectOption(string view)
    {
        currentView = view;
        if (view == "refine")
        {
            await TriggerDraftRefinement();
        }
    }

    private void GoBackToOptions()
    {
        currentView = "options";
    }

    private void SetPrompt(string prompt)
    {
        promptInput = prompt;
    }

    private void SetTone(string tone)
    {
        selectedTone = tone;
    }

    private void LoadSampleDraft()
    {
        EmailDraft.Message = "Hi, I was thinking about the deadline of the project, I need more time because I have some other stuff going on. Can we push it by a week? Let me know.";
        _ = TriggerDraftRefinement();
    }

    private async Task TriggerDraftRefinement()
    {
        if (string.IsNullOrWhiteSpace(EmailDraft.Message)) return;

        isLoading = true;
        StateHasChanged();
        await Task.Delay(1000); // Simulate refinement latency

        refinedText = PerformRefinementText(EmailDraft.Message);
        isLoading = false;
    }

    private string PerformRefinementText(string original)
    {
        if (original.Contains("deadline") && original.Contains("week"))
        {
            return "Subject: Request for Project Deadline Extension\n\nDear Team,\n\nI hope this email finds you well.\n\nI am writing to request a brief one-week extension on the current project deadline. Due to unexpected complexities in the development phase and competing project priorities, this extra time will ensure we deliver a polished, high-quality result.\n\nThank you for your understanding. Please let me know if this adjustment is acceptable.\n\nBest regards,\n[Your Name]";
        }

        // General smart polish
        var subject = string.IsNullOrWhiteSpace(EmailDraft.Subject) ? "Project Update" : EmailDraft.Subject;
        return $"Subject: Refined: {subject}\n\nDear [Recipient],\n\nI hope this message finds you well. I wanted to follow up and share the details regarding our discussion:\n\n{original}\n\nI would appreciate your thoughts on this at your earliest convenience.\n\nBest regards,\n[Your Name]";
    }

    private async Task TriggerPromptGeneration()
    {
        if (string.IsNullOrWhiteSpace(promptInput)) return;

        isLoading = true;
        StateHasChanged();
        await Task.Delay(1200); // Simulate generation latency

        generatedEmail = GenerateEmailFromPrompt(promptInput);
        isLoading = false;
    }

    private string GenerateEmailFromPrompt(string prompt)
    {
        var lowerPrompt = prompt.ToLowerInvariant();
        if (lowerPrompt.Contains("extension") || lowerPrompt.Contains("deadline"))
        {
            return "Subject: Request for Project Deadline Extension\n\nDear [Manager Name],\n\nI hope this email finds you well. I am writing to request a brief extension on the current project deadline.\n\nDue to unforeseen circumstances and additional requirements that emerged during the development phase, I believe an extension of [X days] would allow me to deliver a higher quality result.\n\nI am committed to keeping you updated on progress and ensuring minimal impact on the overall timeline.\n\nThank you for considering this request. I look forward to your response.\n\nBest regards,\n[Your Name]";
        }
        else if (lowerPrompt.Contains("follow up") || lowerPrompt.Contains("meeting"))
        {
            return "Subject: Follow-up & Action Items: Project Kick-off\n\nDear [Client Name],\n\nThank you for taking the time to meet with us today. It was great discussing the roadmap for the Dino AI Academy project.\n\nAs discussed, here are our next steps:\n- Finalize the layout prototype\n- Complete copy refinement for the AI Assistant panel\n- Schedule our weekly sync for next Thursday\n\nI will keep you updated as we make progress. Please let me know if there's anything else you'd like to add.\n\nBest regards,\n[Your Name]";
        }
        else if (lowerPrompt.Contains("out of office") || lowerPrompt.Contains("vacation") || lowerPrompt.Contains("holiday"))
        {
            return "Subject: Out of Office: [Your Name]\n\nHello,\n\nThank you for your email. I am currently out of the office on vacation, returning on Monday, June 8th.\n\nI will have limited access to my email during this time. For urgent matters, please contact our team at info@dinoacademy.com.\n\nBest regards,\n[Your Name]";
        }

        return $"Subject: Dino AI Assistant Draft\n\nDear [Recipient Name],\n\nFollowing up on our query regarding: \"{promptInput}\".\n\nI wanted to reach out and provide an update. We are currently processing the details and expect to have a full response for you shortly.\n\nPlease let me know if you have any questions in the meantime.\n\nBest regards,\n[Your Name]";
    }

    private async Task TriggerProfessionalUpgrade()
    {
        isLoading = true;
        StateHasChanged();
        await Task.Delay(1200); // Simulate upgrade latency

        professionalOutputText = UpgradeToProfessional(selectedTone);
        isLoading = false;
    }

    private string UpgradeToProfessional(string tone)
    {
        if (tone == "Executive")
        {
            return "Subject: Strategic Proposal: Q3 Operational Initiatives\n\nDear [Executive Name],\n\nI am writing to present a strategic opportunity that aligns with our organizational objectives and mid-term growth strategies.\n\nOur analysis indicates a significant potential for optimization. By implementing the proposed framework, we can enhance operational efficiency by an estimated 30% while reducing overhead costs. This initiative requires a modest upfront investment but promises substantial returns within the first fiscal year.\n\nI would welcome the opportunity to discuss this proposal in detail and explore how we might collaborate to drive this initiative forward. I am available for a meeting at your earliest convenience.\n\nRespectfully,\n[Your Name]";
        }
        else if (tone == "Diplomatic")
        {
            return "Subject: Collaborative Review of Project Milestones & Timeline\n\nDear [Team Lead Name],\n\nI hope this email finds you well. I am writing to discuss our upcoming project milestones and ensure we are aligned on resource allocation.\n\nTo ensure we maintain our high standards of quality, I would appreciate your insights on the timeline adjustments we discussed. Balancing our team's capacity with the client's expectations will be key to our collective success. I want to make sure everyone feels supported as we move forward.\n\nCould we schedule a brief sync tomorrow to review the schedule together and find a mutually beneficial path?\n\nWarm regards,\n[Your Name]";
        }
        else // Persuasive
        {
            return "Subject: Unlock Your Team's Productivity with Dino AI Academy\n\nDear [Decision Maker Name],\n\nAre you ready to elevate your team's productivity and master the future of work?\n\nI am writing to invite you to partner with Dino AI Academy. Our hands-on learning platform has helped thousands of professionals automate repetitive tasks, saving an average of 12.5 hours per week. By integrating our course modules, your team will gain practical skills that drive direct bottom-line results.\n\nLet's schedule a 15-minute demo this week to explore how we can tailor our programs to your goals. You can book a slot directly using the link below.\n\nBest regards,\n[Your Name]";
        }
    }

    private static string BuildMessage(EmailPreview preview) =>
        string.Join("\n\n", preview.Paragraphs)
        + "\n\n"
        + string.Join("\n", preview.Bullets.Select(item => $"- {item}"))
        + "\n\n"
        + preview.Closing
        + "\n"
        + preview.Signature.Replace("\n", Environment.NewLine);


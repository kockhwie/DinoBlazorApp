    private class Message
    {
        public string? Text { get; set; }
        public string? Html { get; set; }
        public bool IsUser { get; set; }
        public bool IsTranslating { get; set; }
        public string TargetLanguage { get; set; } = "";
        public bool DidCopy { get; set; }
    }

@page "/"
@inject GeminiService Gemini
@using Markdig
@using Markdig.Parsers
@using Microsoft.AspNetCore.Components.Web
@inject IJSRuntime JS

<div class="portal-container">
    
    <!-- LEFT SIDE: Prompt Constructor & Fossil Dig -->
    <div class="portal-left">
        <div class="portal-brand">
            <img src="hacker_dino.png" alt="Hacker Dino Avatar" class="cyber-dino-logo" />
            <h1>Dino Prompt Academy</h1> 
        </div>

        <div class="academy-section">
            <div class="level-item">
                <div class="level-header">
                    <span class="level-badge lvl-1">L1</span>
                    <span class="level-title">Beginner</span>
                </div>
                <div class="framework-buttons">
                    <button class="framework-btn btn-lvl-1" @onclick='() => InsertTemplate("Role: Act as a ___. Purpose: ___. Output: A bulleted list.")'>PRO</button>
                    <button class="framework-btn btn-lvl-1" @onclick='() => InsertTemplate("Expectation: ___. Role: Act as a ___. Action: Draft a ___.")'>ERA</button>
                </div>
            </div>

            <div class="level-item">
                <div class="level-header">
                    <span class="level-badge lvl-2">L2</span>
                    <span class="level-title">Intermediate</span>
                </div>
                <div class="framework-buttons">
                    <button class="framework-btn btn-lvl-2" @onclick='() => InsertTemplate("Role: Senior ___. Action: Draft a ___. Context: Our audience is ___. Expectation: Format with clear subheadings.")'>RACE</button>
                    <button class="framework-btn btn-lvl-2" @onclick='() => InsertTemplate("Context: ___. Action: ___. Result: ___. Example: ___.")'>CARE</button>
                </div>
            </div>

            <div class="level-item">
                <div class="level-header">
                    <span class="level-badge lvl-3">L3</span>
                    <span class="level-title">Advanced</span>
                </div>
                <div class="framework-buttons">
                    <button class="framework-btn btn-lvl-3" @onclick='() => InsertTemplate("Context: Launching ___. Objective: ___. Style: ___. Tone: ___. Audience: ___. Response: Markdown format.")'>CO-STAR</button>
                    <button class="framework-btn btn-lvl-3" @onclick='() => InsertTemplate("Role: ___. Instructions: ___. Steps: ___. End Goal: ___. Narrowing: ___.")'>RISEN</button>
                </div>
            </div>

            <div class="level-item">
                <div class="level-header">
                    <span class="level-badge lvl-4">L4</span>
                    <span class="level-title">Expert</span>
                </div>
                <div class="framework-buttons">
                    <button class="framework-btn btn-lvl-4" @onclick='() => InsertTemplate("Before solving this, first list 3 key principles of ___. Once done, use those principles to step-by-step analyze ___.")'>CoT + Knowledge</button>
                </div>
            </div>

            <div class="level-item">
                <div class="level-header">
                    <span class="level-badge lvl-5">L5</span>
                    <span class="level-title">Master</span>
                </div>
                <div class="framework-buttons">
                    <button class="framework-btn btn-lvl-5" @onclick='() => InsertTemplate("Step 1: Identify ___. Step 2: For each, explain ___. Step 3: Write a summary. Step 4: Format as PDF brief.")'>Agent Workflow</button>
                </div>
            </div>
        </div>

        <form @onsubmit="OnSubmit" @onsubmit:preventDefault class="constructor-box">
            @if (isRefining)
            {
                <div class="refining-overlay">
                    <i class="fa-solid fa-bolt fa-fade fa-2x mb-2"></i>
                    <span>Sharpening T-Rex claws...</span>
                </div>
            }

            <textarea class="constructor-textarea" 
                      @bind="userInput" 
                      @bind:event="oninput"
                      placeholder="Feed your prompt to the dino here, or tap a glowing framework above..." 
                      disabled="@(isLoading || isRefining)"></textarea>
            
            <div class="constructor-footer">
                <button class="refine-btn" type="button" @onclick="RefinePrompt" disabled="@(isLoading || isRefining || string.IsNullOrWhiteSpace(userInput))">
                    <i class="fa-solid fa-wand-magic-sparkles"></i> Sharpen Claws
                </button>

                <button class="launch-btn" type="submit" disabled="@(isLoading || isRefining || string.IsNullOrWhiteSpace(userInput))">
                    <i class="fa-solid fa-rocket"></i> Release the Dino!
                </button>
            </div>
        </form>    
        
        <p class="mobile-version-text">Version 1.1.0 <a href="/release-notes" target="_blank">Release note</a></p>

    </div>


    <!-- RIGHT SIDE: The Document Canvas -->
    <div class="portal-right" @ref="documentContainer">
        <div class="document-canvas">
            
            @if (messages.Count == 0 && !isLoading)
            {
                <div class="standby-state">                     
                    <p>Select a framework template to begin...</p>
                </div>
            }

            @foreach (var msg in messages)
            {
                @if (msg.IsUser)
                {
                    <div class="doc-query-wrapper">
                        <i class="fa-solid fa-drumstick-bite doc-query-icon"></i>
                        <div class="doc-query">@msg.Text</div>
                    </div>
                }
                else
                {
                    <div class="doc-section chat-content">
                        @( (MarkupString)(msg.Html ?? string.Empty) )
                        <div class="doc-action-bar">
                            @if(msg.IsTranslating)
                            {
                                <span style="font-size: 0.85rem; color: var(--text-muted);"><i class="fa-solid fa-circle-notch fa-spin"></i> Translating...</span>
                            }
                            else
                            {
                                <div class="action-select-wrapper">
                                    <i class="fa-solid fa-earth-asia"></i>
                                    <select class="action-select" value="@msg.TargetLanguage" @onchange="@(e => ChangeLanguage(msg, e.Value?.ToString() ?? ""))">
                                        <option value="">Translate To...</option>
                                        <option value="Mandarin">Mandarin</option>
                                        <option value="French">Malay</option>
                                        <option value="Mandarin">English</option>
                                        <option value="Japanese">Japanese</option>
                                        <option value="Spanish">Spanish</option>                                       
                                    </select>
                                </div>
                                <button class="action-btn" @onclick="() => CopyToClipboard(msg)">
                                    <div class="action-icon-circle">
                                        <i class="fa-solid @(msg.DidCopy ? "fa-check" : "fa-copy")"></i>
                                    </div> 
                                    <span>@(msg.DidCopy ? "Copied" : "Copy")</span>
                                </button>
                                <button class="action-btn" @onclick="() => ShareContent(msg)">
                                    <div class="action-icon-circle">
                                        <i class="fa-solid fa-share-nodes"></i>
                                    </div>
                                    <span>Share</span>
                                </button>
                            }
                        </div>
                    </div>
                }
            }

            @if (isLoading)
            {
                <div class="doc-query-wrapper">
                    <i class="fa-solid fa-drumstick-bite doc-query-icon"></i>
                    <div class="doc-query">@currentPrompt</div>
                </div>
                <div class="doc-section chat-content">
                    @if (string.IsNullOrEmpty(streamingText))
                    {
                        <span class="thinking-dots">Connecting to T-Rex brain...</span>
                    }
                    else
                    {
                        @( (MarkupString)(streamingHtml ?? string.Empty) )
                        <span class="stream-cursor"></span>
                    }
                </div>
            }

        </div>
    </div>
</div>

<!-- MOBILE FLOATING PROMPT BAR -->
<div class="mobile-prompt-bar">
    <form @onsubmit="OnSubmit" @onsubmit:preventDefault class="mobile-prompt-form">
        <input type="text" class="mobile-prompt-input" 
               @bind="userInput" 
               @bind:event="oninput"
               placeholder="Feed the dino..." 
               disabled="@(isLoading || isRefining)" />
        <button class="mobile-send-btn" type="submit" disabled="@(isLoading || isRefining || string.IsNullOrWhiteSpace(userInput))">
            <i class="fa-solid fa-rocket"></i> Release
        </button>
    </form>
    <p class="mobile-version-text">Version 1.1.0 <a href="/release-notes" target="_blank">Release note</a></p>
</div>


<script type="text/javascript">
    window.scrollToBottom = (el) => {
        if (el) {
            // Smooth scroll that follows the stream like reading along
            el.scrollTo({ top: el.scrollHeight, behavior: 'smooth' });
        }
        // On mobile the portal-right is not a scroll container,
        // so also scroll the window itself
        if (window.innerWidth <= 900) {
            window.scrollTo({ top: document.body.scrollHeight, behavior: 'smooth' });
        }
    };
    window.highlightCode = () => {
        if (window.hljs) {
            window.hljs.highlightAll();
        }
    };
    window.copyTextToClipboard = (text) => {
        navigator.clipboard.writeText(text);
    };
    window.shareContentNative = async (text) => {
        if (navigator.share) {
            try {
                await navigator.share({
                    title: 'From AI Prompt Academy',
                    text: text
                });
            } catch (err) { }
        } else {
            alert('Sharing is not supported on this device/browser automatically. Used "Copy" instead!');
        }
    };
</script>

@code {
    private string streamingText = "";
    private string streamingHtml = "";
    private string userInput = "";
    private string currentPrompt = "";
    private bool isLoading = false;
    private bool isRefining = false;
    private List<Message> messages = new();
    private ElementReference documentContainer;

    private MarkdownPipeline _mdPipeline = default!;

    protected override void OnInitialized()
    {
        var builder = new MarkdownPipelineBuilder().UseAdvancedExtensions();
        builder.BlockParsers.RemoveAll(x => x is IndentedCodeBlockParser);
        _mdPipeline = builder.Build();
    }

    private void InsertTemplate(string template)
    {
        userInput = template;
    }

    private async Task CopyToClipboard(Message msg)
    {
        if (string.IsNullOrEmpty(msg.Text)) return;
        
        await JS.InvokeVoidAsync("copyTextToClipboard", msg.Text);
        msg.DidCopy = true;
        StateHasChanged();
        
        // Reset copy icon after 2 seconds
        await Task.Delay(2000);
        msg.DidCopy = false;
        StateHasChanged();
    }

    private async Task ShareContent(Message msg)
    {
        if (string.IsNullOrEmpty(msg.Text)) return;
        await JS.InvokeVoidAsync("shareContentNative", msg.Text);
    }

    private async Task ChangeLanguage(Message msg, string newLanguage)
    {
        if (string.IsNullOrEmpty(newLanguage) || string.IsNullOrEmpty(msg.Text)) return;

        msg.TargetLanguage = newLanguage;
        msg.IsTranslating = true;
        StateHasChanged();

        try
        {
            // Call the Gemini service translating over the RAW markdown
            var translatedRaw = await Gemini.TranslatePromptAsync(msg.Text, newLanguage);
            
            // Overwrite the original text and HTML so its permanently translated in memory
            msg.Text = translatedRaw;
            msg.Html = Markdown.ToHtml(translatedRaw, _mdPipeline);
        }
        catch (Exception ex)
        {
            Console.WriteLine("Translate error: " + ex.Message);
        }
        finally
        {
            msg.IsTranslating = false;
            msg.TargetLanguage = ""; // Reset dropdown
            StateHasChanged();
            
            // Re-fire syntax highlighter over the translated block
            await JS.InvokeVoidAsync("highlightCode");
        }
    }

    private async Task RefinePrompt()
    {
        if (string.IsNullOrWhiteSpace(userInput)) return;
        isRefining = true;
        StateHasChanged();

        try
        {
            var refined = await Gemini.RefinePromptAsync(userInput);
            userInput = refined;
        }
        catch (Exception)
        {
            // Ignore failure, let user keep their text
        }
        finally
        {
            isRefining = false;
            StateHasChanged();
        }
    }

    private async Task AskAI()
    {
        if (string.IsNullOrWhiteSpace(userInput)) return;

        messages.Add(new Message { Text = userInput, IsUser = true });
        currentPrompt = userInput;
        userInput = "";
        isLoading = true;
        streamingText = "";
        streamingHtml = "";
        StateHasChanged(); 

        try
        {
            await foreach (var chunk in Gemini.AskStreamAsync(currentPrompt))
            {
                streamingText += chunk;
                streamingHtml = Markdown.ToHtml(streamingText, _mdPipeline);
                StateHasChanged();
                await JS.InvokeVoidAsync("scrollToBottom", documentContainer);
            }

            var finalHtml = Markdown.ToHtml(streamingText, _mdPipeline);
            messages.Add(new Message { Text = streamingText, Html = finalHtml, IsUser = false });
        }
        catch (Exception ex)
        {
            messages.Add(new Message { Text = $"❌ Error: {ex.Message}", Html = $"❌ Error: {ex.Message}", IsUser = false });
        }
        finally
        {
            streamingText = "";
            streamingHtml = "";
            currentPrompt = "";
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task OnSubmit()
    {
        await AskAI();
    }

    class Message
    {
        public string? Text { get; set; }
        public string? Html { get; set; }
        public bool IsUser { get; set; }
        public DateTime Time { get; set; } = DateTime.Now;
        
        // UI States
        public bool IsTranslating { get; set; }
        public string TargetLanguage { get; set; } = "";
        public bool DidCopy { get; set; }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (messages.Count > 0 || isLoading)
        {
            await JS.InvokeVoidAsync("scrollToBottom", documentContainer);
        }
        await JS.InvokeVoidAsync("highlightCode");
    }
}
    @* Level pills inside sheet *@
    <div class="fsh-levels @(mobileLevelsGlow ? "guide-glow" : "")">
        @foreach (var lv in Levels)
        {
            <button class="fsh-lv t-@lv.Key @(level == lv.Key ? "on" : "")"
                    @onclick="() => SetLevel(lv.Key)">
                @((MarkupString)lv.Value)
            </button>
        }
    </div>

    @{
        var fwCount = GetCurrentFrameworks().Count();
    }
    <div class="fsh-hint">
        @fwCount style@(fwCount > 1 ? "s" : "") at this level — swipe to explore
    </div>

    @* Swipeable cards *@
    <div class="fsh-cards-wrap">
        <div class="fsh-cards">
            @foreach (var (fw, idx) in GetCurrentFrameworks())
            {
                <div class="fsh-card t-@level @(selFw?.Name == fw.Name ? "sel" : "")">
                    <div class="fsh-card-top">
                        <span class="fsh-card-ico">@((MarkupString)fw.Icon)</span>
                        <span class="fsh-card-name">@fw.Name</span>

@page "/"
@inject GeminiService Gemini
@inject IJSRuntime JS
@using DinoBlazorApp.Components.UI
@using Markdig.Parsers
@using System.Net
@implements IDisposable

@* == SEMANTIC DESIGN SYSTEM LAYOUT == *@
<div class="dino-layout-root">
    <NavMenu @bind-IsMobileDrawerOpen="navOpen" />

    <main class="flex-1 flex flex-col min-w-0 relative overflow-hidden">
        
        <nav class="dino-mobile-nav">
            <div class="flex items-center gap-3">
                <span class="logo-anim" style="width: 34px; height: 34px;"></span>
                <div class="leading-tight">
                    <div class="dino-h3 text-sm">Dino Prompt Academy</div>
                    <div class="dino-p-muted text-[10px] font-medium">Learn prompting -- Master AI</div>
                </div>
            </div>
            <button class="btn btn-ghost btn-square border-dino-bdr text-dino-muted hover:text-dino-cream"
                    @onclick="OpenNav" aria-label="Open menu">
                <i class="ti ti-menu-2 text-xl"></i>
            </button>
        </nav>

        <div class="flex-1 flex min-h-0 overflow-hidden relative">
            
            <aside class="dino-sidebar">
                <div class="px-5 pt-6 pb-2 flex flex-col gap-2 shrink-0">
                    
                    @* Brand / Header *@
                    <div class="flex items-center gap-4 px-2">
                        <div>
                            <h1 class="dino-h1">Dino AI Academy</h1>
                            <p class="text-xs text-dino-muted mt-0.5">Learn prompting . Master AI</p>
                        </div>
                    </div>

                    @* ===== SECTION: Levels ===== *@
                    <hr class="border-t border-dino-bdr/50" style="padding:0px;margin: 0px;" />

                    <div class="flex flex-col gap-3 @(desktopLevelsGlow ? "ring-2 ring-primary/30 rounded-2xl p-3 bg-primary/5 animate-pulse" : "px-1")">
                        <div class="px-1"><label class="dino-label-primary">Levels</label></div>
                        <div class="flex flex-wrap gap-2 fw-level">
                            @foreach (var lv in Levels)
                            {
                                <button class="btn-level dino-level-@lv.Key @(level == lv.Key ? "active" : "")"
                                        @onclick="() => SetLevel(lv.Key)">
                                    @((MarkupString)lv.Value)
                                </button>
                            }
                        </div>
                    </div>
                </div>
                 
                @* ===== SECTION: Prompt Frameworks ===== *@
                <div class="flex flex-col gap-3 px-6 pb-6 flex-1 min-h-0">
                     <hr class="border-t border-dino-bdr/50" style="padding:0px;margin: 0px;" />

                    <div class="px-1 shrink-0"><label class="dino-label-primary">Prompt Frameworks</label></div>
                    <div class="flex-1 overflow-y-auto scrollbar-hide pr-1 pb-4 flex flex-col gap-2.5">
                        <div class="grid grid-cols-1 gap-3">
                            @foreach (var (fw, idx) in GetCurrentFrameworks())
                            {
                                <div class="dino-fw-card group dino-level-@level @(selFw?.Name == fw.Name ? "active" : "")"
                                     @onclick="() => PickFw(idx)">
                                    
                                    <div class="flex items-center justify-between gap-2 mb-1">
                                        <div class="flex items-center gap-2.5">
                                            <span class="text-lg text-dino-cream">@((MarkupString)fw.Icon)</span>
                                            <span class="dino-fw-name">@fw.Name</span>
                                        </div>
                                        <div class="flex items-center gap-2">
                                            @if (selFw?.Name == fw.Name)
                                            {
                                                <i class="ti ti-circle-check-filled text-[var(--level-color)] text-lg animate-scale-in"></i>
                                            }
                                            <span class="dino-tier-badge">@fw.Badge</span>
                                        </div>
                                    </div>
                                    
                                    <div class="text-[11px] text-dino-muted leading-relaxed line-clamp-2 mb-3">@fw.Desc</div>
                                    
                                    <div class="flex">
                                        <span class="dino-fw-tag">@fw.Tag</span>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                </div>

            </aside>

            <main class="dino-main-canvas">
                
                @* Ambient glow background *@
                <div class="absolute inset-0 pointer-events-none overflow-hidden">
                    <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] bg-dino-amber/5 blur-[120px] rounded-full"></div>
                    <div class="absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] bg-blue-500/5 blur-[120px] rounded-full"></div>
                </div>

                @* Header Bar *@
                @if (messages.Count > 0 || isLoading)
                {
                    <div class="flex items-center justify-between px-6 py-3 bg-dino-bg/60 backdrop-blur-md border-b border-dino-bdr shrink-0 z-20">
                        <div class="flex items-center gap-3">
                            <span class="logo-anim" style="width: 24px; height: 24px;"></span>
                            <span class="dino-label-sm">Active Extraction</span>
                        </div>
                        <button class="dino-btn-ghost h-8" @onclick="NewSession">
                            <i class="ti ti-refresh"></i> New Session
                        </button>
                    </div>
                }

                @* Scroll Container *@
                <div class="dino-message-container flex-1 min-h-0 overflow-y-auto px-6 py-4 flex flex-col gap-6 pb-[132px] md:pb-4"
                     @ref="documentContainer">
                    <div class="dino-welcome-screen">

                        @* Welcome screen *@
                        @if (messages.Count == 0 && !isLoading)
                        {
                            <div class="dino-intro-section flex flex-col items-center text-center mx-auto">
                                <div class="h-32 flex items-center justify-center mb-6">
                                    <span class="logo-anim" style="width: 110px; height: 110px;"></span>
                                </div>
                                <h2 class="dino-h2 !text-3xl md:!text-4xl mb-4">What will you prompt today?</h2>
                                <p class="dino-p-muted max-w-lg mb-12">Three steps is all it takes. The dino handles the rest, turning your thoughts into master-class directives.</p>
                                
                                <div class="grid grid-cols-1 md:grid-cols-3 gap-4 w-full max-w-2xl px-2">
                                    <button type="button" @onclick="StartStep1Guide"
                                            class="group dino-card-step active !py-4 !px-2">
                                        <div class="dino-step-label">Step 1</div>
                                        <div class="text-primary group-hover:scale-110 transition-transform my-1">
                                            <iconify-icon icon="glyphs-poly:crosshairs" width="36" height="36"></iconify-icon>
                                        </div>
                                        <div class="text-sm font-bold text-dino-cream text-center leading-tight">Choose<br/>Level</div>
                                    </button>
 
                                    <div class="group dino-card-step @(step2Nudge ? "active" : "opacity-50 cursor-not-allowed") !py-4 !px-2">
                                        <div class="dino-step-label">Step 2</div>
                                        <div class="text-primary transition-transform group-hover:scale-110 my-1">
                                            <iconify-icon icon="glyphs-poly:note-pad" width="36" height="36"></iconify-icon>
                                        </div>
                                        <div class="text-sm font-bold text-dino-cream text-center leading-tight">Choose<br/>Framework</div>
                                    </div>
 
                                    <div class="group dino-card-step opacity-40 cursor-not-allowed !py-4 !px-2">
                                        <div class="dino-step-label">Step 3</div>
                                        <div class="text-dino-muted2 transition-transform group-hover:scale-110 my-1">
                                            <iconify-icon icon="glyphs-poly:rocket" width="36" height="36"></iconify-icon>
                                        </div>
                                        <div class="text-sm font-bold text-dino-cream text-center leading-tight">Release<br/>Dino!</div>
                                    </div>
                                </div>
                            </div>
                        }

                        @* Message history *@
                        @foreach (var msg in messages)
                        {
                            <div class="chat-message">
                                @if (msg.IsUser)
                                {
                                    <div class="user-message-row">
                                        <div class="user-message-stack">
                                            <div class="user-prompt-bubble">
                                                @msg.Text
                                            </div>
                                            <div class="message-meta">
                                                <span>You</span>
                                                <i class="ti ti-user-circle text-dino-muted text-sm"></i>
                                            </div>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <div class="flex gap-4">
                                        <div class="flex flex-col gap-3 w-full">
                                            <div class="flex items-center gap-2 px-1">
                                                <span class="logo-anim" style="width: 22px; height: 22px;"></span>
                                                <span class="text-[10px] font-extrabold text-dino-amber uppercase tracking-[2px]">Master Dino</span>
                                            </div>
                                            <div class="assistant-response-bubble prose prose-invert max-w-none chat-response">
                                                @((MarkupString)(msg.Html ?? string.Empty))
                                            </div>
                                            
                                            <div class="flex flex-wrap items-center gap-3 px-2">
                                                @if (msg.IsTranslating)
                                                {
                                                    <div class="flex items-center gap-2 text-[10px] font-bold text-dino-amber uppercase animate-pulse">
                                                        <i class="ti ti-loader-2 animate-spin"></i> Translating...
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div class="flex items-center gap-2 bg-dino-surf2 border border-dino-bdr rounded-lg px-2.5 py-1">
                                                        <i class="ti ti-world text-dino-muted text-xs"></i>
                                                        <select class="bg-transparent border-none outline-none text-[10px] font-bold text-dino-cream cursor-pointer"
                                                                value="@msg.TargetLanguage"
                                                                @onchange="@(e => ChangeLanguage(msg, e.Value?.ToString() ?? string.Empty))">
                                                            <option value="">Translate...</option>
                                                            <option value="English">English</option>
                                                            <option value="Mandarin">Mandarin</option>
                                                            <option value="Malay">Malay</option>
                                                            <option value="Japanese">Japanese</option>                                               
                                                        </select>
                                                    </div>
                                                    <button class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg border text-[10px] font-bold transition-all
                                                                   @(msg.DidCopy ? "bg-green-500/10 border-green-500/30 text-green-400" : "bg-dino-surf2 border-dino-bdr text-dino-muted hover:text-dino-cream hover:border-dino-bdr2")"
                                                            @onclick="() => CopyToClipboard(msg)">
                                                        <i class="ti @(msg.DidCopy ? "ti-circle-check" : "ti-copy")"></i>
                                                        @(msg.DidCopy ? "Copied" : "Copy")
                                                    </button>
                                                    <button class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-dino-surf2 border border-dino-bdr text-[10px] font-bold text-dino-muted hover:text-dino-cream hover:border-dino-bdr2 transition-all"
                                                            @onclick="() => ShareContent(msg)">
                                                        <i class="ti ti-share"></i> Share
                                                    </button>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }

                        @* Live streaming *@
                        @if (isLoading)
                        {
                            <div class="chat-message chat-message--loading">
                                <div class="user-message-row">
                                    <div class="user-message-stack">
                                        <div class="user-prompt-bubble user-prompt-bubble--pending">
                                            @currentPrompt
                                        </div>
                                    </div>
                                </div>

                                @if (string.IsNullOrEmpty(streamingText))
                                {
                                    <div class="flex flex-col items-center gap-4 py-8">
                                        @if (streamStatuses.Count > 0)
                                        {
                                            <div class="flex flex-wrap justify-center gap-2 max-w-2xl">
                                                @foreach (var status in streamStatuses)
                                                {
                                                    <span class="inline-flex items-center gap-2 rounded-full border border-dino-amber/25 bg-dino-amber/10 px-3 py-1.5 text-[11px] font-semibold text-dino-amber">
                                                        <i class="ti ti-activity-heartbeat text-sm"></i>
                                                        @status
                                                    </span>
                                                }
                                            </div>
                                        }
                                        <div class="flex gap-1.5">
                                            <div class="w-2.5 h-2.5 rounded-full bg-dino-amber animate-bounce [animation-delay:-0.3s]"></div>
                                            <div class="w-2.5 h-2.5 rounded-full bg-dino-amber animate-bounce [animation-delay:-0.15s]"></div>
                                            <div class="w-2.5 h-2.5 rounded-full bg-dino-amber animate-bounce"></div>
                                        </div>
                                        <span class="text-[11px] font-bold text-dino-amber uppercase tracking-[3px]">T-Rex brain is thinking...</span>
                                    </div>
                                }
                                else
                                {
                                    <div class="flex gap-4">
                                        <div class="flex flex-col gap-3 w-full">
                                            <div class="flex items-center gap-2 px-1">
                                                <span class="logo-anim" style="width: 22px; height: 22px;"></span>
                                                <span class="text-[10px] font-extrabold text-dino-amber uppercase tracking-[2px]">Generating response</span>
                                            </div>
                                            @if (streamStatuses.Count > 0)
                                            {
                                                <div class="flex flex-wrap gap-2">
                                                    @foreach (var status in streamStatuses)
                                                    {
                                                        <span class="inline-flex items-center gap-2 rounded-full border border-dino-amber/25 bg-dino-amber/10 px-3 py-1.5 text-[11px] font-semibold text-dino-amber">
                                                            <i class="ti ti-activity-heartbeat text-sm"></i>
                                                            @status
                                                        </span>
                                                    }
                                                </div>
                                            }
                                            <div class="assistant-response-bubble assistant-response-bubble--stream">
                                                <div class="prose prose-invert max-w-none chat-response">
                                                    @((MarkupString)(streamingHtml ?? string.Empty))
                                                    <span class="inline-block w-1.5 h-4 bg-dino-amber ml-1 animate-blink align-middle"></span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>

                @* Main Canvas Prompt Box (Desktop) *@
                <div class="dino-prompt-wrapper hidden md:flex shrink-0 flex-col pb-8 pt-4 px-8 z-30 w-full relative">
                    <div class="w-full max-w-4xl mx-auto flex flex-col gap-2">
                        <div class="dino-input-group relative">
                            <textarea class="dino-textarea min-h-[80px] max-h-[300px] !resize-y bg-transparent px-4 py-2 text-sm leading-relaxed text-dino-cream placeholder:text-dino-muted/50"
                                      id="deskTa" data-prompt-editor="true" data-max-height="400"
                                      @bind="userInput" @bind:event="oninput" @bind:after="OnPromptChangedAsync"
                                      placeholder="Choose a template from the sidebar, or write your own directive here..."
                                      disabled="@(isLoading || isRefining)" rows="3"></textarea>
                            
                            <div class="dino-prompt-actions flex items-center justify-between mt-1 pt-2 px-3">
                                <span class="text-[10px] font-bold @(userInput.Length > 3600 ? "text-error" : "text-dino-muted2")">
                                    @userInput.Length / @MaxPromptLength
                                </span>
                                <div class="flex items-center gap-3">
                                    <button class="dino-btn-ghost @(isRefining ? "animate-pulse" : "")"
                                            @onclick="RefinePrompt"
                                            disabled="@(isLoading || isRefining || string.IsNullOrWhiteSpace(userInput) || userInput.Length > MaxPromptLength)">
                                        <i class="ti ti-sparkles @(isRefining ? "animate-spin" : "")"></i> Sharpen
                                    </button>
                                    <button class="dino-btn-primary px-8 shadow-lg font-extrabold tracking-wide"
                                            @onclick="OnSubmit"
                                            disabled="@(isLoading || isRefining || string.IsNullOrWhiteSpace(userInput) || userInput.Length > MaxPromptLength)">
                                        <i class="ti ti-rocket"></i> Release!
                                    </button>
                                </div>
                            </div>
                        </div>
                        @if (isRefining)
                        {
                            <div class="flex items-center justify-center gap-2 px-3 py-2 animate-pulse mx-auto mt-2">
                                <i class="ti ti-bolt text-dino-amber"></i>
                                <p class="text-[10px] font-bold text-dino-amber/80 uppercase">Sharpening your directive...</p>
                            </div>
                        }
                    </div>
                </div>
            </main>
        </div>
    </main>

    @* -- MOBILE OVERLAYS -- *@
    
    @* Floating Guide Strip (Mobile Bottom) *@
    <div class="md:hidden fixed bottom-[76px] left-4 right-4 z-40 transition-all duration-300 @(GuideStripHidden ? "translate-y-24 opacity-0 pointer-events-none" : "translate-y-0 opacity-100")">
        <div class="bg-dino-surf/90 backdrop-blur-lg border border-dino-amber/30 rounded-2xl p-3 shadow-2xl flex items-center gap-3" @onclick="OpenFwSheet">
            <div class="w-10 h-10 rounded-xl bg-dino-amber/10 flex items-center justify-center text-dino-amber shrink-0">
                <i class="ti ti-fossil text-xl"></i>
            </div>
            <div class="flex-1 min-w-0">
                <div class="text-[10px] font-black text-dino-amber uppercase tracking-widest leading-none mb-1">Current Style</div>
                <div class="text-xs font-bold text-dino-cream truncate">
                    @(selFw != null ? selFw.Name : "Pick a prompt style...")
                </div>
            </div>
            <div class="flex items-center gap-2">
                @if (selFw != null)
                {
                    <button class="w-8 h-8 rounded-lg bg-dino-surf2 border border-dino-bdr flex items-center justify-center text-dino-muted"
                            @onclick="ClearStyle" @onclick:stopPropagation="true">
                        <i class="ti ti-x text-sm"></i>
                    </button>
                    <div class="w-8 h-8 rounded-lg bg-dino-amber flex items-center justify-center text-dino-bg">
                        <i class="ti ti-refresh text-sm font-bold"></i>
                    </div>
                }
                else
                {
                    <div class="text-dino-amber animate-pulse">
                        <i class="ti ti-chevron-right text-xl"></i>
                    </div>
                }
            </div>
        </div>
    </div>

    @* Mobile Input Bar *@
    <div class="md:hidden fixed bottom-0 left-0 right-0 bg-dino-surf border-t border-dino-bdr p-3 flex gap-3 z-40 shadow-[0_-10px_30px_rgba(0,0,0,0.5)]">
        <div class="flex-1 bg-black/40 border border-dino-bdr rounded-xl px-3 py-2 flex items-center">
            <textarea class="w-full bg-transparent border-none outline-none text-dino-cream text-sm leading-relaxed resize-none scrollbar-none"
                      id="mobTa" data-prompt-editor="true" data-max-height="120"
                      @bind="userInput" @bind:event="oninput" @bind:after="OnPromptChangedAsync"
                      placeholder="Feed the dino a prompt..."
                      disabled="@(isLoading || isRefining)" rows="1"></textarea>
        </div>
        <button class="w-12 h-12 rounded-xl bg-dino-amber text-dino-bg flex items-center justify-center shadow-lg active:scale-95 transition-transform"
                @onclick="OnSubmit"
                disabled="@(isLoading || isRefining || string.IsNullOrWhiteSpace(userInput) || userInput.Length > MaxPromptLength)">
            <i class="ti ti-rocket text-xl"></i>
        </button>
    </div>

    @* Mobile Framework Sheet *@
    @if (fwSheetOpen)
    {
        <div class="md:hidden fixed inset-0 bg-black/80 z-[100] backdrop-blur-sm animate-fade-in" @onclick="CloseFwSheet"></div>
    }
    <div class="md:hidden fixed bottom-0 left-0 right-0 bg-dino-surf border-t border-dino-bdr rounded-t-[32px] z-[101] shadow-2xl transition-transform duration-500 ease-out flex flex-col max-h-[85vh]
                @(fwSheetOpen ? "translate-y-0" : "translate-y-full")">
        
        <div class="w-12 h-1.5 bg-dino-bdr rounded-full mx-auto mt-4 mb-2 shrink-0"></div>
        
        <div class="px-6 py-4 border-b border-dino-bdr shrink-0">
            <div class="flex items-center gap-3 mb-1">
                <h3 class="font-display font-bold text-lg text-dino-cream">Choose style</h3>
                <span class="logo-anim" style="width: 24px; height: 24px;"></span>
            </div>
            <p class="text-[11px] text-dino-muted">Pick what fits --- the framework is handled behind the scenes.</p>
        </div>

        <div class="flex-1 overflow-y-auto px-6 py-4 flex flex-col gap-6">
            @* Levels in sheet *@
            <div class="flex flex-col gap-3 @(mobileLevelsGlow ? "ring-2 ring-dino-amber/30 rounded-2xl p-3 bg-dino-amber/5" : "")">
                <div class="flex flex-wrap gap-2">
                    @foreach (var lv in Levels)
                    {
                        <button class="btn-level dino-level-@lv.Key @(level == lv.Key ? "active" : "")"
                                @onclick="() => SetLevel(lv.Key)">
                            @((MarkupString)lv.Value)
                        </button>
                    }
                </div>
            </div>

            @* Framework cards in sheet *@
            <div class="flex flex-col gap-4 pb-12">
                @foreach (var (fw, idx) in GetCurrentFrameworks())
                {
                    <div class="dino-fw-card dino-level-@level @(selFw?.Name == fw.Name ? "active" : "")"
                         @onclick="() => PickFwMob(idx)">
                        
                        @if (selFw?.Name == fw.Name)
                        {
                            <div class="absolute top-0 right-0 p-3">
                                <i class="ti ti-circle-check-filled text-primary animate-scale-in"></i>
                            </div>
                        }

                        <div class="flex items-center gap-3">
                            <span class="text-xl shrink-0">@((MarkupString)fw.Icon)</span>
                            <span class="font-display font-bold text-base-content flex-1">@fw.Name</span>
                            <span class="dino-badge-@fw.Bc">@fw.Badge</span>
                        </div>
                        <div class="text-xs text-dino-muted leading-relaxed">@fw.Desc</div>
                        <div class="flex items-center justify-between mt-1">
                            <span class="text-[10px] font-bold px-2 py-0.5 bg-primary/10 text-primary rounded-md border border-primary/20">@fw.Tag</span>
                            @if (selFw?.Name != fw.Name)
                            {
                                <button class="dino-btn-primary h-7 px-3 text-[9px]">Use style</button>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

</div>

@* -- JS HELPERS -- *@
<script type="text/javascript">
    window.scrollToBottom = (el) => {
        if (el) el.scrollTo({ top: el.scrollHeight, behavior: 'smooth' });
        if (window.innerWidth <= 860)
            window.scrollTo({ top: document.body.scrollHeight, behavior: 'smooth' });
    };
    window.highlightCode = () => {
        if (window.hljs) hljs.highlightAll();
    };
    window.copyTextToClipboard = (text) => {
        navigator.clipboard.writeText(text);
    };
    window.shareContentNative = async (text) => {
        if (navigator.share) {
            try { await navigator.share({ title: 'From Dino Prompt Academy', text }); } catch {}
        } else {
            navigator.clipboard.writeText(text);
        }
    };
    window.syncPromptEditors = () => {
        document.querySelectorAll('[data-prompt-editor="true"]').forEach((el) => {
            const maxHeight = parseInt(el.dataset.maxHeight || '200', 10);
            el.style.height = 'auto';
            const nextHeight = Math.min(el.scrollHeight, maxHeight);
            el.style.height = `${nextHeight}px`;
        });
    };
    window.isMobileView = () => window.innerWidth <= 860;
</script>



@code {
    private const int MaxPromptLength = 4000;

    // ------------------------------------------------------------------------------------------------------
    // FRAMEWORK DATA
    // ------------------------------------------------------------------------------------------------------
    private record FrameworkItem(
        string Icon, string Name, string Desc,
        string Tag, string Badge, string Bc, string Tpl);

    private static readonly Dictionary<int, string> Levels = new()
    {
        { 1, "Baby" },
        { 2, "Explorer" },
        { 3, "Pro" },
        { 4, "Expert" },
        { 5, "Master" }
    };

    private static readonly Dictionary<int, List<FrameworkItem>> FW = new()
    {
        { 1, new() {
            new("<i class='ti ti-message-reply'></i>", "Get a quick answer",
                "Simple questions, definitions, short explanations. No fuss --- just ask.",
                "PRO Framework", "L1", "b1",

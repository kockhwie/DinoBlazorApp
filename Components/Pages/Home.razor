    private async Task TriggerDraftRefinement()
    {
        if (string.IsNullOrWhiteSpace(EmailDraft.Message))
        {
            await ShowToast(L["Home.Assistant.EmptyDraft.Title"], isError: true);
            return;
        }

        isLoading = true;
        refineOriginal = EmailDraft.Message;
        refinedEmail = "";
        StateHasChanged();

        var result = await EmailAssistant.RefineEmailAsync(EmailDraft.Message, refineInstruction);
        refinedEmail = result.Content;
        EmailDraft = EmailDraft with { StatusMessage = string.Empty };

        await ShowToast(FormatAssistantStatus(result, "Refined"));
        isLoading = false;
    }


            StatusMessage = string.Empty
        };
    }

    private async Task TriggerPromptGeneration()
    {
        if (string.IsNullOrWhiteSpace(promptInput)) return;

        isLoading = true;
        generatedEmail = "";
        StateHasChanged();

        var result = await EmailAssistant.GenerateEmailAsync(promptInput);

        generatedEmail = result.Content;
        EmailDraft = EmailDraft with { Message = generatedEmail, StatusMessage = string.Empty };

        await ShowToast(FormatAssistantStatus(result, "Generated"));
        isLoading = false;


@* ══ JS HELPERS ══ *@
<script type="text/javascript">
    window.scrollToBottom = (el) => {
        if (el) el.scrollTo({ top: el.scrollHeight, behavior: 'smooth' });
        if (window.innerWidth <= 860)
            window.scrollTo({ top: document.body.scrollHeight, behavior: 'smooth' });
    };
    window.highlightCode = () => {
        if (window.hljs) hljs.highlightAll();
    };
    window.copyTextToClipboard = (text) => {
        navigator.clipboard.writeText(text);
    };
    window.shareContentNative = async (text) => {
        if (navigator.share) {
            try { await navigator.share({ title: 'From Dino Prompt Academy', text }); } catch {}
        } else {
            navigator.clipboard.writeText(text);
        }
    };
    window.syncPromptEditors = () => {
        document.querySelectorAll('[data-prompt-editor="true"]').forEach((el) => {
            const maxHeight = parseInt(el.dataset.maxHeight || '200', 10);
            el.style.height = 'auto';
            const nextHeight = Math.min(el.scrollHeight, maxHeight);
            el.style.height = `${nextHeight}px`;
        });
    };
    window.isMobileView = () => window.innerWidth <= 860;
</script>


@code {
    private const int MaxPromptLength = 4000;

    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    // FRAMEWORK DATA

@page "/"
@using DinoAI.Services
@using Microsoft.Extensions.Localization
@inject IEmailAssistantService EmailAssistant
@inject IStringLocalizer<SharedResource> L

<PageTitle>Dino AI Academy</PageTitle>

<main class="home-page">
    <section class="hero-shell">
        <SiteNav />

        <div class="hero-grid">
            <div class="hero-copy">
                <h1>@L["Home.Hero.Title1"]<br />@L["Home.Hero.Title2"]</h1>
                <p class="lead">
                    @L["Home.Hero.Lead"]
                </p>

                <div class="benefits">
                    <div class="benefit">
                        <span class="benefit-icon"><i class="ti ti-leaf"></i></span>                       
                        <div class="benefit-content">
                            <div class="benefit-title">@L["Home.Benefit.LearnAI"]</div>
                            <div class="benefit-brief">@L["Home.Benefit.LearnAI.Brief"]</div>
                        </div>
                    </div>
                    <div class="benefit">
                        <span class="benefit-icon"><i class="ti ti-mountain"></i></span>                        
                        <div class="benefit-content">
                            <div class="benefit-title">@L["Home.Benefit.BuildProjects"]</div>
                            <div class="benefit-brief">@L["Home.Benefit.BuildProjects.Brief"]</div>
                        </div>
                    </div>
                    <div class="benefit">
                        <span class="benefit-icon"><i class="ti ti-cloud-network"></i></span>
                        <div class="benefit-content">
                            <div class="benefit-title">@L["Home.Benefit.JoinCommunity"]</div>
                            <div class="benefit-brief">@L["Home.Benefit.JoinCommunity.Brief"]</div>
                        </div>
                    </div>
                    <div class="benefit">
                        <span class="benefit-icon"><i class="ti ti-briefcase"></i></span>
                        <div class="benefit-content">
                            <div class="benefit-title">@L["Home.Benefit.AdvanceCareer"]</div>
                            <div class="benefit-brief">@L["Home.Benefit.AdvanceCareer.Brief"]</div>
                        </div>
                    </div>
                </div>

                <div class="hero-actions">
                    <a href="/membership" class="btn btn-cta">@L["Home.Hero.StartCta"] <i class="ti ti-chevron-right"></i></a>
                </div>
            </div>

            <div class="hero-visual" aria-hidden="true">
                <img alt="" class="hero-mascot" src="@Assets["assets/dino_mascot.png"]" />
            </div>
        </div>
    </section>

    <section class="showcase-shell">
        <div class="showcase-panel workbench">
            <div class="panel-title-composer">
                <i class="ti ti-mail-fast"></i>
                <span>@L["Home.Composer.Title"]</span>
            </div>

            <EditForm Model="@EmailDraft" class="flex flex-col gap-4 w-full">
                <div class="space-y-3">
                    <fieldset class="fieldset p-0">
                        <legend class="fieldset-legend text-xs font-bold uppercase tracking-wider text-slate-300">@L["Home.Composer.Label.To"]</legend>
                        <input class="input input-sm w-full bg-[#031810] border-slate-700/60 text-slate-200 focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500" @bind="EmailDraft.To"
                               aria-label="@L["Home.Composer.Label.To"]" />
                    </fieldset>

                    <fieldset class="fieldset p-0">
                        <legend class="fieldset-legend text-xs font-bold uppercase tracking-wider text-slate-300">@L["Home.Composer.Label.Subject"]</legend>
                        <input class="input input-sm w-full bg-[#031810] border-slate-700/60 text-slate-200 focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500" @bind="EmailDraft.Subject"
                               aria-label="@L["Home.Composer.Label.Subject"]" />
                    </fieldset>

                    <fieldset class="fieldset p-0">
                        <legend class="fieldset-legend text-xs font-bold uppercase tracking-wider text-slate-300">@L["Home.Composer.Label.Message"]</legend>
                        <textarea id="txtDraftEmailMessage" @bind="EmailDraft.Message"
                                  rows="10" class="textarea textarea-sm w-full bg-[#031810] border-slate-700/60 text-slate-200 focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 resize-none h-[280px]"
                                  placeholder="@L["Home.Composer.Placeholder.Message"]"
                                  aria-label="@L["Home.Composer.Label.Message"]"></textarea>
                    </fieldset>
                </div> 
                <div class="composer-actions">
                    <!--button type="button" class="mini-btn ghost" @onclick="ClearDraft">@L["Home.Composer.Action.Clear"]</button-->
                    <button type="button" class="mini-btn solid" @onclick="LoadImprovedDraft">@L["Home.Composer.Action.Improve"] </button>
                    <button type="button" class="mini-btn solid" @onclick="HandleSendEmail">@L["Home.Composer.Action.Send"]</button>
                </div>
                <!--  status moved to toast — remove this block entirely -->
                @*    
                @if (!string.IsNullOrWhiteSpace(EmailDraft.StatusMessage))
                {
                    <div class="text-xs text-emerald-400 mt-2 px-1 text-right">
                        @EmailDraft.StatusMessage
                    </div>
                }
                *@
            </EditForm>
        </div>

        <div class="showcase-panel assistant">
            <div class="panel-title">
                <i class="ti ti-robot text-[#33d7a6] text-lg"></i>
                <span>@L["Home.Assistant.Title"]</span>
            </div>
 
            @if (currentView == "options")
            {
                <p class="assistant-subtitle">@L["Home.Assistant.ChooseAction"]</p>
                <div class="assistant-options">

                    <!-- Option 1: Generate from Prompt -->
                    <button type="button" @onclick='() => SelectOption("generate")' class="assistant-option assistant-option-generate">
                        <div class="assistant-option-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 36 36">
                                <path d="M0 0h36v36H0z" fill="none" />
                                <path fill="#ffd983" d="M29 11.06c0 6.439-5 7.439-5 13.44c0 3.098-3.123 3.359-5.5 3.359c-2.053 0-6.586-.779-6.586-3.361C11.914 18.5 7 17.5 7 11.06C7 5.029 12.285.14 18.083.14C23.883.14 29 5.029 29 11.06" />
                                <path fill="#ccd6dd" d="M22.167 32.5c0 .828-2.234 2.5-4.167 2.5s-4.167-1.672-4.167-2.5S16.066 32 18 32s4.167-.328 4.167.5" />
                                <path fill="#ffcc4d" d="M22.707 10.293a1 1 0 0 0-1.414 0L18 13.586l-3.293-3.293a.999.999 0 1 0-1.414 1.414L17 15.414V26a1 1 0 1 0 2 0V15.414l3.707-3.707a1 1 0 0 0 0-1.414" />
                                <path fill="#99aab5" d="M24 31a2 2 0 0 1-2 2h-8a2 2 0 0 1-2-2v-6h12z" />
                                <path fill="#ccd6dd" d="M11.999 32a1 1 0 0 1-.163-1.986l12-2a.994.994 0 0 1 1.15.822a1 1 0 0 1-.822 1.15l-12 2a1 1 0 0 1-.165.014m0-4a1 1 0 0 1-.163-1.986l12-2a.995.995 0 0 1 1.15.822a1 1 0 0 1-.822 1.15l-12 2a1 1 0 0 1-.165.014" />
                            </svg>
                        </div>
                        <div class="assistant-option-bubble">
                            <div class="stars-container">
                                <span class="stars">★</span>
                            </div>
                            <h3>@L["Assistant.Option.Generate.Title"] </h3>
                            <p>@L["Assistant.Option.Generate.Description"]</p>
                        </div>
                        <span class="assistant-option-arrow"><i class="ti ti-arrow-narrow-right-dashed"></i></span>
                    </button>


                    <!-- Option 2: Refine My Email -->
                    <button type="button" @onclick='() => SelectOption("refine")' class="assistant-option assistant-option-refine">
                        <div class="assistant-option-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" width="1.4em" height="1.4em" viewBox="0 0 32 32">
                                <path d="M0 0h32v32H0z" fill="none" />
                                <g fill="none">
                                    <path fill="#433B6B" d="m5 29l-2-2l16-16l2 2z" />
                                    <path fill="#F4F4F4" d="m18 12l2 2l1.674-1.667c.435-.445.435-1.24 0-1.675l-.33-.331C20.9 9.89 20 10 19.5 10.5zM2.338 29.252l.41.41c.44.452 1.17.452 1.61-.01L6 28.007L4 26l-1.662 1.627a1.146 1.146 0 0 0 0 1.625" />
                                    <path fill="#F9C23C" d="M27.87 4.423c.131.284.352.508.644.635l1.215.527a.453.453 0 0 1 0 .83l-1.205.527a1.22 1.22 0 0 0-.643.635l-.954 2.167c-.17.341-.683.341-.854 0l-.954-2.167a1.26 1.26 0 0 0-.643-.635l-1.205-.527a.453.453 0 0 1 0-.83l1.205-.527a1.22 1.22 0 0 0 .643-.635l.954-2.167c.17-.341.683-.341.854 0zm-11.429 1.18a.88.88 0 0 1-.458-.438l-.676-1.49c-.125-.233-.49-.233-.614 0l-.676 1.49a.85.85 0 0 1-.458.438l-.864.36a.309.309 0 0 0 0 .574l.864.36a.9.9 0 0 1 .458.438l.676 1.49c.125.233.49.233.614 0l.676-1.49a.85.85 0 0 1-.458.438l.864-.36a.309.309 0 0 0 0-.574zm9.51 10.695a.95.95 0 0 1-.46-.48l-.686-1.622c-.128-.261-.492-.261-.61 0l-.685 1.623a.95.95 0 0 1-.46.479l-.857.392c-.257.13-.257.5 0 .62l.856.392a.95.95 0 0 1 .46.48l.686 1.622c.128.261.492.261.61 0l.685-1.622a.95.95 0 0 1 .46-.48l.857-.392c.257-.13.257-.5 0-.62zM12 14a1 1 0 1 0 0-2a1 1 0 0 0 0 2m18-1a1 1 0 1 1-2 0a1 1 0 0 1 2 0M19 4a1 1 0 1 0 0-2a1 1 0 0 0 0 2m1 17a1 1 0 1 1-2 0a1 1 0 0 1 2 0" />
                                </g>
                            </svg>
                        </div>
                        <div class="assistant-option-bubble">
                            <div class="stars-container">
                                <span class="stars">★</span>
                                <span class="stars">★</span>
                            </div>
                            <h3>@L["Assistant.Option.Refine.Title"] </h3>
                            <p>@L["Assistant.Option.Refine.Description"]</p>
                        </div>
                        <span class="assistant-option-arrow"><i class="ti ti-arrow-narrow-right-dashed"></i></span>
                    </button>                    


                    <!-- Option 3: Professional Upgrade -->
                    <button type="button" @onclick='() => SelectOption("professional")' class="assistant-option assistant-option-professional">
                        <div class="assistant-option-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" width="1.2em" height="1.2em" viewBox="0 0 36 36">
                                <path d="M0 0h36v36H0z" fill="none" />
                                <path fill="#f4900c" d="M14.174 17.075L6.75 7.594l-3.722 9.481z" />
                                <path fill="#f4900c" d="m17.938 5.534l-6.563 12.389H24.5z" />
                                <path fill="#f4900c" d="m21.826 17.075l7.424-9.481l3.722 9.481z" />
                                <path fill="#ffcc4d" d="M28.669 15.19L23.887 3.523l-5.88 11.668l-.007.003l-.007-.004l-5.88-11.668L7.331 15.19C4.197 10.833 1.28 8.042 1.28 8.042S3 20.75 3 33h30c0-12.25 1.72-24.958 1.72-24.958s-2.917 2.791-6.051 7.148" />
                                <circle cx="17.957" cy="22" r="3.688" fill="#5c913b" />
                                <circle cx="26.463" cy="22" r="2.412" fill="#981ceb" />
                                <circle cx="32.852" cy="22" r="1.986" fill="#dd2e44" />
                                <circle cx="9.45" cy="22" r="2.412" fill="#981ceb" />
                                <circle cx="3.061" cy="22" r="1.986" fill="#dd2e44" />
                                <path fill="#ffac33" d="M33 34H3a1 1 0 1 1 0-2h30a1 1 0 1 1 0 2m0-3.486H3a1 1 0 1 1 0-2h30a1 1 0 1 1 0 2" />
                                <circle cx="1.447" cy="8.042" r="1.407" fill="#ffcc4d" />
                                <circle cx="6.75" cy="7.594" r="1.192" fill="#f4900c" />
                                <circle cx="12.113" cy="3.523" r="1.784" fill="#ffcc4d" />
                                <circle cx="34.553" cy="8.042" r="1.407" fill="#ffcc4d" />
                                <circle cx="29.25" cy="7.594" r="1.192" fill="#f4900c" />
                                <circle cx="23.887" cy="3.523" r="1.784" fill="#ffcc4d" />
                                <circle cx="17.938" cy="5.534" r="1.784" fill="#f4900c" />
                            </svg>
                        </div>
                        <div class="assistant-option-bubble">
                            <div class="stars-container">
                                <span class="stars">★</span>
                                <span class="stars">★</span>
                                <span class="stars">★</span>
                            </div>
                            <h3>@L["Assistant.Option.Professional.Title"] </h3>
                            <p>@L["Assistant.Option.Professional.Description"]</p>
                        </div>
                        <span class="assistant-option-arrow"><i class="ti ti-arrow-narrow-right-dashed"></i></span>
                    </button>
                </div>
            }
            else
            {
                <!-- AI Assistant Section -->
                 <div class="assistant-body">
                    @if (isLoading)
                    {
                        <div class="assistant-loading animate-pulse">
                            <div class="skeleton h-8 w-1/3 skeleton-row"></div>
                            <div class="skeleton h-36 w-full skeleton-row"></div>
                            <div class="skeleton h-10 w-full skeleton-row"></div>
                        </div>
                    }                            
                    else if (currentView == "generate")
                    {
                        <!-- Option 1: Generate Email -->
                        <div class="assistant-view flex flex-col gap-4">
                            <div class="flex justify-between items-center">
                                <h3 class="text-sm font-bold text-white">@L["Assistant.Option.Generate.Title"]</h3>
                                <button type="button" @onclick="GoBackToOptions" class="btn-nav-back">
                                    <i class="ti ti-chevron-left"></i> @L["Home.Assistant.Button.Back"]
                                </button>
                            </div>
                            <div class="flex flex-col gap-3">
                                <fieldset class="fieldset p-0">
                                    <legend class="fieldset-legend text-xs font-bold uppercase tracking-wider text-slate-300">@L["Assistant.Prompt.Label"]</legend>
                                    <textarea id="txtGenerateEmailPrompt" @bind="promptInput" class="textarea textarea-sm w-full bg-[#031810] border-slate-700/60 text-slate-200 focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 resize-none h-[90px]" placeholder="@L["Assistant.Prompt.Placeholder"]"></textarea>
                                </fieldset>
                                
                                <div class="flex flex-wrap gap-1.5 my-1">
                                    @foreach (var preset in EmailPresets)
                                    {
                                        <button type="button" @onclick="() => SelectPreset(preset)" class="btn btn-xs rounded-full border border-slate-700 bg-[#02100c] text-slate-400 hover:text-emerald-400 hover:border-emerald-500/50 transition-colors cursor-pointer @(selectedPresetKey == preset.Key ? "border-emerald-500/70 text-emerald-400" : "")">
                                            @preset.Label
                                        </button>
                                    }
                                </div>
                                <button type="button" @onclick="TriggerPromptGeneration" class="btn btn-sm btn-success text-slate-900 font-bold border-0 bg-gradient-to-r from-emerald-400 to-lime-400 hover:brightness-110 shadow-lg cursor-pointer">
                                    @L["Assistant.Button.Generate"]
                                </button>
                                @if (!string.IsNullOrWhiteSpace(generatedEmail))
                                {
                                    <div class="p-3 text-xs bg-[#031810] border border-emerald-500/30 rounded-xl text-slate-300">
                                        @L["Home.Composer.Status.DraftIsDone"]
                                    </div>
                                }
 
                            </div>
                        </div>
                    }                    
                    else if (currentView == "refine")
                    {   
                        <!-- Option 2: Refine My Email -->
                        <div class="assistant-view flex flex-col gap-4"> 
                                <div class="flex justify-between items-center">
                                    <h3 class="text-sm font-bold text-white">@L["Assistant.Option.Refine.Title"]</h3>
                                    <button type="button" @onclick="GoBackToOptions" class="btn-nav-back">
                                        <i class="ti ti-chevron-left"></i> @L["Home.Assistant.Button.Back"]
                                    </button>
                                </div>
                                @if (string.IsNullOrWhiteSpace(EmailDraft.Message))
                                {
                                    <div class="empty-state-box">
                                        <div>
                                            <h4 class="empty-state-title">@L["Home.Assistant.EmptyDraft.Title"]</h4>
                                            <p class="empty-state-desc">@L["Home.Assistant.EmptyDraft.Body"]</p>
                                        </div>
                                        <div class="grid gap-2 sm:grid-cols-2">
                                            <button type="button" @onclick='() => SelectOption("generate")' class="btn btn-sm btn-success border-0 text-slate-900 bg-gradient-to-r from-emerald-400 to-lime-400 hover:brightness-110 shadow-lg cursor-pointer">
                                                @L["Home.Assistant.Button.CreateDraftFirst"]
                                            </button>
                                            <button type="button" @onclick="UseSampleDraftForRefinement" class="btn btn-sm btn-outline border-emerald-500/50 text-emerald-400 hover:bg-emerald-500/10 cursor-pointer">
                                                @L["Home.Assistant.Button.UseSampleDraft"]
                                            </button>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <div class="flex flex-col gap-3">
                                        <fieldset class="fieldset p-0">
                                            <legend class="fieldset-legend text-xs font-bold uppercase tracking-wider text-slate-300">@L["Assistant.Prompt.Label"]</legend>
                                            <textarea id="txtRefineEmailPrompt" @bind="refineInstruction" class="textarea textarea-sm w-full bg-[#031810] border-slate-700/60 text-slate-200 focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 resize-none h-[90px]" placeholder="@L["Assistant.Prompt.Placeholder"]"></textarea>
                                        </fieldset>
                                        
                                        <div class="flex flex-wrap gap-1.5 my-1">
                                            <button type="button" @onclick='() => SetRefineInstruction("Make it clearer, polite, and professional.")' class="btn btn-xs rounded-full border border-slate-700 bg-[#02100c] text-slate-400 hover:text-emerald-400 hover:border-emerald-500/50 cursor-pointer">Professional</button>
                                            <button type="button" @onclick='() => SetRefineInstruction("Make it shorter and easier to read.")' class="btn btn-xs rounded-full border border-slate-700 bg-[#02100c] text-slate-400 hover:text-emerald-400 hover:border-emerald-500/50 cursor-pointer">Shorter</button>
                                            <button type="button" @onclick='() => SetRefineInstruction("Make it friendlier and fix grammar mistakes.")' class="btn btn-xs rounded-full border border-slate-700 bg-[#02100c] text-slate-400 hover:text-emerald-400 hover:border-emerald-500/50 cursor-pointer">Friendly</button>
                                        </div>
                                        
                                        <button type="button" @onclick="TriggerDraftRefinement" class="btn btn-sm btn-success text-slate-900 font-bold border-0 bg-gradient-to-r from-emerald-400 to-lime-400 hover:brightness-110 shadow-lg cursor-pointer">
                                            @L["Assistant.Option.Refine.Button"]
                                        </button>
                                        @if (!string.IsNullOrWhiteSpace(refinedEmail))
                                        {
                                            <div class="grid gap-2 lg:grid-cols-2">
                                                <fieldset class="fieldset p-0">
                                                    <legend class="fieldset-legend text-xs font-bold uppercase tracking-wider text-slate-400">@L["Assistant.Option.Refine.Original"]</legend>
                                                    <textarea readonly class="textarea textarea-sm w-full bg-[#031810] border-slate-800 text-slate-400 resize-none h-[220px]" rows="12">@refineOriginal</textarea>
                                                </fieldset>
                                                <fieldset class="fieldset p-0">
                                                    <legend class="fieldset-legend text-xs font-bold uppercase tracking-wider text-slate-300">@L["Assistant.Option.Refine.Improved"]</legend>
                                                    <textarea @bind="refinedEmail" class="textarea textarea-sm w-full bg-[#031810] border-slate-700/60 text-slate-200 focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 resize-none h-[220px]" rows="12"></textarea>
                                                </fieldset>
                                            </div>
                                            <button type="button" @onclick="ApplyRefinedEmail" class="btn btn-sm btn-outline border-emerald-500/50 text-emerald-400 hover:bg-emerald-500/10 cursor-pointer">
                                                @L["Assistant.Button.UseImprovedVersion"]
                                            </button>
                                        }
                                    </div>
                                }
                        </div>
                    }                    
                    else if (currentView == "professional") 
                    {   
                        <!-- Option 3: Professional Upgrade -->
                        <div class="assistant-view flex flex-col gap-4">
                            <div class="flex justify-between items-center">
                                <h3 class="text-sm font-bold text-white">@L["Assistant.Option.Professional.Title"]</h3>
                                <button type="button" @onclick="GoBackToOptions" class="btn-nav-back">
                                    <i class="ti ti-chevron-left"></i> @L["Home.Assistant.Button.Back"]
                                </button>
                            </div> 
                            <div class="flex flex-col gap-3">
                                <fieldset class="fieldset p-0">
                                    <legend class="fieldset-legend text-xs font-bold uppercase tracking-wider text-slate-300">@L["Assistant.Option.Professional.Purpose"]</legend>
                                    <textarea id="txtGenerateProfessionalEmailPrompt" @bind="professionalPurpose" class="textarea textarea-sm w-full bg-[#031810] border-slate-700/60 text-slate-200 focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 resize-none h-[65px]" rows="2" placeholder="What do you want the email to do?"></textarea>
                                </fieldset>
 
                                <fieldset class="fieldset p-0">
                                    <legend class="fieldset-legend text-xs font-bold uppercase tracking-wider text-slate-300">@L["Assistant.Option.Professional.Audience"]</legend>
                                    <input @bind="professionalAudience" class="input input-sm w-full bg-[#031810] border-slate-700/60 text-slate-200 focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500" placeholder="Teacher, manager, client, colleague..." />
                                </fieldset>
 
                                <fieldset class="fieldset p-0">
                                    <legend class="fieldset-legend text-xs font-bold uppercase tracking-wider text-slate-300">@L["Assistant.Tone.Select"]</legend>
                                    <div class="flex gap-2">
                                        <button type="button" @onclick='() => SetTone("Formal")' class="btn btn-xs rounded-lg border border-slate-700 bg-[#02100c] text-slate-400 hover:text-emerald-400 hover:border-emerald-500/50 cursor-pointer @(selectedTone == "Formal" ? "border-emerald-500/70 text-emerald-400 bg-emerald-500/5" : "")">
                                            💼 Formal
                                        </button>
                                        <button type="button" @onclick='() => SetTone("Polite")' class="btn btn-xs rounded-lg border border-slate-700 bg-[#02100c] text-slate-400 hover:text-emerald-400 hover:border-emerald-500/50 cursor-pointer @(selectedTone == "Polite" ? "border-emerald-500/70 text-emerald-400 bg-emerald-500/5" : "")">
                                            🤝 Polite
                                        </button>
                                        <button type="button" @onclick='() => SetTone("Persuasive")' class="btn btn-xs rounded-lg border border-slate-700 bg-[#02100c] text-slate-400 hover:text-emerald-400 hover:border-emerald-500/50 cursor-pointer @(selectedTone == "Persuasive" ? "border-emerald-500/70 text-emerald-400 bg-emerald-500/5" : "")">
                                            📣 Persuasive
                                        </button>
                                    </div>
                                </fieldset>
 
                                <fieldset class="fieldset p-0">
                                    <legend class="fieldset-legend text-xs font-bold uppercase tracking-wider text-slate-300">@L["Assistant.Option.Professional.Context"]</legend>
                                    <textarea @bind="professionalContext" class="textarea textarea-sm w-full bg-[#031810] border-slate-700/60 text-slate-200 focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 resize-none h-[75px]" rows="3" placeholder="Add any details, deadline, or reason..."></textarea>
                                </fieldset>
 
                                <button type="button" @onclick="TriggerProfessionalUpgrade" class="btn btn-sm btn-success text-slate-900 font-bold border-0 bg-gradient-to-r from-emerald-400 to-lime-400 hover:brightness-110 shadow-lg cursor-pointer">
                                        @L["Assistant.Button.Generate"]
                                </button>
                                @if (!string.IsNullOrWhiteSpace(professionalOutputText))
                                {
                                    <fieldset class="fieldset p-0">
                                        <legend class="fieldset-legend text-xs font-bold uppercase tracking-wider text-slate-300">@L["Assistant.Option.Professional.GeneratedEmail"]</legend>
                                        <textarea readonly class="textarea textarea-sm w-full bg-[#031810] border-slate-800 text-slate-400 resize-none h-[220px]" rows="14">@professionalOutputText</textarea>
                                    </fieldset>
                                    <button type="button" @onclick="ApplyProfessionalOutput" class="btn btn-sm btn-success border-0 text-slate-900 bg-gradient-to-r from-emerald-400 to-lime-400 hover:brightness-110 shadow-lg cursor-pointer">
                                        @L["Assistant.Button.UseThisVersion"]
                                    </button>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </section>

    <SiteFooter />


    @if (_showToast)
    {
        <div class="composer-toast @(_toastIsError ? "toast-error" : "toast-success")" role="status" aria-live="polite">
            <span class="toast-icon">@(_toastIsError ? "✕" : "✓")</span>
            <span class="toast-msg">@_toastMessage</span>
        </div>
    }
</main>


        */
    }

    private async Task TriggerProfessionalUpgrade()
    {
        isLoading = true;
        StateHasChanged();

        var prompt = BuildProfessionalPrompt();
        var result = await EmailAssistant.UpgradeEmailAsync(prompt, selectedTone);
        professionalOutputText = result.Content;
        EmailDraft = EmailDraft with { StatusMessage = string.Empty };

        await ShowToast(FormatAssistantStatus(result, "Upgraded"));
        isLoading = false;
    }

    private static string FormatAssistantStatus(EmailAssistantResult result, string action)
    {
        if (result.UsedLiveModel)
        {
            return $"{action} with {result.ModelName}.";
        }

        return string.IsNullOrWhiteSpace(result.FallbackReason)
            ? $"{action} with demo fallback."
            : $"{action} with demo fallback. {result.FallbackReason}";
    }

    private async Task ApplyRefinedEmail()
    {
        EmailDraft = EmailDraft with { Message = refinedEmail, StatusMessage = string.Empty };
        await ShowToast(L["Toast.Applied"]);
    }

    private async Task ApplyProfessionalOutput()
    {
        EmailDraft = EmailDraft with { Message = professionalOutputText, StatusMessage = string.Empty };
        await ShowToast(L["Toast.Applied"]);
    }

    private string BuildProfessionalPrompt()
    {
        var parts = new List<string>
        {
            $"Purpose: {professionalPurpose}",
            $"Audience: {professionalAudience}",
            $"Tone: {selectedTone}"
        };

        if (!string.IsNullOrWhiteSpace(professionalContext))
        {
            parts.Add($"Context: {professionalContext}");
        }

        parts.Add("Write the full email with a subject line and a professional closing. Return only the email content.");
        return string.Join("\n", parts);
    }

    private static string BuildMessage(EmailPreview preview) =>
        string.Join("\n\n", preview.Paragraphs)
        + "\n\n"
        + string.Join("\n", preview.Bullets.Select(item => $"- {item}"))
        + "\n\n"
        + preview.Closing
        + "\n"
        + preview.Signature.Replace("\n", Environment.NewLine);


    // ------------------------------------------------------------------------------------------------------
    // GUIDE STRIP --- computed property
    // This is the core fix for the auto-hide bug.
    // Blazor evaluates this on every render so it is
    // always accurate with zero timers or async races.
    //
    //  selFw != null  --- ALWAYS show (locked visible so user can change/clear)
    //  selFw == null  --- hide only when user has typed something into the box
    //                   (strip would cover the input area on small screens)
    // ------------------------------------------------------------------------------------------------------
    private bool GuideStripHidden => selFw == null && userInput.Trim().Length > 0;

    // ------------------------------------------------------------------------------------------------------
    // INIT
    // ------------------------------------------------------------------------------------------------------
    protected override void OnInitialized()
    {
        var builder = new MarkdownPipelineBuilder()
            .UseAdvancedExtensions()
            .DisableHtml();

        builder.BlockParsers.RemoveAll(x => x is IndentedCodeBlockParser);
        _mdPipeline = builder.Build();
    }

    // ------------------------------------------------------------------------------------------------------
    // HELPERS
    // ------------------------------------------------------------------------------------------------------
    private IEnumerable<(FrameworkItem fw, int idx)> GetCurrentFrameworks()
        => (FW.TryGetValue(level, out var list) ? list : new List<FrameworkItem>())
           .Select((fw, i) => (fw, i));

    private string RenderMarkdown(string markdown)
    {
        if (string.IsNullOrWhiteSpace(markdown)) return string.Empty;
        
        // Clean up common "LLM stutter" patterns at the end of the text
        var cleaned = markdown.TrimEnd();
        if (cleaned.EndsWith("*.. ..") || cleaned.EndsWith("*..") || cleaned.EndsWith(".. .."))
        {
            cleaned = cleaned.Substring(0, cleaned.LastIndexOf('*')).TrimEnd();
        }

        cleaned = PromoteSoftParagraphBreaks(cleaned);
        var normalized = NormalizeCodeBlocks(cleaned);
        var prepared = ExtractCodeBlocks(normalized, out var codeBlocks);

        var html = Markdown.ToHtml(prepared, _mdPipeline);
        return InjectCodeBlocks(html, codeBlocks);
    }

    private static string InjectCodeBlocks(string html, IReadOnlyList<CodeBlock> codeBlocks)
    {
        if (codeBlocks.Count == 0)
        {
            return html;
        }

        var output = html;
        for (var i = 0; i < codeBlocks.Count; i++)
        {
            var token = $"[[[CODE_BLOCK_{i}]]]";
            output = output.Replace(token, BuildCodeBlockHtml(codeBlocks[i]));
        }

        return output;
    }

    private static string BuildCodeBlockHtml(CodeBlock block)
    {
        var languageClass = string.IsNullOrWhiteSpace(block.Language)
            ? string.Empty
            : $" language-{WebUtility.HtmlEncode(block.Language)}";

        return $"""
                <pre class="ai-code{languageClass}"><code>{WebUtility.HtmlEncode(block.Content)}</code></pre>
                """;
    }

    private static string ExtractCodeBlocks(string markdown, out List<CodeBlock> codeBlocks)
    {
        codeBlocks = new List<CodeBlock>();

        if (string.IsNullOrWhiteSpace(markdown))
        {
            return markdown;
        }

        var lines = markdown.Replace("\r\n", "\n").Replace('\r', '\n').Split('\n');
        var output = new List<string>(lines.Length);
        var inFence = false;
        var fenceLanguage = string.Empty;
        var codeLines = new List<string>();

        foreach (var rawLine in lines)
        {
            var line = rawLine.TrimEnd();
            var trimmed = line.TrimStart();

            if (!inFence && trimmed.StartsWith("```", StringComparison.Ordinal))
            {
                inFence = true;
                fenceLanguage = trimmed[3..].Trim();
                codeLines.Clear();
                continue;
            }

            if (inFence && trimmed.StartsWith("```", StringComparison.Ordinal))
            {
                output.Add($"[[[CODE_BLOCK_{codeBlocks.Count}]]]");
                codeBlocks.Add(new CodeBlock(fenceLanguage, string.Join('\n', codeLines)));
                inFence = false;
                fenceLanguage = string.Empty;
                codeLines.Clear();
                continue;
            }

            if (inFence)
            {
                codeLines.Add(line);
                continue;
            }

            output.Add(line);
        }

        if (inFence)
        {
            output.Add($"[[[CODE_BLOCK_{codeBlocks.Count}]]]");
            codeBlocks.Add(new CodeBlock(fenceLanguage, string.Join('\n', codeLines)));
        }

        return string.Join('\n', output);
    }

    private static string NormalizeCodeBlocks(string markdown)
    {
        if (string.IsNullOrWhiteSpace(markdown))
        {
            return markdown;
        }

        var lines = markdown.Replace("\r\n", "\n").Replace('\r', '\n').Split('\n');
        var normalized = new List<string>(lines.Length + 8);
        var inFence = false;
        var inInferredCode = false;

        foreach (var rawLine in lines)
        {
            var line = rawLine.TrimEnd();
            var trimmed = line.TrimStart();

            if (trimmed.StartsWith("```", StringComparison.Ordinal))
            {
                if (inInferredCode)
                {
                    normalized.Add("```");
                    inInferredCode = false;
                }

                inFence = !inFence;
                normalized.Add(line);
                continue;
            }

            if (inFence)
            {
                normalized.Add(line);
                continue;
            }

            if (inInferredCode)
            {
                if (ShouldEndInferredCode(trimmed))
                {
                    normalized.Add("```");
                    normalized.Add(string.Empty);
                    inInferredCode = false;
                }
                else
                {
                    normalized.Add(line);
                    continue;
                }
            }

            if (StartsUnfencedCode(trimmed))
            {
                normalized.Add("```razor");
                normalized.Add(line);
                inInferredCode = true;
                continue;
            }

            normalized.Add(line);
        }

        if (inInferredCode)
        {
            normalized.Add("```");
        }

        return string.Join('\n', normalized);
    }

    private static bool StartsUnfencedCode(string line)
        => !string.IsNullOrWhiteSpace(line) &&
           (line.StartsWith('@') ||
            line.StartsWith('<') ||
            line.StartsWith('{') ||
            line.StartsWith('}') ||
            line.StartsWith("using ", StringComparison.Ordinal) ||
            line.StartsWith("namespace ", StringComparison.Ordinal) ||
            line.StartsWith("public ", StringComparison.Ordinal) ||
            line.StartsWith("private ", StringComparison.Ordinal) ||
            line.StartsWith("protected ", StringComparison.Ordinal) ||
            line.StartsWith("internal ", StringComparison.Ordinal) ||
            line.StartsWith("var ", StringComparison.Ordinal) ||
            line.StartsWith("const ", StringComparison.Ordinal) ||
            line.StartsWith("await ", StringComparison.Ordinal) ||
            line.StartsWith("if ", StringComparison.Ordinal) ||
            line.StartsWith("if(", StringComparison.Ordinal) ||
            line.Contains("=>", StringComparison.Ordinal) ||
            line.Contains(" = new", StringComparison.Ordinal) ||
            line.Contains(");", StringComparison.Ordinal));

    private static bool ShouldEndInferredCode(string line)
        => string.IsNullOrWhiteSpace(line) ||
           line.StartsWith("Explanation", StringComparison.OrdinalIgnoreCase) ||
           line.StartsWith("Important Note", StringComparison.OrdinalIgnoreCase) ||
           line.StartsWith("Note:", StringComparison.OrdinalIgnoreCase) ||
           (line.Length > 3 && char.IsDigit(line[0]) && line[1] == '.' && line[2] == ' ');

    private static string PromoteSoftParagraphBreaks(string markdown)
    {
        if (string.IsNullOrWhiteSpace(markdown) || markdown.Contains("\n\n", StringComparison.Ordinal))
        {
            return markdown;
        }

        var lines = markdown.Replace("\r\n", "\n").Replace('\r', '\n').Split('\n');
        if (lines.Length < 2)
        {
            return markdown;
        }

        var hasMarkdownStructure = lines.Any(line =>
        {
            var trimmed = line.TrimStart();
            return trimmed.StartsWith("#", StringComparison.Ordinal) ||
                   trimmed.StartsWith("-", StringComparison.Ordinal) ||
                   trimmed.StartsWith("*", StringComparison.Ordinal) ||
                   trimmed.StartsWith("```", StringComparison.Ordinal) ||
                   trimmed.StartsWith(">", StringComparison.Ordinal) ||
                   (trimmed.Length > 1 && char.IsDigit(trimmed[0]) && trimmed[1] == '.');
        });

        if (hasMarkdownStructure)
        {
            return markdown;
        }

        return string.Join("\n\n", lines.Select(line => line.TrimEnd()));
    }

    private sealed record CodeBlock(string Language, string Content);

    // ------------------------------------------------------------------------------------------------------
    // LEVEL & FRAMEWORK SELECTION
    // ------------------------------------------------------------------------------------------------------
    private void SetLevel(int lv)
    {
        level = lv;

        if (desktopLevelsGlow || mobileLevelsGlow)
        {
            desktopLevelsGlow = false;
            mobileLevelsGlow = false;
            step2Nudge = true;
        }
    }

    private void PickFw(int i)
    {
        if (!FW.TryGetValue(level, out var list) || i >= list.Count) return;
        selFw = list[i];
        userInput = selFw.Tpl;
        QueuePromptResize();
        // GuideStripHidden will re-evaluate automatically on next render
        // and will return FALSE because selFw != null --- no manual call needed
    }

    private void PickFwMob(int i)
    {
        PickFw(i);
        fwSheetOpen = false;
    }

    // ------------------------------------------------------------------------------------------------------
    // GUIDE STRIP ACTIONS
    // ------------------------------------------------------------------------------------------------------
    private void OpenFwSheet() => fwSheetOpen = true;
    private void CloseFwSheet() => fwSheetOpen = false;

    private async Task StartStep1Guide()
    {
        step2Nudge = false;

        var isMobile = await JS.InvokeAsync<bool>("isMobileView");
        if (isMobile)
        {
            fwSheetOpen = true;
            mobileLevelsGlow = true;
            desktopLevelsGlow = false;
        }
        else
        {
            desktopLevelsGlow = true;
            mobileLevelsGlow = false;
        }
        
        StateHasChanged();
    }

    // --- button: clear the selected style, keep the prompt text
    private void ClearStyle() => selFw = null;

    // ------------------------------------------------------------------------------------------------------
    // NAV DRAWER
    // ------------------------------------------------------------------------------------------------------
    private void OpenNav() => navOpen = true;
    private void CloseNav() => navOpen = false;

    // ------------------------------------------------------------------------------------------------------
    // SUBMIT
    // ------------------------------------------------------------------------------------------------------
    private async Task OnSubmit() => await AskAI();

    private Task OnPromptChangedAsync()
    {
        QueuePromptResize();
        return Task.CompletedTask;
    }

    private void QueuePromptResize() => promptResizeNeeded = true;

    // ------------------------------------------------------------------------------------------------------
    // AI --- STREAMING
    // ------------------------------------------------------------------------------------------------------
    private async Task AskAI()
    {
        if (string.IsNullOrWhiteSpace(userInput) || isLoading || isRefining) return;
        if (userInput.Length > MaxPromptLength)
        {
            messages.Add(new Message
            {
                Text = $"Prompt is too long. Please keep it under {MaxPromptLength} characters.",
                Html = $"<p style='color:var(--rose)'>Prompt is too long. Please keep it under {MaxPromptLength} characters.</p>",
                IsUser = false
            });
            return;
        }

        messages.Add(new Message { Text = userInput, IsUser = true });
        currentPrompt = userInput;
        userInput = "";
        selFw = null;
        isLoading = true;
        streamingText = "";
        streamingHtml = "";
        streamStatuses.Clear();
        StateHasChanged();

        try
        {
            _cts.Cancel();
            _cts = new CancellationTokenSource();

            await foreach (var chunk in Gemini.AskStreamAsync(currentPrompt, usageKey, _cts.Token))
            {
                if (_cts.Token.IsCancellationRequested) break;
                if (TryReadStreamStatus(chunk, out var status))
                {
                    streamStatuses.Add(status);
                    StateHasChanged();
                    await JS.InvokeVoidAsync("scrollToBottom", documentContainer);
                    continue;
                }

                streamingText += chunk;
                streamingHtml = RenderMarkdown(streamingText);
                StateHasChanged();
                await JS.InvokeVoidAsync("scrollToBottom", documentContainer);
            }

            var finalHtml = RenderMarkdown(streamingText);
            messages.Add(new Message
            {
                Text = streamingText,
                Html = finalHtml,
                IsUser = false
            });
        }
        catch (OperationCanceledException) { /* user navigated away */ }
        catch (Exception ex)
        {
            messages.Add(new Message
            {
                Text = $"--- Error: {ex.Message}",
                Html = $"<p style='color:var(--rose)'>--- {ex.Message}</p>",
                IsUser = false
            });
        }
        finally
        {
            streamingText = "";
            streamingHtml = "";
            streamStatuses.Clear();
            currentPrompt = "";
            isLoading = false;
            StateHasChanged();
            await JS.InvokeVoidAsync("scrollToBottom", documentContainer);
        }
    }

    // ------------------------------------------------------------------------------------------------------
    // REFINE PROMPT
    // ------------------------------------------------------------------------------------------------------
    private async Task RefinePrompt()
    {
        if (string.IsNullOrWhiteSpace(userInput) || isRefining || isLoading) return;
        if (userInput.Length > MaxPromptLength) return;
        isRefining = true;
        StateHasChanged();
        try
        {
            var refined = await Gemini.RefinePromptAsync(userInput, usageKey, _cts.Token);
            userInput = refined;
            QueuePromptResize();
        }
        catch { /* silent --- user keeps their original text */ }
        finally
        {
            isRefining = false;
            StateHasChanged();
        }
    }

    // ------------------------------------------------------------------------------------------------------
    // TRANSLATE
    // ------------------------------------------------------------------------------------------------------
    private async Task ChangeLanguage(Message msg, string newLanguage)
    {
        if (string.IsNullOrEmpty(newLanguage) || string.IsNullOrEmpty(msg.Text)) return;
        msg.TargetLanguage = newLanguage;
        msg.IsTranslating = true;
        StateHasChanged();
        try
        {
            var lines = msg.Text.Split('\n').ToList();
            lines.RemoveAll(l => l.Trim().StartsWith("*Attempting ") || l.Trim().StartsWith("*(Connected to "));
            var textToTranslate = string.Join("\n", lines).Trim();

            var translated = await Gemini.TranslatePromptAsync(textToTranslate, newLanguage, usageKey, _cts.Token);
            msg.Text = translated;
            msg.Html = RenderMarkdown(translated);
        }
        catch { }
        finally
        {
            msg.IsTranslating = false;
            msg.TargetLanguage = "";
            StateHasChanged();
        }
    }

    // ------------------------------------------------------------------------------------------------------
    // COPY / SHARE
    // ------------------------------------------------------------------------------------------------------
    private async Task CopyToClipboard(Message msg)
    {
        if (string.IsNullOrEmpty(msg.Text)) return;
        await JS.InvokeVoidAsync("copyTextToClipboard", msg.Text);
        msg.DidCopy = true;
        StateHasChanged();
        await Task.Delay(2000);
        msg.DidCopy = false;
        StateHasChanged();
    }

    private async Task ShareContent(Message msg)
    {
        if (string.IsNullOrEmpty(msg.Text)) return;
        await JS.InvokeVoidAsync("shareContentNative", msg.Text);
    }

    // ------------------------------------------------------------------------------------------------------
    // NEW SESSION
    // ------------------------------------------------------------------------------------------------------
    private void NewSession()
    {
        messages.Clear();
        userInput = "";
        selFw = null;
        streamingText = "";
        streamingHtml = "";
        streamStatuses.Clear();
        QueuePromptResize();
    }

    private static bool TryReadStreamStatus(string chunk, out string status)
    {
        const string prefix = "__DINO_STATUS__:";
        if (chunk.StartsWith(prefix, StringComparison.Ordinal))
        {
            status = chunk[prefix.Length..].Trim();
            return true;
        }

        status = string.Empty;
        return false;
    }

    // ------------------------------------------------------------------------------------------------------
    // LIFECYCLE
    // ------------------------------------------------------------------------------------------------------
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!isLoading && messages.Count > 0)
            await JS.InvokeVoidAsync("highlightCode");

        if (promptResizeNeeded)
        {
            promptResizeNeeded = false;
            await JS.InvokeVoidAsync("syncPromptEditors");
        }
    }

    public void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
    }


    </div>
    <button class="mob-send"
            @onclick="OnSubmit"
            disabled="@(isLoading || isRefining || string.IsNullOrWhiteSpace(userInput) || userInput.Length > MaxPromptLength)">
        <i class="ti ti-rocket"></i>
    </button>
</div>


@* ══ FRAMEWORK SHEET ══ *@

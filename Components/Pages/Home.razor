@page "/"
@inject GeminiService Gemini
@using Microsoft.AspNetCore.Components.Web

<h3 class="mb-3">AI Assistant 🤖</h3>

<div class="chat-container">

    @foreach (var msg in messages)
    {
        <div class="chat-bubble @(msg.IsUser ? "user" : "ai")">
            <b>@(msg.IsUser ? "You" : "AI"):</b>
            <div>@msg.Text</div>
        </div>
    }

</div>

<div class="input-area mt-3">
    <form @onsubmit="OnSubmit" @onsubmit:preventDefault>
    <input class="form-control"
           @bind="userInput"
           placeholder="Ask anything..." />

        <button id="sendButton" type="submit" class="btn btn-primary mt-2"
            disabled="@isLoading">
        @(isLoading ? "Thinking..." : "Send")
    </button>
    </form>
</div>

@code {
    private string? userInput;
    private bool isLoading = false;

    private List<Message> messages = new();

    private async Task AskAI()
    {
        if (string.IsNullOrWhiteSpace(userInput))
            return;

        // Add user message
        messages.Add(new Message
        {
            Text = userInput,
            IsUser = true
        });

        var prompt = userInput;
        userInput = "";
        isLoading = true;

        StateHasChanged();


        // Call AI
        try
        {
            var aiResponse = await Gemini.AskAsync(prompt);
            // Add AI response
            messages.Add(new Message
            {
                Text = aiResponse,
                IsUser = false
            });
        }
        catch (Exception ex)
        {
            messages.Add(new Message
            {
                Text = $"❌ Error: {ex.Message}",
                IsUser = false
            });
        }

        isLoading = false;
    }

    private async Task OnSubmit()
    {
            await AskAI();
        }

    class Message
    {
        public string? Text { get; set; }
        public bool IsUser { get; set; }
        public DateTime Time { get; set; } = DateTime.Now;
    }

}
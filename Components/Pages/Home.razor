@page "/"

<PageTitle>@T["Site.Title"]</PageTitle>

<main class="home-page">
    @* Debug info removed. Keep localization middleware and resources intact. *@
    <section class="hero-shell">
        <SiteNav />

        <div class="hero-grid">
            <div class="hero-copy">

                <h1>@T["Don't just use AI."]<br />@T["Evolve with it."]</h1>
                <p class="lead">
                    @T["Home.Hero.Lead"]
                </p>

                <div class="benefits">
                    @foreach (var item in BenefitItems)
                    {
                        <div class="benefit">
                            <span class="benefit-icon">@((MarkupString)item.Icon)</span>
                            <span>@T[item.Label]</span>
                        </div>
                    }
                </div>

                <div class="hero-actions">
                    <a href="/membership" class="btn btn-cta">@T["Home.Hero.StartCta"] <i class="ti ti-chevron-right"></i></a>
                </div>
            </div>

            <div class="hero-visual" aria-hidden="true">
                <img alt="" class="hero-mascot" src="@Assets["assets/dino_mascot.png"]" />
            </div>
        </div>
    </section>

    <section class="showcase-shell">
            <div class="showcase-panel workbench">
            <div class="panel-title">
                <i class="ti ti-mail-fast"></i>
                <span>@T["Home.Composer.Title"]</span>
            </div>

            <EditForm Model="@EmailDraft" class="composer-card">
                <div class="composer-form">
                    <div class="email-fields">
                        <label class="email-field">
                            <span class="email-label">@T["Home.Composer.Label.To"]</span>
                            <input @bind="EmailDraft.To" class="email-input" />
                        </label>
                        <label class="email-field">
                            <span class="email-label">@T["Home.Composer.Label.Subject"]</span>
                            <input @bind="EmailDraft.Subject" class="email-input" />
                        </label>
                        <label class="email-field email-field-message">
                            <span class="email-label">@T["Home.Composer.Label.Message"]</span>
                            <textarea @bind="EmailDraft.Message" rows="10" class="email-textarea" placeholder="@T["Home.Composer.Placeholder.Message"]"></textarea>
                        </label>
                    </div>
                </div> 
                <div class="composer-actions">
                    <button type="button" class="mini-btn ghost" @onclick="ClearDraft">@T["Home.Composer.Action.Clear"]</button>
                    <button type="button" class="mini-btn ghost" @onclick="LoadImprovedDraft">@T["Home.Composer.Action.Improve"]</button>
                    <button type="button" class="mini-btn solid" @onclick="HandleSendEmail">@T["Home.Composer.Action.Send"]</button>
                </div>
                @if (!string.IsNullOrWhiteSpace(EmailDraft.StatusMessage))
                {
                    <div class="text-xs text-emerald-400 mt-2 px-1 text-right">
                        @EmailDraft.StatusMessage
                    </div>
                }
            </EditForm>
        </div>

        <div class="showcase-panel assistant flex flex-col h-full">
            <div class="flex items-center justify-between mt-1 mb-0">
                <div class="panel-title">
                    <i class="ti ti-robot text-[#33d7a6] text-lg"></i>
                    <span>@T["Home.Assistant.Title"]</span>
                </div>
                @if (currentView != "options")
                {
                    <button type="button" @onclick="GoBackToOptions" class="px-2.5 py-1 rounded-lg text-slate-400 hover:text-[#33d7a6] hover:bg-[#33d7a6]/10 gap-1 flex items-center transition-all duration-300 text-xs cursor-pointer">
                        <i class="ti ti-chevron-left"></i> @T["Home.Assistant.Button.Back"]
                    </button>
                }
            </div>

            @if (currentView == "options")
            {
                <p class="text-xs text-slate-400 mb-4">@T["Home.Assistant.ChooseAction"]</p>
                <div class="assistant-options">
                    <!-- Option 1: Refine My Email -->
                    <button type="button" @onclick='() => SelectOption("refine")' class="assistant-option assistant-option-refine">
                        <div class="assistant-option-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" width="1.4em" height="1.4em" viewBox="0 0 32 32">
                                <path d="M0 0h32v32H0z" fill="none" />
                                <g fill="none">
                                    <path fill="#433B6B" d="m5 29l-2-2l16-16l2 2z" />
                                    <path fill="#F4F4F4" d="m18 12l2 2l1.674-1.667c.435-.445.435-1.24 0-1.675l-.33-.331C20.9 9.89 20 10 19.5 10.5zM2.338 29.252l.41.41c.44.452 1.17.452 1.61-.01L6 28.007L4 26l-1.662 1.627a1.146 1.146 0 0 0 0 1.625" />
                                    <path fill="#F9C23C" d="M27.87 4.423c.131.284.352.508.644.635l1.215.527a.453.453 0 0 1 0 .83l-1.205.527a1.22 1.22 0 0 0-.643.635l-.954 2.167c-.17.341-.683.341-.854 0l-.954-2.167a1.26 1.26 0 0 0-.643-.635l-1.205-.527a.453.453 0 0 1 0-.83l1.205-.527a1.22 1.22 0 0 0 .643-.635l.954-2.167c.17-.341.683-.341.854 0zm-11.429 1.18a.88.88 0 0 1-.458-.438l-.676-1.49c-.125-.233-.49-.233-.614 0l-.676 1.49a.85.85 0 0 1-.458.438l-.864.36a.309.309 0 0 0 0 .574l.864.36a.9.9 0 0 1 .458.438l.676 1.49c.125.233.49.233.614 0l.676-1.49a.85.85 0 0 1 .458-.438l.864-.36a.309.309 0 0 0 0-.574zm9.51 10.695a.95.95 0 0 1-.46-.48l-.686-1.622c-.128-.261-.492-.261-.61 0l-.685 1.623a.95.95 0 0 1-.46.479l-.857.392c-.257.13-.257.5 0 .62l.856.392a.95.95 0 0 1 .46.48l.686 1.622c.128.261.492.261.61 0l.685-1.622a.95.95 0 0 1 .46-.48l.857-.392c.257-.13.257-.5 0-.62zM12 14a1 1 0 1 0 0-2a1 1 0 0 0 0 2m18-1a1 1 0 1 1-2 0a1 1 0 0 1 2 0M19 4a1 1 0 1 0 0-2a1 1 0 0 0 0 2m1 17a1 1 0 1 1-2 0a1 1 0 0 1 2 0" />
                                </g>
                            </svg>

                        </div>
                        <div class="assistant-option-copy">
                            <h3>@T["Assistant.Option.Refine.Title"]</h3>
                            <p>@T["Assistant.Option.Refine.Description"]</p>
                        </div>
                        <span class="assistant-option-arrow">→</span>
                    </button>

                    <!-- Option 2: Generate from Prompt -->
                    <button type="button" @onclick='() => SelectOption("generate")' class="assistant-option assistant-option-generate">
                        <div class="assistant-option-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 36 36">
                                <path d="M0 0h36v36H0z" fill="none" />
                                <path fill="#ffd983" d="M29 11.06c0 6.439-5 7.439-5 13.44c0 3.098-3.123 3.359-5.5 3.359c-2.053 0-6.586-.779-6.586-3.361C11.914 18.5 7 17.5 7 11.06C7 5.029 12.285.14 18.083.14C23.883.14 29 5.029 29 11.06" />
                                <path fill="#ccd6dd" d="M22.167 32.5c0 .828-2.234 2.5-4.167 2.5s-4.167-1.672-4.167-2.5S16.066 32 18 32s4.167-.328 4.167.5" />
                                <path fill="#ffcc4d" d="M22.707 10.293a1 1 0 0 0-1.414 0L18 13.586l-3.293-3.293a.999.999 0 1 0-1.414 1.414L17 15.414V26a1 1 0 1 0 2 0V15.414l3.707-3.707a1 1 0 0 0 0-1.414" />
                                <path fill="#99aab5" d="M24 31a2 2 0 0 1-2 2h-8a2 2 0 0 1-2-2v-6h12z" />
                                <path fill="#ccd6dd" d="M11.999 32a1 1 0 0 1-.163-1.986l12-2a.994.994 0 0 1 1.15.822a1 1 0 0 1-.822 1.15l-12 2a1 1 0 0 1-.165.014m0-4a1 1 0 0 1-.163-1.986l12-2a.995.995 0 0 1 1.15.822a1 1 0 0 1-.822 1.15l-12 2a1 1 0 0 1-.165.014" />
                            </svg>

                        </div>
                        <div class="assistant-option-copy">
                            <h3>@T["Assistant.Option.Generate.Title"]</h3>
                            <p>@T["Assistant.Option.Generate.Description"]</p>
                        </div>
                        <span class="assistant-option-arrow">→</span>
                    </button>

                    <!-- Option 3: Professional Upgrade -->
                    <button type="button" @onclick='() => SelectOption("professional")' class="assistant-option assistant-option-professional">
                        <div class="assistant-option-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" width="1.2em" height="1.2em" viewBox="0 0 36 36">
                                <path d="M0 0h36v36H0z" fill="none" />
                                <path fill="#f4900c" d="M14.174 17.075L6.75 7.594l-3.722 9.481z" />
                                <path fill="#f4900c" d="m17.938 5.534l-6.563 12.389H24.5z" />
                                <path fill="#f4900c" d="m21.826 17.075l7.424-9.481l3.722 9.481z" />
                                <path fill="#ffcc4d" d="M28.669 15.19L23.887 3.523l-5.88 11.668l-.007.003l-.007-.004l-5.88-11.668L7.331 15.19C4.197 10.833 1.28 8.042 1.28 8.042S3 20.75 3 33h30c0-12.25 1.72-24.958 1.72-24.958s-2.917 2.791-6.051 7.148" />
                                <circle cx="17.957" cy="22" r="3.688" fill="#5c913b" />
                                <circle cx="26.463" cy="22" r="2.412" fill="#981ceb" />
                                <circle cx="32.852" cy="22" r="1.986" fill="#dd2e44" />
                                <circle cx="9.45" cy="22" r="2.412" fill="#981ceb" />
                                <circle cx="3.061" cy="22" r="1.986" fill="#dd2e44" />
                                <path fill="#ffac33" d="M33 34H3a1 1 0 1 1 0-2h30a1 1 0 1 1 0 2m0-3.486H3a1 1 0 1 1 0-2h30a1 1 0 1 1 0 2" />
                                <circle cx="1.447" cy="8.042" r="1.407" fill="#ffcc4d" />
                                <circle cx="6.75" cy="7.594" r="1.192" fill="#f4900c" />
                                <circle cx="12.113" cy="3.523" r="1.784" fill="#ffcc4d" />
                                <circle cx="34.553" cy="8.042" r="1.407" fill="#ffcc4d" />
                                <circle cx="29.25" cy="7.594" r="1.192" fill="#f4900c" />
                                <circle cx="23.887" cy="3.523" r="1.784" fill="#ffcc4d" />
                                <circle cx="17.938" cy="5.534" r="1.784" fill="#f4900c" />
                            </svg>

                        </div>
                        <div class="assistant-option-copy">
                            <h3>@T["Assistant.Option.Professional.Title"]</h3>
                            <p>@T["Assistant.Option.Professional.Description"]</p>
                        </div>
                        <span class="assistant-option-arrow">→</span>
                    </button>
                </div>
            }
            else
            {
                <div class="assistant-view-header"> 
                        <h3>@T[SelectedAssistant.Title]</h3>
                </div>

                <div class="flex-1 flex flex-col">
                    @if (isLoading)
                    {
                        <div class="flex flex-col gap-4 w-full py-4 flex-1 justify-center animate-pulse">
                            <div class="skeleton h-8 w-1/3 bg-[#031810]"></div>
                            <div class="skeleton h-36 w-full bg-[#031810]"></div>
                            <div class="skeleton h-10 w-full bg-[#031810]"></div>
                        </div>
                    }
                    else if (currentView == "refine")
                    {
                        <div class="space-y-4 flex-1 flex flex-col">
                                @if (string.IsNullOrWhiteSpace(EmailDraft.Message))
                            {
                                <div class="p-4 rounded-xl bg-amber-500/5 border border-amber-500/20 text-amber-200 text-xs space-y-2">
                                    <p class="font-semibold">@T["Home.Assistant.EmptyDraft.Title"]</p>
                                    <p>@T["Home.Assistant.EmptyDraft.Body"]</p>
                                    <button type="button" @onclick="LoadSampleDraft" class="w-full py-2 bg-gradient-to-r from-[#f5b722] to-[#f5bb2c] text-[#08110f] font-bold rounded-lg text-xs mt-2 hover:brightness-110 transition-all duration-300 cursor-pointer">
                                        @T["Home.Assistant.Button.UseSampleDraft"]
                                    </button>
                                </div>
                            }
                            else
                            {
                                <div class="flex flex-col flex-1 gap-3">
                                    <p class="text-xs text-slate-400">@T["Home.Assistant.RefinedHeading"]</p>
                                    <textarea @bind="refinedText" class="w-full p-3 bg-[#031810] border border-[rgba(86, 230, 145, 0.22)] rounded-xl text-xs text-slate-100 placeholder-slate-500 focus:outline-none focus:border-[#9be326] focus:ring-1 focus:ring-[#9be326] transition-all duration-300 flex-1 min-h-[180px] resize-none" rows="8"></textarea>
                                    <button type="button" @onclick="TriggerPromptGeneration" class="w-full py-2 rounded-lg bg-gradient-to-r from-[#2dc98e] to-[#80e36b] text-[#08110f] font-bold hover:brightness-110 transition-all duration-300 text-xs flex items-center justify-center gap-1.5 cursor-pointer">
                                        🚀 @T["Home.Assistant.Button.GenerateEmail"]
                                    </button>
                                    <label id="new-email-message1" class="block text-xs font-medium text-slate-300 mb-1.5">@T["Home.Assistant.Label.NewEmailMessage"]</label>
                                    <textarea @bind="refinedEmail" class="w-full p-3 bg-[#031810] border border-[rgba(86, 230, 145, 0.22)] rounded-xl text-xs text-slate-100 focus:outline-none focus:border-[#25d0be] focus:ring-1 focus:ring-[#25d0be] transition-all duration-300 flex-1 min-h-[150px] resize-none" rows="6"></textarea>

                                        <div class="p-3 bg-green-500/5 border border-green-500/20 rounded-xl mt-auto">
                                        <p class="text-xs font-semibold text-green-400 flex items-center gap-1">@T["Home.Assistant.TimeSaved", "8.5 minutes"]</p>
                                        <p class="text-[10px] text-slate-400 mt-0.5">@T["Home.Assistant.TimeSavedYear", "7.1"]</p>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else if (currentView == "generate")
                    {
                        <div class="space-y-4 flex-1 flex flex-col">
                            <div class="space-y-3 flex-1 flex flex-col">
                                <div>
                                    <label class="block text-xs font-medium text-slate-300 mb-1.5">@T["Home.Assistant.Prompt.Label"]</label>
                                    <textarea @bind="promptInput" class="w-full p-3 bg-[#031810] border border-[rgba(86, 230, 145, 0.22)] rounded-xl text-xs text-slate-100 placeholder-slate-500 focus:outline-none focus:border-[#25d0be] focus:ring-1 focus:ring-[#25d0be] transition-all duration-300 resize-none" rows="3" placeholder="Describe what email you want to generate..."></textarea>
                                </div>

                                <div class="flex flex-wrap gap-1.5">
                                    <button type="button" @onclick='() => SetPrompt("Write a professional email requesting a project deadline extension. Keep it concise and polite.")' class="px-2.5 py-1 rounded-full border border-slate-700 text-slate-400 hover:text-[#25d0be] hover:border-[#25d0be]/50 bg-[#02100c] text-[10px] transition-all duration-300 cursor-pointer">
                                        📅 @T["Home.Assistant.Button.Extension"]
                                    </button>
                                    <button type="button" @onclick='() => SetPrompt("Write a warm follow-up email after a project kick-off meeting. Summarize key action items.")' class="px-2.5 py-1 rounded-full border border-slate-700 text-slate-400 hover:text-[#25d0be] hover:border-[#25d0be]/50 bg-[#02100c] text-[10px] transition-all duration-300 cursor-pointer">
                                        🤝 @T["Home.Assistant.Button.FollowUp"]
                                    </button>
                                    <button type="button" @onclick='() => SetPrompt("Write a brief out-of-office auto-reply. I am on vacation until next Monday.")' class="px-2.5 py-1 rounded-full border border-slate-700 text-slate-400 hover:text-[#25d0be] hover:border-[#25d0be]/50 bg-[#02100c] text-[10px] transition-all duration-300 cursor-pointer">
                                        🏝️ @T["Home.Assistant.Button.Vacation"]
                                    </button>
                                </div>

                                <button type="button" @onclick="TriggerPromptGeneration" class="w-full py-2 rounded-lg bg-gradient-to-r from-[#2dc98e] to-[#80e36b] text-[#08110f] font-bold hover:brightness-110 transition-all duration-300 text-xs flex items-center justify-center gap-1.5 cursor-pointer">
                                    🚀 @T["Home.Assistant.Button.GenerateEmail"]
                                </button>
                                        <label id="new-email-message2" class="block text-xs font-medium text-slate-300 mb-1.5">@T["Home.Assistant.NewMessageLabel"]</label>

                                    <div class="space-y-3 flex-1 flex flex-col">
                                        <textarea @bind="generatedEmail" class="w-full p-3 bg-[#031810] border border-[rgba(86, 230, 145, 0.22)] rounded-xl text-xs text-slate-100 focus:outline-none focus:border-[#25d0be] focus:ring-1 focus:ring-[#25d0be] transition-all duration-300 flex-1 min-h-[150px] resize-none" rows="6"></textarea>
                                        <div class="p-3 bg-green-500/5 border border-green-500/20 rounded-xl mt-auto">
                                            <p class="text-xs font-semibold text-green-400 flex items-center gap-1">⏱️ Time Saved: 12 minutes</p>
                                            <p class="text-[10px] text-slate-400 mt-0.5">That's 10 hours per year!</p>
                                        </div>
                                    </div>
 
                            </div>
                        </div>
                    }
                    else if (currentView == "professional")
                    {
                        <div class="space-y-4 flex-1 flex flex-col">
                            <div class="space-y-3 flex-1 flex flex-col">
                                <div>
                                    <label class="block text-xs font-medium text-slate-300 mb-1.5">@T["Home.Assistant.Prompt.Label"]</label>
                                    <textarea @bind="professionalFramework" class="w-full p-3 bg-[#031810] border border-[rgba(86, 230, 145, 0.22)] rounded-xl text-[11px] text-slate-100 placeholder-slate-500 focus:outline-none focus:border-[#f5b722] focus:ring-1 focus:ring-[#f5b722] transition-all duration-300 resize-none font-mono" rows="6"></textarea>
                                </div>

                                <div class="space-y-1.5">
                                    <span class="block text-[11px] font-medium text-slate-400">@T["Home.Assistant.Tone.Select"]</span>
                                    <div class="flex gap-2">
                                        <button type="button" @onclick='() => SetTone("Executive")' class="px-2.5 py-1 rounded-lg text-xs font-semibold transition-all duration-300 flex-1 cursor-pointer @(selectedTone == "Executive" ? "bg-[#f5b722] text-[#08110f]" : "border border-slate-700 text-slate-400 hover:text-[#f5b722] hover:border-[#f5b722]/50 bg-[#02100c]")">
                                            💼 @T["Home.Assistant.Tone.Executive"]
                                        </button>
                                        <button type="button" @onclick='() => SetTone("Diplomatic")' class="px-2.5 py-1 rounded-lg text-xs font-semibold transition-all duration-300 flex-1 cursor-pointer @(selectedTone == "Diplomatic" ? "bg-[#f5b722] text-[#08110f]" : "border border-slate-700 text-slate-400 hover:text-[#f5b722] hover:border-[#f5b722]/50 bg-[#02100c]")">
                                            🤝 @T["Home.Assistant.Tone.Diplomatic"]
                                        </button>
                                        <button type="button" @onclick='() => SetTone("Persuasive")' class="px-2.5 py-1 rounded-lg text-xs font-semibold transition-all duration-300 flex-1 cursor-pointer @(selectedTone == "Persuasive" ? "bg-[#f5b722] text-[#08110f]" : "border border-slate-700 text-slate-400 hover:text-[#f5b722] hover:border-[#f5b722]/50 bg-[#02100c]")">
                                            📣 @T["Home.Assistant.Tone.Persuasive"]
                                        </button>
                                    </div>
                                </div>

                                <button type="button" @onclick="TriggerProfessionalUpgrade" class="w-full py-2 rounded-lg bg-gradient-to-r from-[#2dc98e] to-[#80e36b] text-[#08110f] font-bold hover:brightness-110 transition-all duration-300 text-xs flex items-center justify-center gap-1.5 cursor-pointer">
                                    👑 @T["Home.Assistant.Button.GenerateEmail"]
                                </button>
                                <label class="block text-xs font-medium text-slate-300 mb-1.5">@T["Home.Assistant.NewMessageLabel"]</label>

                                    <div class="space-y-3 flex-1 flex flex-col">
                                        <textarea @bind="professionalOutputText" class="w-full p-3 bg-[#031810] border border-[rgba(86, 230, 145, 0.22)] rounded-xl text-xs text-slate-100 focus:outline-none focus:border-[#f5b722] focus:ring-1 focus:ring-[#f5b722] transition-all duration-300 flex-1 min-h-[150px] resize-none" rows="6"></textarea>
                                        <div id="new-email-message3" class="p-3 bg-green-500/5 border border-green-500/20 rounded-xl mt-auto">
                                            <p class="text-xs font-semibold text-green-400 flex items-center gap-1">⏱️ Time Saved: 15 minutes</p>
                                            <p class="text-[10px] text-slate-400 mt-0.5">That's 12.5 hours per year!</p>
                                        </div>
                                    </div>
                                
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </section>

    <footer class="footer-shell">
        <div class="footer-grid">
            <div class="footer-card" id="release-notes">
                <p class="footer-card-title">@T["Footer.ReleaseNotesTitle"]</p>
                <ul class="footer-list">
                    <li><strong>v2.0.0</strong> - @T["Footer.ReleaseNotes.V2"]</li>
                    <li><a href="/release-notes">@T["Footer.ReleaseNotes.ReadFull"]</a></li>
                </ul>
            </div>
            <div class="footer-card" id="feedback">
                <p class="footer-card-title">@T["Footer.Feedback.Title"]</p>
                <ul class="footer-links">
                    <li><a href="mailto:admin@codingdinos.asia?subject=Dino%20AI%20Academy%20Feedback">@T["Footer.Feedback.Send"]</a></li>
                    <li><a href="mailto:admin@codingdinos.asia?subject=Dino%20AI%20Academy%20Wishlist">@T["Footer.Feedback.Wishlist"]</a></li>
                    <li><a href="#">@T["Footer.Feedback.Roadmap"]</a></li>
                </ul>
            </div>
        </div>

        <div class="footer-bottom">
            <span>@T["Footer.Copyright", DateTime.Now.Year]</span>
            <span>@T["Footer.BuiltWith"]</span>
        </div>
    </footer>
</main>

@code {
    private sealed record AssistantViewSpec(
        string Key,
        string Title,
        string Description,
        string IconMarkup,
        string AccentClass);

    // State variables for interactive AI Assistant
    private string currentView = "options";
    private bool isLoading = false;
    private string refinedText = "";
    private string refinedEmail = "";
    private string promptInput = "Write a professional email requesting a project deadline extension. Keep it concise and polite.";
    private string generatedEmail = "";
 
    private string professionalFramework = "Subject: [Clear, specific subject line]\n\nDear [Recipient Name],\n\n[Opening: State your purpose clearly and professionally]\n\n[Body: Provide context and key details in 2-3 sentences]\n\n[Call to Action: Specify what you need or expect]\n\nBest regards,\n[Your Name]";
    private string professionalOutputText = "";
 
    private string selectedTone = "Executive";

    private static readonly IReadOnlyDictionary<string, AssistantViewSpec> AssistantViews =
        new Dictionary<string, AssistantViewSpec>
        {
            ["refine"] = new AssistantViewSpec(
                "refine",

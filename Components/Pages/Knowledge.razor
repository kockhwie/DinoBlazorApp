@page "/knowledge"
@using DinoAI.Data
@using DinoAI.Services
@using Microsoft.Extensions.Localization
@inject KnowledgeService KnowledgeService
@inject NavigationManager Nav
@inject IStringLocalizer<SharedResource> L

<PageTitle>Dino AI Academy - Knowledge Hub</PageTitle>

<main class="knowledge-page">
    <section class="hero-shell">
        <SiteNav />

        <div class="knowledge-hero text-center py-12 px-6">
            <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-white mb-3">
                @L["Knowledge.Hero.Title"]
            </h1>
            <p class="max-w-2xl mx-auto text-slate-300 text-sm sm:text-base leading-relaxed">
                @L["Knowledge.Hero.Subtitle"]
            </p>
        </div>
    </section>

    <!-- Evolution Progress Bar Section -->
    <section class="progress-bar-shell py-6 px-4">
        <div class="evolution-container max-w-6xl mx-auto">
            <div class="journey-brief mb-0">
                <div>
                    <p class="journey-kicker">@L["Knowledge.Journey.Kicker"]</p>
                    <h2 class="journey-title">@SelectedJourneyTitle</h2>
      
                </div>
                <div class="journey-path" aria-label="Suggested learning path">
                    @foreach (var track in _featuredPath)
                    {
                        <button type="button" class="path-chip" @onclick="() => NavigateToDetail(track.Slug)">
                            @track.Label
                        </button>
                    }
                </div>
            </div>
            
            <div class="evolution-stepper flex flex-col md:flex-row items-stretch justify-between gap-1 md:gap-3">

                @foreach (var age in _ages)
                {
                    var isSelected = _selectedAgeKey == age.Key;
                    <button type="button" @onclick="() => SelectAge(age.Key)"
                            class="evolution-step flex-1 text-left md:text-center transition-all duration-300 @(isSelected ? "active" : "")"
                            style="--step-color: @age.AccentColor">
                        <div class="step-arrow-container">
                            <div class="step-icon-wrap">
                                <i class="@age.Icon text-xl"></i>
                            </div>
                            <div class="step-details">
                                <h3 class="step-title">@AgeName(age)</h3> <!-- age.Name -->
                                <p class="step-subtitle">@AgeSubtitle(age)</p><!-- age.Subtitle -->
                            </div>
                        </div>
                    </button>
                    @if (age.Order < _ages.Count)
                    {
                        <div class="evolution-divider hidden md:flex items-center justify-center"
                                style="--divider-color: @(age.Order < 4 ? "#d97706" : age.Order == 4 ? "#64748b" : "#3b82f6")">
                            <i class="ti ti-arrow-big-right-line"></i>
                        </div>
                    }
                }

            </div>
        </div>
    </section>

    <!-- Filters and Card Grid Section -->
    <section class="showcase-shell py-8">
        <div class="max-w-6xl mx-auto">
            
            <!-- Filter Bar -->
            <div class="filter-bar flex flex-col sm:flex-row items-center justify-between gap-4 mb-4 p-4 bg-[#020e0a]/80 border border-[rgba(58,209,141,0.16)] rounded-2xl">
                <div class="flex flex-wrap items-center gap-2 w-full sm:w-auto">
                    <!-- Reset Button/All Era -->
                    <button type="button" @onclick="ResetFilters" class="px-4 py-2 text-xs font-semibold rounded-xl transition-all duration-300 cursor-pointer @(string.IsNullOrEmpty(_selectedAgeKey) && string.IsNullOrEmpty(_selectedCategory) && string.IsNullOrEmpty(_searchQuery) ? "bg-[#33d7a6] text-[#04110f]" : "bg-[#031810] text-slate-300 border border-slate-700 hover:text-[#33d7a6]")">
                        @L["Knowledge.Filter.AllEras"]
                    </button>

                    <!-- Category Dropdown -->
                    <div class="dropdown relative z-[9999]">
                        <div tabindex="0" role="button" class="btn btn-sm bg-[#031810] border-slate-700 hover:border-[#33d7a6] hover:bg-[#031810] text-xs font-semibold text-slate-300 normal-case rounded-xl h-9">
                            @(string.IsNullOrEmpty(_selectedCategory) ? @L["Knowledge.Filter.CategoryPrefix"] + " " + @L["Knowledge.Filter.AllCategories"] : $"Category: {_selectedCategory}")
                            <i class="ti ti-chevron-down ms-1"></i>
                        </div>
                        <ul tabindex="0" class="dropdown-content absolute top-full left-0 mt-2 z-[9999] menu p-2 shadow-2xl bg-[#02100c] border border-[rgba(58,209,141,0.16)] rounded-box w-52">
                            <li><button type="button" class="text-xs" @onclick="() => FilterByCategory(null)">@L["Knowledge.Filter.CategoryAll"]</button></li>

                            @foreach (var cat in _categories)
                            {
                                <li>
                                    <button type="button" class="text-xs" @onclick="() => FilterByCategory(cat)">
                                        @LocalizeCategory(cat)
                                    </button>
                                </li>
                            }
                        </ul>
                    </div>
                </div>

                <!-- Search Input -->
                <div class="relative w-full sm:w-64">
                    <input type="text" placeholder="@L["Knowledge.Filter.SearchPlaceholder"]" @bind-value="SearchQuery" @bind-value:event="oninput" class="form-input knowledge-search-input" />
                    <span class="search-icon">
                        <i class="ti ti-search text-sm"></i>
                    </span>
                </div>
            </div>



            <!-- Card Grid -->
            @if (_filteredCards.Count == 0)
            {
                <div class="knowledge-empty">
                    <i class="ti ti-search-off text-4xl text-slate-600 mb-3 block"></i>
                    <h3 class="empty-state-title">@L["Knowledge.Empty.Title"]</h3>
                    <p class="empty-state-desc" style="max-width:20rem;margin-inline:auto">@L["Knowledge.Empty.Description"]</p>
                </div>
            }
            else
            {
                <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
                    @foreach (var card in _filteredCards)
                    {
                        var age = _ages.FirstOrDefault(a => a.Key == card.AgeKey);
                        var nextTracks = GetNextTracks(card);
                        <article class="knowledge-card" style="--era-color: @(age?.AccentColor ?? "#33d7a6")">
 
                            <div class="knowledge-card-header">
                                <div class="icon-wrap">
                                    <i class="@card.Icon"></i>
                                </div>
                                <div style="min-width:0">
                                    <div class="knowledge-card-header-meta">
                                        <p class="knowledge-era">@AgeName(age)</p>
                                        <span class="knowledge-category">@LocalizeCategory(card.Category)</span>
                                    </div>
                                    <h3 class="knowledge-card-title">@card.Title</h3>
                                </div>
                            </div>
 

                            <div class="knowledge-card-body">
                                <section class="learning-section learning-definition">
                                    <h4><i class="ti ti-compass"></i> @L["Knowledge.Card.Definition"]</h4>
                                    <p>@GetDefinition(card)</p>
                                </section>

                                <div class="learning-grid">
                                    <section class="learning-section">
                                        <h4><i class="ti ti-bulb"></i> @L["Knowledge.Card.WhyCare"]</h4>
                                        <p>@GetWhyCare(card)</p>
                                    </section>
                                    <section class="learning-section">
                                        <h4><i class="ti ti-map-pin"></i> @L["Knowledge.Card.Example"]</h4>
                                        <p>@GetExample(card)</p>
                                    </section>
                                </div>

                                <section class="learning-section learning-without">
                                    <h4><i class="ti ti-alert-triangle"></i> @L["Knowledge.Card.WithoutIt"]</h4>
                                    <p>@GetWithoutIt(card)</p>
                                </section>
                            </div>

                            <div class="knowledge-card-footer">
                                <div>
                                    <p class="next-label">@L["Knowledge.Card.NextTracks"]</p>
                                    <div class="next-track-list">
                                        @foreach (var next in nextTracks)
                                        {
                                            <button type="button" class="next-track" @onclick="() => NavigateToDetail(next.Slug)">
                                                @next.Label
                                            </button>
                                        }
                                    </div>
                                </div>
                                <button type="button" class="continue-button" @onclick="() => NavigateToDetail(card.Slug)">
                                    @L["Knowledge.Card.ContinueEvolution"] <i class="ti ti-arrow-right"></i>
                                </button>
                            </div>
                        </article>
                    }
                </div>
            }

            <aside class="continue-evolution mt-10">
                <div>
                    <p class="journey-kicker">@L["Knowledge.Journey.Kicker"]</p>
                    <h2>@L["Knowledge.Continue.Title"]</h2>
                    <p>@L["Knowledge.Continue.Body"]</p>
                </div>
                <button type="button" class="continue-button" @onclick='() => NavigateToDetail("what-is-ai")'>
                    @L["Knowledge.Continue.Button"] <i class="ti ti-arrow-right"></i>
                </button>
            </aside>

        </div>
    </section>

    <SiteFooter />
</main>

@code {
    private IReadOnlyList<EvolutionAge> _ages = [];
    private IReadOnlyList<string> _categories = [];
    private IReadOnlyList<KnowledgeCard> _filteredCards = [];
    private readonly IReadOnlyList<(string Slug, string Label)> _featuredPath =
    [
        ("the-internet", "Internet"),
        ("the-world-wide-web", "Website"),
        ("databases", "Database"),
        ("what-is-an-api", "API"),
        ("the-cloud", "Cloud"),
        ("what-is-ai", "AI"),
        ("what-is-rag", "RAG"),
        ("ai-agents", "AI Agents"),
        ("what-is-mcp", "MCP")
    ];

    private string? _selectedAgeKey;
    private string? _selectedCategory;
    private string _searchQuery = string.Empty;
    private string SearchQuery
    {
        get => _searchQuery;
        set
        {
            if (_searchQuery == value)
            {
                return;
            }

            _searchQuery = value;
            UpdateFilters();
        }
    }

    private string SelectedJourneyTitle
        => string.IsNullOrEmpty(_selectedAgeKey)
            ? @L["Knowledge.Journey.DefaultTitle"]
            : $"{_ages.First(a => a.Key == _selectedAgeKey).Name}: {_ages.First(a => a.Key == _selectedAgeKey).Subtitle}";

    private string SelectedJourneyCopy
        => string.IsNullOrEmpty(_selectedAgeKey)
            ? @L["Knowledge.Journey.DefaultCopy"]
            : @L["Knowledge.Journey.EraSubtitleSuffix"];

    protected override void OnInitialized()
    {
        _ages = KnowledgeService.GetAges();
        _categories = KnowledgeService.GetCategories();
        UpdateFilters();
    }

    private void SelectAge(string ageKey)
    {
        _selectedAgeKey = _selectedAgeKey == ageKey ? null : ageKey;
        UpdateFilters();
    }

    private void FilterByCategory(string? category)
    {
        _selectedCategory = category;
        UpdateFilters();
    }

    private void ResetFilters()
    {
        _selectedAgeKey = null;
        _selectedCategory = null;
        SearchQuery = string.Empty;
        UpdateFilters();
    }

    private void UpdateFilters()
    {
        _filteredCards = KnowledgeService.GetCards(_selectedAgeKey, _selectedCategory, _searchQuery);
    }

    protected override void OnParametersSet()
    {
        UpdateFilters();
    }

    private void NavigateToDetail(string slug)
    {
        Nav.NavigateTo($"/knowledge/{slug}");
    }

    private static string GetDefinition(KnowledgeCard card)
        => TrimSentence(card.Summary);

    private static string GetWhyCare(KnowledgeCard card)
        => card.Slug switch
        {
            "what-is-data" => "Every app, report, dashboard, and AI answer starts with data.",
            "what-is-binary" => "It explains how digital machines turn simple signals into useful work.",
            "what-is-an-algorithm" => "Algorithms are the repeatable steps behind search, recommendations, automation, and AI.",
            "the-internet" => "Almost every modern service depends on connected devices exchanging data.",
            "what-is-code" => "Code is how teams turn ideas, business rules, and workflows into software.",
            "the-world-wide-web" => "Websites are still the front door for most products, companies, and learning experiences.",
            "databases" => "Without reliable storage, apps cannot remember users, orders, content, or decisions.",
            "servers-and-clients" => "This pattern explains what happens whenever a browser, app, or AI tool asks for something.",
            "what-is-an-api" => "APIs let products reuse maps, payments, AI models, and business systems instead of rebuilding everything.",
            "automation" => "Automation removes repetitive work so people can focus on judgment and creativity.",
            "git-and-open-source" => "Most professional software work depends on shared code, history, and collaboration.",
            "the-cloud" => "Cloud platforms let teams launch and scale software without buying all the hardware first.",
            "networks-and-ips" => "Networking knowledge helps you understand how devices, services, and cloud systems find each other.",
            "what-is-ai" => "AI is changing how people write, analyze, build, support customers, and make decisions.",
            "what-is-machine-learning" => "Machine learning powers predictions, recommendations, ranking, and many AI systems.",
            "what-is-deep-learning" => "Deep learning is behind many breakthroughs in language, vision, voice, and modern generative AI.",
            "what-is-an-llm" => "LLMs power the chat, writing, coding, and reasoning experiences people now expect from AI.",
            "what-is-a-prompt" => "Prompts are the practical interface between human intent and AI output.",
            "what-is-rag" => "RAG helps AI answer from trusted company or product knowledge instead of guessing.",
            "ai-agents" => "Agents move AI from answering questions to completing multi-step work.",
            "what-is-mcp" => "MCP makes it easier for agents to reach the tools and data they need.",
            _ => "This concept is one of the stepping stones in the technology evolution path."
        };

    private static string GetExample(KnowledgeCard card)
        => card.Slug switch
        {
            "the-internet" => "Video calls, online banking, cloud apps, and AI chat all travel through the internet.",
            "the-world-wide-web" => "A company website, a product dashboard, or an online course is delivered through the Web.",
            "databases" => "A shopping cart remembers items because a database stores them.",
            "what-is-an-api" => "A food delivery app uses APIs for maps, payments, messages, and restaurant menus.",
            "the-cloud" => "Microsoft 365 and Google Drive store files on remote servers you access anywhere.",
            "what-is-ai" => "ChatGPT, Copilot, support chatbots, and image recognition tools are everyday AI examples.",
            "what-is-rag" => "An HR chatbot can answer from company policy PDFs using RAG.",
            "ai-agents" => "An agent can draft emails, check a CRM, summarize results, and prepare a report.",
            "what-is-mcp" => "An AI assistant can connect to a database or CRM through an MCP server.",
            _ => FirstSentence(card.Body)
        };

    private static string GetWithoutIt(KnowledgeCard card)
        => card.Slug switch
        {
            "what-is-data" => "Software would have nothing to process and AI would have nothing to learn from.",
            "what-is-binary" => "Digital hardware would lose its simplest, most reliable way to represent information.",
            "what-is-an-algorithm" => "Computers would not have repeatable instructions for solving problems.",
            "the-internet" => "Modern online services, cloud apps, and remote AI systems would not exist.",
            "what-is-code" => "Most digital products would stay as ideas instead of becoming working tools.",
            "the-world-wide-web" => "People would need separate installed software for many things they now open in a browser.",
            "databases" => "Apps would forget accounts, orders, inventory, messages, and settings.",
            "servers-and-clients" => "Browsers and apps would not have a clear way to request and receive services.",
            "what-is-an-api" => "Software systems would struggle to share data or reuse external capabilities.",
            "automation" => "Humans would repeat manual steps that machines can perform consistently.",
            "git-and-open-source" => "Teams would lose safer collaboration and much of the shared software ecosystem.",
            "the-cloud" => "Companies would need far more physical hardware before launching or scaling products.",
            "networks-and-ips" => "Devices and services would not know where to send information.",
            "what-is-ai" => "Many modern assistants, recommendations, and automation tools would disappear.",
            "what-is-machine-learning" => "Software would rely more on hand-written rules and less on patterns learned from data.",
            "what-is-deep-learning" => "AI would struggle with complex language, vision, and speech tasks.",
            "what-is-an-llm" => "AI would be much weaker at natural language conversations, writing, and code help.",
            "what-is-a-prompt" => "People would have a harder time steering AI toward useful outcomes.",
            "what-is-rag" => "AI would rely more on training data and be less grounded in current private knowledge.",
            "ai-agents" => "People would need to manually perform every step across tools and workflows.",
            "what-is-mcp" => "Every AI-tool connection would need more custom integration work.",
            _ => "The journey would have a gap that makes later concepts harder to understand."
        };

    private IReadOnlyList<(string Slug, string Label)> GetNextTracks(KnowledgeCard card)
    {
        var index = _featuredPath.ToList().FindIndex(track => track.Slug == card.Slug);
        if (index >= 0)
        {
            return _featuredPath.Skip(index + 1).Take(3).ToList();
        }

        return KnowledgeService.GetCards()
            .Where(candidate => candidate.AgeKey == card.AgeKey && candidate.Slug != card.Slug)
            .OrderBy(candidate => candidate.SortOrder)
            .Take(3)
            .Select(candidate => (candidate.Slug, candidate.Title.Replace("What is ", "").Replace("?", "")))
            .ToList();
    }

    private static string FirstSentence(string value)
    {
        var index = value.IndexOf('.');
        return index < 0 ? value : value[..(index + 1)];
    }

    private static string TrimSentence(string value)
        => value.Length <= 130 ? value : $"{value[..127].TrimEnd()}...";


    private string LocalizeCategory(string category) =>
    category.Replace(" & ", "").Replace(" ", "") switch
    {
        "DataLogic"         => L["Category.DataLogic"],
        "Networking"        => L["Category.Networking"],
        "Software"          => L["Category.Software"],
        "Infrastructure"    => L["Category.Infrastructure"],
        "ArtificialIntelligence" => L["Category.ArtificialIntelligence"],
        "PromptEngineering" => L["Category.PromptEngineering"],
        "AIArchitecture"    => L["Category.AIArchitecture"],
        _ => category   // safe fallback
    };

    private string AgeName(EvolutionAge age) => L[$"Age.{ToPascalKey(age.Key)}.Name"];

    private string AgeSubtitle(EvolutionAge age) => L[$"Age.{ToPascalKey(age.Key)}.Subtitle"];

 
    private static string ToPascalKey(string slug)
    {
        var abbreviations = new HashSet<string>(StringComparer.OrdinalIgnoreCase) { "ai", "ip" };
        return string.Concat(slug.Split('-').Select(w =>
            abbreviations.Contains(w) ? w.ToUpper() : char.ToUpper(w[0]) + w[1..]));
    }
    // "ai-era"        → "AIEra"
    // "dinosaur-era"  → "DinosaurEra"
    // "stone-age"     → "StoneAge"

}

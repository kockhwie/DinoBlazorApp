@page "/knowledge/{Slug}"
@using DinoAI.Data
@using DinoAI.Services
@using Microsoft.Extensions.Localization 
@inject IStringLocalizer<SharedResource> L
@inject KnowledgeService KnowledgeService
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Dino AI Academy - @(_card?.Title ?? "Concept Details")</PageTitle>

<main class="detail-page">
    <section class="hero-shell">
        <SiteNav />
    </section>

    <div class="detail-shell">

        <!-- Back Navigation -->
        <div class="mb-2">
            <a href="/knowledge" class="btn btn-xs btn-nav-back">
                <i class="ti ti-arrow-left"></i> @L["Knowledge.Detail.BackToHub"]
            </a>
        </div>

        @if (_card == null)
        {
            <div class="concept-not-found">
                <i class="ti ti-alert-triangle concept-not-found-icon"></i>
                <h2 class="concept-not-found-title">@L["Knowledge.Detail.NotFound.Title"]</h2>
                <p class="concept-not-found-text">@L["Knowledge.Detail.NotFound.Body"]</p>
                <a href="/knowledge" class="btn-primary-gradient" style="max-width:14rem;margin-inline:auto">
                    @L["Knowledge.Detail.BackToHub"]
                </a>
            </div>
        }
        else
        {
            var age = _ages.FirstOrDefault(a => a.Key == _card.AgeKey);

            <article class="concept-article mb-4" style="--age-color: @(age?.AccentColor ?? "#33d7a6")">

                <!-- Decorative glow -->
                <div class="concept-glow" style="background-color: @age?.AccentColor"></div>

                <!-- -- HEADER --------------------------------------------- -->
                <header class="concept-header">
                    <div class="concept-badges">
                        <span class="badge-knowledge-era" style="--section-color: @(age?.AccentColor ?? "#33d7a6")">
                            <i class="@age?.Icon"></i> @AgeName(age!)
                        </span>
                        <span class="badge-knowledge-category" style="--section-color: @(age?.AccentColor ?? "#33d7a6")">@LocalizeCategory(_card.Category)</span>
                    </div>

                    <h2 class="concept-title">
                        <span class="concept-title-icon" style="color: @age?.AccentColor">
                            <i class="@_card.Icon"></i>
                        </span>
                        @_card.Title
                    </h2>

                    <!-- Summary callout -->
                    <div class="summary-callout" style="border-color: @age?.AccentColor">
                        <strong>@L["Knowledge.Detail.InShort"]</strong> @_card.Summary
                    </div>
                </header>

                <!-- -- LEARNING SECTIONS ---------------------------------- -->
                <div class="learning-sections">

                    <section class="learn-section" style="--section-color: @(age?.AccentColor ?? "#33d7a6")">
                        <h2 class="learn-section-title">
                            <i class="ti ti-compass"></i> @L["Knowledge.Card.Definition"]
                        </h2>
                        <p>@_card.Summary</p>
                    </section>

                    <div class="learn-grid-2">
                        <section class="learn-section" style="--section-color: @(age?.AccentColor ?? "#33d7a6")">
                            <h2 class="learn-section-title">
                                <i class="ti ti-bulb"></i> @L["Knowledge.Card.WhyCare"]
                            </h2>
                            <p>@_card.WhyCare</p>
                        </section>

                        <section class="learn-section" style="--section-color: @(age?.AccentColor ?? "#33d7a6")">
                            <h2 class="learn-section-title">
                                <i class="ti ti-map-pin"></i> @L["Knowledge.Card.Example"]
                            </h2>
                            <p>@_card.Example</p>
                        </section>
                    </div>

                    <section class="learn-section" style="--section-color: @(age?.AccentColor ?? "#33d7a6")">
                        <h2 class="learn-section-title">
                            <i class="ti ti-alert-triangle"></i> @L["Knowledge.Card.WithoutIt"]
                        </h2>
                        <p>@_card.WithoutIt</p>
                    </section>

                    <!-- Full explanation body -->
                    <section class="learn-section" style="--section-color: @(age?.AccentColor ?? "#33d7a6")">
                        <h2 class="learn-section-title">
                            <i class="ti ti-book-2"></i> @L["Knowledge.Card.ContinueEvolution"]
                        </h2>
                        <div class="concept-body">@_card.Body</div>
                    </section>

                </div>

                <!-- -- SHARE FOOTER --------------------------------------- -->
                <footer class="concept-footer">
                    <div class="share-row">
                        <span class="share-label">@L["Knowledge.Detail.ShareKnowledge"]</span>
                        <a href="@GetTwitterShareUrl()" target="_blank" class="share-btn" title="Share on X / Twitter">
                            <i class="ti ti-brand-twitter"></i>
                        </a>
                        <a href="@GetFacebookShareUrl()" target="_blank" class="share-btn" title="Share on Facebook">
                            <i class="ti ti-brand-facebook"></i>
                        </a>
                        <a href="@GetLinkedinShareUrl()" target="_blank" class="share-btn" title="Share on LinkedIn">
                            <i class="ti ti-brand-linkedin"></i>
                        </a>
                        <button type="button" @onclick="CopyLinkToClipboard" class="share-btn" title="Copy link">
                            @if (_copied)
                            {
                                <i class="ti ti-check" style="color:#33d7a6"></i>
                            }
                            else
                            {
                                <i class="ti ti-link"></i>
                            }
                        </button>
                        @if (_copied)
                        {
                            <span class="copy-confirm">@L["Knowledge.Detail.LinkCopied"]</span>
                        }
                    </div>
                </footer>
            </article>

            <!-- -- RELATED CONCEPTS --------------------------------------- -->
            @if (_relatedCards.Count > 0)
            {
                <section class="related-section">
                    <h3 class="related-title">@L["Knowledge.Detail.RelatedConcepts"]</h3>
                    <div class="related-grid">
                        @foreach (var rCard in _relatedCards)
                        {
                            var rAge = _ages.FirstOrDefault(a => a.Key == rCard.AgeKey);
                            <button type="button" class="related-card" @onclick="() => NavigateToDetail(rCard.Slug)">
                                <span class="related-icon" style="color: @(rAge?.AccentColor ?? "#33d7a6")">
                                    <i class="@rCard.Icon"></i>
                                </span>
                                <span class="related-copy">
                                    <span class="related-card-title">@rCard.Title</span>
                                    <span class="related-card-summary">@rCard.Summary</span>
                                </span>
                                <i class="ti ti-arrow-right related-arrow"></i>
                            </button>
                        }
                    </div>
                </section>
            }
        }

    </div>

    <SiteFooter />
</main>

@code {
    [Parameter] public string Slug { get; set; } = string.Empty;

    private KnowledgeCard? _card;
    private IReadOnlyList<EvolutionAge> _ages = [];
    private IReadOnlyList<KnowledgeCard> _relatedCards = [];
    private bool _copied = false;

    protected override void OnParametersSet()
    {
        _copied = false;
        _ages = KnowledgeService.GetAges();
        _card = KnowledgeService.GetCardBySlug(Slug);
        _relatedCards = _card != null ? KnowledgeService.GetRelatedCards(Slug, 2) : [];
    }

    private void NavigateToDetail(string slug) => Nav.NavigateTo($"/knowledge/{slug}");

    private string GetTwitterShareUrl() =>
        $"https://twitter.com/intent/tweet?text={Uri.EscapeDataString($"Learning about '{_card?.Title}' on Dino AI Academy! ")}&url={Uri.EscapeDataString(Nav.Uri)}";

    private string GetFacebookShareUrl() =>
        $"https://www.facebook.com/sharer/sharer.php?u={Uri.EscapeDataString(Nav.Uri)}";

    private string GetLinkedinShareUrl() =>
        $"https://www.linkedin.com/sharing/share-offsite/?url={Uri.EscapeDataString(Nav.Uri)}";

    private async Task CopyLinkToClipboard()
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", Nav.Uri);
            _copied = true;
            StateHasChanged();
            await Task.Delay(2000);
            _copied = false;
            StateHasChanged();
        }
        catch { }
    }

    private string LocalizeCategory(string category) =>
        category.Replace(" & ", "").Replace(" ", "") switch
        {
            "DataLogic"         => L["Category.DataLogic"],
            "Networking"        => L["Category.Networking"],
            "Software"          => L["Category.Software"],
            "Infrastructure"    => L["Category.Infrastructure"],
            "ArtificialIntelligence" => L["Category.ArtificialIntelligence"],
            "PromptEngineering" => L["Category.PromptEngineering"],
            "AIArchitecture"    => L["Category.AIArchitecture"],
            _ => category
        };

    private string AgeName(EvolutionAge age) => L[$"Age.{ToPascalKey(age.Key)}.Name"];

    private static string ToPascalKey(string slug)
    {
        var abbreviations = new HashSet<string>(StringComparer.OrdinalIgnoreCase) { "ai", "ip" };
        return string.Concat(slug.Split('-').Select(w =>
            abbreviations.Contains(w) ? w.ToUpper() : char.ToUpper(w[0]) + w[1..]));
    }
}
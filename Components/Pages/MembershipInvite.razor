@page "/membership"
@page "/join"

<PageTitle>@T["Membership By Invitation"]</PageTitle>

<main class="membership-page">
    <section class="membership-panel">
        <a href="/" class="membership-brand" aria-label="@T["Dino AI Academy home"]">
            <img alt="@T["Dino mascot"]" class="membership-logo" src="@Assets["assets/company_logo.png"]" />
            <img alt="@T["Dino AI Academy"]" class="membership-wordmark" src="@Assets["assets/company_name.png"]" />
        </a>

        <div class="membership-copy">
            <p class="membership-kicker">@T["Membership Access"]</p>
            <h1>@T["Invitation-only registration is currently in place."]</h1>
            <p>
                @T["Dino AI Academy membership is free. At this stage, access is available by invitation only while we prepare the full login and registration experience."]
            </p>
            <p>
                @T["To be considered for the waiting list, please email the admin team and we will keep your request for future intake."]
            </p>
        </div>

        <div class="membership-actions">
            <a class="btn membership-primary" href="mailto:admin@codingdinos.asia?subject=Dino%20AI%20Academy%20Membership%20Request">
                @T["Email Admin"]
            </a>
            <a class="btn membership-secondary" href="/">
                @T["Back to Home"]
            </a>
        </div>
    </section>
</main>

@page "/membership"
@page "/join"

<PageTitle>Membership By Invitation</PageTitle>

<main class="membership-page">
    <section class="membership-panel">
        <a href="/" class="membership-brand" aria-label="Dino AI Academy home">
            <img alt="Dino mascot" class="membership-logo" src="@Assets["assets/company_logo.png"]" />
            <img alt="Dino AI Academy" class="membership-wordmark" src="@Assets["assets/company_name.png"]" />
        </a>

        <div class="membership-copy">
            <p class="membership-kicker">Membership Access</p>
            <h1>Invitation-only registration is currently in place.</h1>
            <p>
                Dino AI Academy membership is free. At this stage, access is available by invitation only while we prepare the full login and registration experience.
            </p>
            <p>
                To be considered for the waiting list, please email the admin team and we will keep your request for future intake.
            </p>
        </div>

        <div class="membership-actions">
            <a class="btn membership-primary" href="mailto:admin@codingdinos.asia?subject=Dino%20AI%20Academy%20Membership%20Request">
                Email Admin
            </a>
            <a class="btn membership-secondary" href="/">
                Back to Home
            </a>
        </div>
    </section>
</main>

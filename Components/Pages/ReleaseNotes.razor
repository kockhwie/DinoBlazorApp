    private async Task ScrollToVersion(string versionId)
    {
        var elementId = "v" + versionId.Replace(".", "");
        await JS.InvokeVoidAsync("scrollToVersionElement", elementId);
    }

    private class LogVersion
    {
        public string Id       { get; set; } = "";
        public string Date     { get; set; } = "";
        public string Subtitle { get; set; } = "";
        public List<string> Added      { get; set; } = new();
        public List<string> Changed    { get; set; } = new();
        public List<string> Deprecated { get; set; } = new();
        public List<string> Removed    { get; set; } = new();
        public List<string> Fixed      { get; set; } = new();
        public List<string> Security   { get; set; } = new();

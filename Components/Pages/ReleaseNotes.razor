@page "/release-notes"

<PageTitle>@T["Release Notes - Dino AI Academy"]</PageTitle>

<main class="release-page">
    <section class="release-shell">
        <div class="release-header">
            <a href="/" class="release-brand" aria-label="@T["Dino AI Academy home"]">
                <img alt="@T["Dino mascot"]" class="release-logo" src="@Assets["assets/company_logo.png"]" />
                <img alt="@T["Dino AI Academy"]" class="release-wordmark" src="@Assets["assets/company_name.png"]" />
            </a>

            <div class="release-heading">
                <p class="release-kicker">@T["Release Notes"]</p>
                <h1>@T["Version 2 is ready for release."]</h1>
                <p>
                    @T["This release prepares the public Dino AI Academy website for sharing on GitHub with a refreshed homepage, clearer membership flow, and a cleaner AI workbench preview."]
                </p>
            </div>
        </div>

        <article class="release-card">
            <div class="release-card-header">
                <span class="release-version">v2.0.0</span>
                <span class="release-date">May 31, 2026</span>
            </div>

            <div class="release-section">
                <h2>@T["Added"]</h2>
                <ul>
                    <li>@T["New invitation-only membership page for Login, Join Academy, and Start Your Evolution actions."]</li>
                    <li>@T["Change Admin email call-to-action for membership enquiries."]</li>
                    <li>@T["Release notes page for tracking public website updates."]</li>
                    <li>@T["Added.Localization"]</li>
                </ul>
            </div>

            <div class="release-section">
                <h2>@T["Changed"]</h2>
                <ul>
                    <li>@T["Updated the homepage with a refreshed Dino AI Academy landing experience."]</li>
                    <li>@T["Improved the AI Workbench email composer with cleaner green styling and easier-to-maintain CSS variables."]</li>
                    <li>@T["Replaced unfinished login and registration entry points with a professional invitation-only message."]</li>
                </ul>
            </div>

            <div class="release-section">
                <h2>@T["Fixed"]</h2>
                <ul>
                    <li>@T["Fixed the email composer input styling by using native bound HTML controls that work correctly with page-scoped CSS."]</li>
                    <li>@T["Reduced button and form spacing so the workbench preview is more compact and readable."]</li>
                </ul>
            </div>
        </article>

        <div class="release-actions">
            <a class="btn release-primary" href="/">@T["Back to Home"]</a>
            <a class="btn release-secondary" href="mailto:admin@codingdinos.asia?subject=Dino%20AI%20Academy%20Feedback">@T["Send Feedback"]</a>
        </div>
    </section>
</main>

<style>
    .release-page {
        min-height: 100vh;
        padding: clamp(1rem, 4vw, 3rem);
        background:
            radial-gradient(circle at 50% 18%, rgba(60, 201, 128, 0.18), transparent 22%),
            radial-gradient(circle at 82% 18%, rgba(42, 201, 161, 0.16), transparent 20%),
            linear-gradient(180deg, #020405 0%, #03110d 52%, #020405 100%);
        color: rgba(245, 250, 248, 0.94);
    }

    .release-shell {
        width: min(100%, 62rem);
        margin: 0 auto;
        display: grid;
        gap: 1rem;
    }

    .release-header,
    .release-card {
        border: 1px solid rgba(58, 209, 141, 0.2);
        border-radius: 1rem;
        background: rgba(2, 12, 9, 0.88);
        box-shadow: 0 24px 60px rgba(0, 0, 0, 0.34);
    }

    .release-header {
        display: grid;
        gap: 1.25rem;
        padding: clamp(1.25rem, 4vw, 2.5rem);
    }

    .release-brand {
        display: inline-flex;
        align-items: center;
        gap: 0.65rem;
        width: fit-content;
    }

    .release-logo {
        height: 2.8rem;
        width: auto;
    }

    .release-wordmark {
        height: 2.65rem;
        width: auto;
    }

    .release-heading {
        display: grid;
        gap: 0.75rem;
    }

    .release-kicker {
        margin: 0;
        color: #4ee1b6;
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 0.16em;
        text-transform: uppercase;
    }

    .release-heading h1 {
        margin: 0;
        color: #f5f7f7;
        font-family: "Sora", "DM Sans", sans-serif;
        font-size: clamp(2rem, 5vw, 3.35rem);
        line-height: 1;
        font-weight: 800;
    }

    .release-heading p,
    .release-section li {
        color: rgba(229, 240, 235, 0.82);
        line-height: 1.6;
    }

    .release-heading p {
        margin: 0;
        max-width: 46rem;
        font-size: 1rem;
    }

    .release-card {
        display: grid;
        gap: 1.25rem;
        padding: clamp(1.25rem, 4vw, 2rem);
    }

    .release-card-header {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 0.75rem;
        padding-bottom: 0.9rem;
        border-bottom: 1px solid rgba(78, 225, 182, 0.16);
    }

    .release-version {
        color: #80e36b;
        font-size: 1.15rem;
        font-weight: 800;
    }

    .release-date {
        color: rgba(229, 240, 235, 0.64);
        font-size: 0.9rem;
    }

    .release-section {
        display: grid;
        gap: 0.55rem;
    }

    .release-section h2 {
        margin: 0;
        color: #59dc98;
        font-size: 0.9rem;
        font-weight: 800;
        letter-spacing: 0.1em;
        text-transform: uppercase;
    }

    .release-section ul {
        display: grid;
        gap: 0.45rem;
        margin: 0;
        padding-left: 1.1rem;
    }

    .release-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
    }

    .release-primary,
    .release-secondary {
        min-height: 2.7rem;
        border-radius: 0.7rem;
        padding-inline: 1rem;
        font-weight: 700;
    }

    .release-primary {
        border: 0;
        background: linear-gradient(90deg, #2dc98e 0%, #80e36b 100%);
        color: #07110d;
    }

    .release-secondary {
        border: 1px solid rgba(78, 225, 182, 0.32);
        background: rgba(255, 255, 255, 0.02);
        color: rgba(245, 250, 248, 0.9);
    }

    @@media (max-width: 520px) {
        .release-actions {
            display: grid;
        }
    }
</style>

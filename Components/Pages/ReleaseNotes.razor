@page "/release-notes"
@using Markdig
@inject IJSRuntime JS

<div class="changelog-container">
    <!-- SIDEBAR FOR NAVIGATION -->
    <aside class="changelog-sidebar">
        <div class="sidebar-header">
            <i class="fa-solid fa-dna"></i>
            <span>Fossil Record</span>
        </div>
        <nav class="version-nav">
            @foreach (var version in versions)
            {
                <a @onclick="() => ScrollToVersion(version.Id)" @onclick:preventDefault class="nav-item">
                    <span class="v-label">@version.Id</span>
                    <span class="v-date">@version.Date</span>
                </a>
            }
        </nav>

        <footer class="changelog-footer">
            <a href="/" class="back-link button"><i class="fa-solid fa-arrow-left"></i> 🦕 Return to the academy</a>
        </footer>

    </aside>

    <!-- MAIN CONTENT -->
    <main class="changelog-main">
        <!-- MOBILE BACK LINK -->
        <a href="/" class="mobile-back-link"><i class="fa-solid fa-arrow-left"></i> 🦕 Return to the academy</a>
        <!-- MOBILE VERSION STRIP -->
        <div class="mobile-version-strip">
            @foreach (var version in versions)
            {
                <a @onclick="() => ScrollToVersion(version.Id)" @onclick:preventDefault class="mobile-nav-pill">
                    v@version.Id
                </a>
            }
        </div>

        <header class="main-header">
            <h1>🦖 Dino Evolution Log</h1>
            <p>All notable mutations to <strong>Dino Prompt Academy</strong> are documented in this fossil record.</p>
        </header>

        <section class="log-content">
            @foreach (var v in versions)
            {
                <article id="v@(v.Id.Replace(".", ""))" class="version-block">
                    <div class="version-header">
                        <h2 class="version-number">[@v.Id] — @v.Date</h2>
                    </div>

                    @if (v.Added.Any())
                    {
                        <div class="change-group">
                            <h3>🧬 Added</h3>
                            <ul>
                                @foreach (var item in v.Added) { <li>@item</li> }
                            </ul>
                        </div>
                    }

                    @if (v.Changed.Any())
                    {
                        <div class="change-group">
                            <h3>🔄 Changed</h3>
                            <ul>
                                @foreach (var item in v.Changed) { <li>@item</li> }
                            </ul>
                        </div>
                    }

                    @if (v.Deprecated.Any())
                    {
                        <div class="change-group">
                            <h3>🪨 Deprecated</h3>
                            <ul>
                                @foreach (var item in v.Deprecated) { <li>@item</li> }
                            </ul>
                        </div>
                    }

                    @if (v.Removed.Any())
                    {
                        <div class="change-group">
                            <h3>☄️ Removed</h3>
                            <ul>
                                @foreach (var item in v.Removed) { <li>@item</li> }
                            </ul>
                        </div>
                    }

                    @if (v.Fixed.Any())
                    {
                        <div class="change-group">
                            <h3>🩹 Fixed</h3>
                            <ul>
                                @foreach (var item in v.Fixed) { <li>@item</li> }
                            </ul>
                        </div>
                    }

                    @if (v.Security.Any())
                    {
                        <div class="change-group">
                            <h3>🛡️ Security</h3>
                            <ul>
                                @foreach (var item in v.Security) { <li>@item</li> }
                            </ul>
                        </div>
                    }
                </article>
            }
        </section>


    </main>
</div>

<style>
    .changelog-container {
        display: grid;
        grid-template-columns: 280px 1fr;
        height: 100vh;
        background: #0d0f17;
        color: #eee;
        font-family: 'Inter', -apple-system, sans-serif;
    }

    /* SIDEBAR */
    .changelog-sidebar {
        background: #080a0f;
        border-right: 1px solid rgba(255, 255, 255, 0.05);
        padding: 40px 20px;
        overflow-y: auto;
    }

    .sidebar-header {
        display: flex;
        align-items: center;
        gap: 12px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: #10b981;
        margin-bottom: 40px;
        padding-left: 10px;
    }

    .version-nav {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .nav-item {
        display: flex;
        flex-direction: column;
        padding: 12px 15px;
        border-radius: 12px;
        text-decoration: none;
        color: #888;
        transition: all 0.2s;
        border: 1px solid transparent;
    }

    .nav-item:hover {
        background: rgba(255, 255, 255, 0.03);
        color: #fff;
    }

    .nav-item .v-label {
        font-weight: 700;
        font-size: 0.95rem;
    }

    .nav-item .v-date {
        font-size: 0.75rem;
        opacity: 0.6;
    }

    /* MAIN */
    .changelog-main {
        overflow-y: auto;
        padding: 60px 80px;
        scroll-behavior: smooth;
    }

    .main-header {
        max-width: 800px;
        margin-bottom: 60px;
    }

    .main-header h1 {
        font-size: 3rem;
        font-weight: 900;
        margin: 0 0 15px;
        color: #fff;
    }

    .main-header p {
        font-size: 1.2rem;
        color: #aaa;
        line-height: 1.6;
    }

    .principle-note {
        margin-top: 20px;
        font-size: 0.9rem;
        color: #666;
    }

    .principle-note a {
        color: #10b981;
        text-decoration: none;
    }

    /* LOG CONTENT */
    .log-content {
        max-width: 800px;
    }

    .version-block {
        margin-bottom: 80px;
        scroll-margin-top: 60px;
    }

    .version-header {
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        margin-bottom: 30px;
        padding-bottom: 10px;
    }

    .version-number {
        font-size: 1.8rem;
        font-weight: 700;
        color: #10b981;
    }

    .change-group {
        margin-bottom: 30px;
    }

    .change-group h3 {
        font-size: 1.1rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #fff;
        margin-bottom: 15px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .change-group ul {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .change-group li {
        position: relative;
        padding-left: 20px;
        margin-bottom: 10px;
        color: #ccc;
        line-height: 1.6;
    }

    .change-group li::before {
        content: "-";
        position: absolute;
        left: 0;
        color: #10b981;
        font-weight: 900;
    }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        margin-top: 40px;
        color: #10b981;
        text-decoration: none;
        transition: all 0.2s;
        font-weight: 600;
    }

    .back-link:hover {
        opacity: 0.8;
        transform: translateX(-4px);
    }

    .mobile-back-link {
        display: none;
    }

    @@media (max-width: 1024px) {
        .mobile-back-link {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            color: #10b981;
            text-decoration: none;
            font-size: 0.9rem;
            font-weight: 600;
            margin-bottom: 20px;
        }
        .changelog-container {
            grid-template-columns: 1fr;
        }
        .changelog-sidebar {
            display: none;
        }
        .changelog-main {
            padding: 40px 20px;
        }
        .mobile-version-strip {
            display: flex;
        }
    }

    .mobile-version-strip {
        display: none;
        gap: 10px;
        overflow-x: auto;
        padding: 15px 0;
        margin-bottom: 30px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .mobile-nav-pill {
        flex-shrink: 0;
        padding: 8px 16px;
        border-radius: 20px;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: #aaa;
        font-size: 0.85rem;
        font-weight: 600;
        text-decoration: none;
        cursor: pointer;
        transition: all 0.2s;
    }

    .mobile-nav-pill:hover {
        background: rgba(16, 185, 129, 0.15);
        color: #10b981;
        border-color: #10b981;
    }
</style>

<script>
    window.scrollToVersionElement = (elementId) => {
        const el = document.getElementById(elementId);
        if (el) {
            el.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
    };
</script>

@code {
